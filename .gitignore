# SLBC source data — keep local only (PDFs, zips, scrapes, intermediate JSONs)
slbc-data/**/*.pdf
slbc-data/**/*.zip
slbc-data/**/*.rar
slbc-data/**/*.xlsx
slbc-data/**/*.xls
slbc-data/**/quarterly/
slbc-data/**/extracted/
# Exception: tracked wayback-extracted JSONs are committed artifacts
# (raw historical SLBC tables recovered from Wayback). The PDFs they
# came from are gitignored above but the structured extractions are
# durable and reproducible from db/extract_wayback_*.py + the manifest.
!slbc-data/**/wayback/extracted/
!slbc-data/**/wayback/extracted/*.json
slbc-data/**/_temp/
slbc-data/**/pdfs/
slbc-data/**/downloads/
slbc-data/**/data-tables/
slbc-data/scraped_data/
slbc-data/**/scraped_data/
# Large intermediate scrape outputs
slbc-data/ne_*.json
slbc-data/*_checkpoint.json
slbc-data/*_blockwise_*.json
slbc-data/scraped_data/

# Intermediate per-state extraction outputs (large; canonical copies live in public/slbc-data/)
slbc-data/**/*_complete.json
slbc-data/**/*_fi_timeseries.json
slbc-data/**/*_fi_timeseries.csv
slbc-data/**/*_fi_slim.json

# Public-side SLBC source PDFs (downloads served via separate route — keep local)
public/slbc-data/**/*.pdf
public/slbc-data/**/*.zip
public/slbc-data/**/*.xlsx
public/slbc-data/**/pdfs/

# Scrape outputs
scraped_data/
scraped_data_fy26/

# Local build/dev artifacts
.cache/

# Audit: regenerated download-panel output (reproducible via audit/generate_panels.py)
audit/panels/
