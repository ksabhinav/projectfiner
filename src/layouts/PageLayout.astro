---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  pageTitle: string;
  subtitle?: string;
  backLink?: { href: string; label: string };
  activeSubNav?: string;
  hideFooter?: boolean;
}

const { title, pageTitle, subtitle, backLink, activeSubNav, hideFooter } = Astro.props;
---

<BaseLayout title={title}>
  <Header title={pageTitle} subtitle={subtitle} backLink={backLink} activeSubNav={activeSubNav} />
  <slot />
  {!hideFooter && <Footer />}
</BaseLayout>
