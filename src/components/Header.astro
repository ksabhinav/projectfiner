---
interface Props {
  title: string;
  subtitle?: string;
  backLink?: { href: string; label: string };
}

const { title, subtitle, backLink } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class="site-header">
  <nav class="site-nav">
    <a href={`${base}`} class="nav-brand">Project FINER</a>
    <div class="nav-links">
      <a href={`${base}`}>Home</a>
      <a href={`${base}capital-markets/map`}>Map</a>
      <a href={`${base}capital-markets/data-download`}>Downloads</a>
      <a href={`${base}slbc-data`}>SLBC Data</a>
      <a href={`${base}analysis`}>Analysis</a>
    </div>
  </nav>
  <div class="header-content">
    <h1>{title}</h1>
    {subtitle && <p set:html={subtitle} />}
    {backLink && <p><a href={backLink.href}>&larr; {backLink.label}</a></p>}
  </div>
</header>

<style>
  .site-header {
    background: #fff;
    border-bottom: 1px solid var(--border-dark);
  }
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 40px;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-sans);
    font-size: 11px;
  }
  .nav-brand {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 14px;
    color: var(--muted);
  }
  .nav-brand:hover { color: var(--text); }
  .nav-links {
    display: flex;
    gap: 24px;
  }
  .nav-links a {
    color: var(--muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 10px;
  }
  .nav-links a:hover { color: var(--accent); }
  .header-content {
    padding: 28px 40px 24px;
  }
  .header-content h1 {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 6px;
  }
  .header-content p {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    color: var(--muted);
    line-height: 1.7;
    max-width: 640px;
  }
</style>
