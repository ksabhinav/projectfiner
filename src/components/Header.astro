---
/**
 * Header.astro — Atlas identity
 *
 * Four-bar mark + FINER. wordmark + capsule nav + gradient hairline.
 * The page-hero / sub-nav / burger menu from the legacy header are gone.
 * Pages render their own H1 in the page body.
 *
 * Props:
 *   transparent — homepage map overlay (frosted paper instead of solid)
 *   activeNav   — 'map' | 'news' | 'downloads' | 'ask' | 'about'
 *   title       — accepted but unused (legacy compat for pages still passing it)
 */

interface Props {
  transparent?: boolean;
  activeNav?: 'map' | 'news' | 'downloads' | 'ask' | 'about';
  title?: string;
  subtitle?: string;
  backLink?: { href: string; label: string };
  activeSubNav?: string;
}

const { transparent = false, activeNav = 'map' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class={`finer-header ${transparent ? 'transparent' : ''}`}>
  <a href={base} class="brand" aria-label="FINER home">
    <svg class="brand-mark" viewBox="0 0 18 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="0" y="2"  width="7"  height="3" fill="#B84A2E"/>
      <rect x="0" y="7"  width="11" height="3" fill="#1B140E"/>
      <rect x="0" y="12" width="18" height="3" fill="#1B140E"/>
      <rect x="0" y="17" width="9"  height="3" fill="#D4A24A"/>
    </svg>
    <span class="brand-text">FINER<span class="brand-dot">.</span></span>
  </a>

  <nav class="nav" aria-label="Primary">
    <a href={base} class={`nav-cap ${activeNav === 'map' ? 'active' : ''}`}>Map</a>
    <a href={`${base}downloads/`} class={`nav-cap ${activeNav === 'downloads' ? 'active' : ''}`}>Downloads</a>
    <a href={`${base}ask`} class={`nav-cap ${activeNav === 'ask' ? 'active' : ''}`}>Ask</a>
    <a href={`${base}about`} class={`nav-cap ${activeNav === 'about' ? 'active' : ''}`}>About</a>
  </nav>
</header>

{/* Atlas Header CSS lives in src/styles/global.css to avoid Astro scoped-CSS quirks */}
