---
import PageLayout from '../../layouts/PageLayout.astro';
import AskChat from '../../components/AskChat.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Ask | Project FINER"
  pageTitle="Ask FINER"
  subtitle="District-level financial inclusion data across 16 states — powered by AI."
>
  <div class="container">
    <AskChat client:load />
  </div>
</PageLayout>

<style>
  .container { max-width: 720px; margin: 0 auto; padding: 0 32px 20px; }
  @media (max-width: 640px) {
    .container { padding: 0 16px 16px; }
  }
</style>
