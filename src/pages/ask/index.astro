---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import AskChat from '../../components/AskChat.svelte';
---

<BaseLayout title="Ask | Project FINER" description="Ask FINER about district-level financial inclusion data — every reply cites its sources.">
  <Header activeNav="ask" />

  <div class="ask-page">
    <div class="ask-head">
      <div class="ask-eye">RAG over SLBC bookers · 22 states · 39 quarters</div>
      <h1 class="ask-title">
        Ask <span class="em">FINER</span>.
      </h1>
      <p class="ask-dek">
        Natural-language questions about district-level financial inclusion. Every reply cites the SLBC meeting it draws from. The model reads ~26,000 chunks of source material — meeting agendas, indicator tables, trend summaries — to answer.
      </p>
    </div>

    <AskChat client:load />
  </div>
</BaseLayout>

<style>
  /* Layout: page height pinned to viewport, hero is fixed-size, chat takes
     the remaining flex space and scrolls internally when long. Page itself
     never scrolls. */
  .ask-page {
    max-width: 880px;
    margin: 0 auto;
    padding: 28px 32px 16px;
    height: calc(100vh - 52px);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ask-head {
    flex-shrink: 0;
    margin-bottom: 14px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--rule, #D9D2C5);
  }

  .ask-eye {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--vermillion, #B84A2E);
    margin-bottom: 10px;
  }

  .ask-title {
    font-family: 'Fraunces', Georgia, serif;
    font-weight: 380;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
    font-size: 38px;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--ink, #1B140E);
    margin: 0 0 4px;
  }
  .ask-title .em {
    color: var(--vermillion-d, #8E331E);
    font-style: italic;
    font-weight: 320;
  }

  .ask-dek {
    font-family: 'Source Serif 4', Georgia, serif;
    font-style: italic;
    font-size: 14px;
    color: var(--ink-soft, #3D332A);
    line-height: 1.5;
    margin: 0;
    max-width: 640px;
  }

  @media (max-width: 760px) {
    .ask-page { padding: 18px 18px 10px; }
    .ask-title { font-size: 28px; }
    .ask-dek { font-size: 13px; }
  }
</style>
