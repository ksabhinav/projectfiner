---
import PageLayout from '../../layouts/PageLayout.astro';
import AskChat from '../../components/AskChat.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Ask | Project FINER"
  pageTitle=""
  subtitle=""
  hideFooter
>
  <div class="container">
    <AskChat client:load />
  </div>
</PageLayout>

<style>
  .container { max-width: 720px; margin: 0 auto; padding: 0 32px 0; }
  @media (max-width: 640px) {
    .container { padding: 0 12px 0; }
  }
</style>
