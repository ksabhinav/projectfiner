---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="FI Indicators — Project FINER">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <div id="map"></div>

  <div id="panel">
    <div id="panel-head">
      <h1>FI Indicators</h1>
      <p class="panel-sub">District-level Financial Inclusion · North East India</p>
    </div>

    <nav class="panel-nav">
      <a href={`${base}`} class="nav-pill">Map</a>
      <a href={`${base}slbc-data`} class="nav-pill">SLBC Data</a>
      <a href={`${base}capital-markets/data-download`} class="nav-pill">Downloads</a>
      <a href={`${base}analysis`} class="nav-pill">Analysis</a>
    </nav>

    <div id="panel-body">
      <!-- Indicator selector -->
      <div class="field">
        <span class="flabel">Indicator</span>
        <select class="finput" id="sel-indicator">
          <option value="credit_deposit_ratio">Credit-Deposit Ratio</option>
          <option value="pmjdy">PM Jan Dhan Yojana</option>
          <option value="branch_network">Branch Network</option>
          <option value="kcc">Kisan Credit Card</option>
          <option value="shg">Self Help Groups</option>
          <option value="digital_transactions">Digital Transactions</option>
          <option value="aadhaar_authentication">Aadhaar Authentication</option>
        </select>
      </div>

      <!-- Metric selector (populated dynamically) -->
      <div class="field">
        <span class="flabel">Metric</span>
        <select class="finput" id="sel-metric"></select>
      </div>

      <!-- Quarter selector -->
      <div class="field">
        <span class="flabel">Quarter</span>
        <select class="finput" id="sel-quarter"></select>
      </div>

      <div style="height:1px;background:#e8e5e0;margin:10px 0"></div>

      <!-- State filter -->
      <div class="field">
        <span class="flabel">State</span>
        <select class="finput" id="sel-state">
          <option value="">All NE States</option>
          <option value="ASSAM">Assam</option>
          <option value="MEGHALAYA">Meghalaya</option>
          <option value="MANIPUR">Manipur</option>
          <option value="ARUNACHAL PRADESH">Arunachal Pradesh</option>
          <option value="MIZORAM">Mizoram</option>
          <option value="TRIPURA">Tripura</option>
          <option value="NAGALAND">Nagaland</option>
          <option value="SIKKIM">Sikkim</option>
        </select>
      </div>

      <div id="stats">Loading…</div>
      <button id="btn-reset">&#8634; Reset</button>
    </div>
  </div>

  <!-- Legend -->
  <div id="choro-legend">
    <div id="legend-title" style="font-size:8px;letter-spacing:0.1em;text-transform:uppercase;color:#aaa09a;margin-bottom:4px">Overall CD Ratio</div>
    <div class="choro-scale" id="legend-scale"></div>
    <div class="choro-labels" id="legend-labels"></div>
    <div style="display:flex;align-items:center;gap:5px;margin-top:6px;padding-top:5px;border-top:1px solid #e8e5e0">
      <div style="width:12px;height:12px;background:#e8e4dc;border:1px solid #ccc8c0;flex-shrink:0"></div>
      <span style="font-size:8px;color:#aaa09a;letter-spacing:0.04em">No data</span>
    </div>
  </div>

  <div id="wm">Project FINER</div>

  <script is:inline define:vars={{ base }}>
    window.__FINER_BASE = base;
  </script>

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline>
    const _B = window.__FINER_BASE;
    const DIST_URL = _B + 'data/district_boundaries.geojson';

    const NE_STATES = ['ASSAM','MEGHALAYA','MANIPUR','MIZORAM','NAGALAND','TRIPURA','ARUNACHAL PRADESH','SIKKIM'];
    const STATE_SLUGS = {
      'ASSAM': 'assam', 'MEGHALAYA': 'meghalaya', 'MANIPUR': 'manipur',
      'MIZORAM': 'mizoram', 'NAGALAND': 'nagaland', 'TRIPURA': 'tripura',
      'ARUNACHAL PRADESH': 'arunachal-pradesh', 'SIKKIM': 'sikkim',
    };

    // ── Indicator definitions ──
    const INDICATORS = {
      credit_deposit_ratio: {
        title: 'Credit-Deposit Ratio',
        metrics: [
          { field: 'overall_cd_ratio', label: 'Overall CD Ratio (%)', unit: '%', fallbacks: ['cd_ratio', 'current_c_d_ratio', 'cdr', 'overall'] },
          { field: 'total_deposit', label: 'Total Deposits (₹ Lakh)', unit: '₹L', fallbacks: ['deposit', 'deposits_rural'] },
          { field: 'total_advance', label: 'Total Advances (₹ Lakh)', unit: '₹L', fallbacks: ['advance', 'advances'] },
          { field: 'total_branch', label: 'Total Branches', unit: '', fallbacks: ['total', 'no_of_brs'] },
        ],
      },
      pmjdy: {
        title: 'PM Jan Dhan Yojana',
        metrics: [
          { field: 'total_pmjdy_no', label: 'Total PMJDY Accounts', unit: '', fallbacks: ['pmjdy_no', 'total_no', 'no_of_pmjdy_accounts', 'pmjdy'] },
          { field: 'no_of_zero_balance_a_c', label: 'Zero Balance Accounts', unit: '' },
          { field: 'no_of_aadhaar_seeded', label: 'Aadhaar Seeded', unit: '' },
          { field: 'no_of_rupay_card_issued', label: 'RuPay Cards Issued', unit: '' },
          { field: 'female_no', label: 'Female Accounts', unit: '', fallbacks: ['no_of_women_pmjdy_accounts'] },
          { field: 'rural_no', label: 'Rural Accounts', unit: '' },
        ],
      },
      branch_network: {
        title: 'Branch Network',
        metrics: [
          { field: 'total_branch', label: 'Total Branches', unit: '', fallbacks: ['total', 'no_of_branches'] },
          { field: 'branch_rural', label: 'Rural Branches', unit: '', fallbacks: ['atm_rural'] },
          { field: 'branch_semi_urban', label: 'Semi-Urban Branches', unit: '', fallbacks: ['semi_urban'] },
          { field: 'branch_urban', label: 'Urban Branches', unit: '', fallbacks: ['urban'] },
          { field: 'total_atm', label: 'Total ATMs', unit: '', fallbacks: ['no_of_atm'] },
          { field: 'total_csp', label: 'Total CSPs', unit: '', fallbacks: ['bc_total'] },
        ],
      },
      kcc: {
        title: 'Kisan Credit Card',
        metrics: [
          { field: 'total_no_of_kcc', label: 'Total KCC Issued', unit: '', fallbacks: ['no_of_kcc', 'kcc_no', 'total_kcc_no', 'total_no', 'o_s_position_no_of_cards_issued', 'cum_no_app_sanc', 'no_of_kcc_issued_during_quarter_including_renewal'] },
          { field: 'outstanding_amt', label: 'Outstanding Amount (₹ Lakh)', unit: '₹L', fallbacks: ['total_outstanding', 'total_o_s_kcc_amt', 'kcc_outstanding', 'kcc_outstanding', 'o_s_position_limit_sanctioned', 'kcc_limit_sanctioned_in_rs_lakhs'] },
          { field: 'no_of_rupay_card_issued', label: 'RuPay Cards Issued', unit: '' },
          { field: 'kcc_card_activated', label: 'Cards Activated', unit: '', fallbacks: ['card_activated'] },
        ],
      },
      shg: {
        title: 'Self Help Groups',
        metrics: [
          { field: 'savings_linked_no', label: 'Savings Linked SHGs', unit: '', fallbacks: ['savings_linked', 'credit_linked_no', 'credit_linked', 'current_fy_savings_linked_no', 'no_of_shgs', 'deposit_linkage_no_of_groups'] },
          { field: 'credit_linked_no', label: 'Credit Linked SHGs', unit: '', fallbacks: ['credit_linked', 'current_fy_credit_linked_no', 'credit_linkage_loan_given_by_banks_no'] },
          { field: 'shg_o_s_amt', label: 'Outstanding Amount (₹ Lakh)', unit: '₹L', fallbacks: ['outstanding_amt', 'shg_o_s', 'outstanding_accounts'] },
          { field: 'shg_npa_pct', label: 'SHG NPA %', unit: '%' },
        ],
      },
      digital_transactions: {
        title: 'Digital Transactions',
        metrics: [
          { field: 'bhim_upi_a_c', label: 'BHIM/UPI Transactions', unit: '', fallbacks: ['bhim_upi', 'coverage_pct'] },
          { field: 'bhim_upi_amt', label: 'UPI Amount (₹ Lakh)', unit: '₹L' },
          { field: 'imps_a_c', label: 'IMPS Transactions', unit: '', fallbacks: ['imps'] },
          { field: 'cards_debit_credit_a_c', label: 'Card Transactions', unit: '', fallbacks: ['cards_debit_credit', 'cards_debit'] },
        ],
      },
      aadhaar_authentication: {
        title: 'Aadhaar Authentication',
        metrics: [
          { field: 'no_of_aadhaar_seeded_casa', label: 'Aadhaar Seeded CASA', unit: '', fallbacks: ['aadhaar_seeded_casa'] },
          { field: 'no_of_operative_casa', label: 'Operative CASA', unit: '', fallbacks: ['operative_casa'] },
          { field: 'no_of_authenticated_casa', label: 'Authenticated CASA', unit: '', fallbacks: ['authenticated_casa'] },
        ],
      },
    };

    // ── Color ramps ──
    // Terracotta ramp for most indicators
    const RAMP_DEFAULT = ['#faf6f0','#f0e0c8','#e8c89a','#d4a06a','#b8603e','#8a3a1a'];
    // Green ramp for CD ratio (higher is better)
    const RAMP_GREEN = ['#f5f9f0','#d4eac0','#a8d48a','#6ab04c','#3a8a2a','#1a5a10'];
    // Blue ramp for digital
    const RAMP_BLUE = ['#f0f5fa','#c8ddf0','#8ab8d4','#4a90b8','#2a6a8e','#104060'];

    function getRamp(indicator) {
      if (indicator === 'credit_deposit_ratio') return RAMP_GREEN;
      if (indicator === 'digital_transactions') return RAMP_BLUE;
      return RAMP_DEFAULT;
    }

    // ── State ──
    let distGeoJSON = null;
    let slbcData = {}; // { slug: [ { district, period, field1, field2, ... }, ... ] }
    let choroLayer = null;
    let distLabelsLayer = null;
    let distCentroids = [];
    let currentIndicator = 'credit_deposit_ratio';
    let currentMetricIdx = 0;
    let currentQuarter = '';
    let stateFilter = '';

    // ── Map init ──
    const NE_BOUNDS = L.latLngBounds(L.latLng(21.5, 88.0), L.latLng(29.5, 97.5));
    const map = L.map('map', {
      center: [25.5, 93.0],
      zoom: 7,
      minZoom: 5,
      maxZoom: 14,
      maxBounds: L.latLngBounds(L.latLng(15, 80), L.latLng(35, 100)),
      maxBoundsViscosity: 1.0,
      attributionControl: false,
      zoomControl: false,
    });
    L.control.zoom({ position: 'topright' }).addTo(map);

    // White canvas background
    (new (L.GridLayer.extend({
      createTile: function() {
        const t = document.createElement('canvas');
        t.width = t.height = 256;
        const c = t.getContext('2d');
        c.fillStyle = '#fff';
        c.fillRect(0, 0, 256, 256);
        return t;
      }
    }))).addTo(map);

    // India outline
    fetch('https://raw.githubusercontent.com/datameet/maps/master/Country/india-land-simplified.geojson')
      .then(r => r.json()).then(geo => {
        L.geoJSON(geo, {
          style: { fillColor: '#faf9f7', fillOpacity: 1, color: '#ccc8c0', weight: 1.2, opacity: 0.6 },
          interactive: false,
        }).addTo(map);
      }).catch(() => {});

    // ── Helpers ──
    function normalizePeriod(p) {
      if (/^\d{4}-\d{2}$/.test(p)) return p;
      const mm = { january:'01', february:'02', march:'03', april:'04', may:'05', june:'06',
        july:'07', august:'08', september:'09', october:'10', november:'11', december:'12',
        jan:'01', feb:'02', mar:'03', apr:'04', jun:'06', jul:'07', aug:'08', sep:'09', sept:'09',
        oct:'10', nov:'11', dec:'12' };
      const parts = p.trim().toLowerCase().split(/\s+/);
      if (parts.length === 2 && mm[parts[0]] && /^\d{4}$/.test(parts[1])) return parts[1] + '-' + mm[parts[0]];
      return p;
    }

    function fmtQuarter(q) {
      const parts = q.split('-');
      if (parts.length !== 2) return q;
      const m = { '01':'Jan','02':'Feb','03':'Mar','04':'Apr','05':'May','06':'Jun',
        '07':'Jul','08':'Aug','09':'Sep','10':'Oct','11':'Nov','12':'Dec' };
      return (m[parts[1]] || parts[1]) + ' ' + parts[0];
    }

    function fmtNum(n) {
      if (n === null || n === undefined || isNaN(n)) return '—';
      if (Math.abs(n) >= 1e7) return (n / 1e7).toFixed(1) + ' Cr';
      if (Math.abs(n) >= 1e5) return (n / 1e5).toFixed(1) + ' L';
      if (Math.abs(n) >= 1e3) return (n / 1e3).toFixed(1) + 'K';
      if (n % 1 !== 0) return n.toFixed(1);
      return n.toLocaleString('en-IN');
    }

    // Normalize district name for matching
    function normDist(d) {
      return (d || '').trim().replace(/\r?\n/g, '').toUpperCase()
        .replace(/[^A-Z\s]/g, '').replace(/\s+/g, ' ').trim();
    }

    // GeoJSON → SLBC district name aliases (GeoJSON normalized → SLBC normalized)
    const DISTRICT_ALIASES = {
      'PAPUMPARE': 'PAPUM PARE',
      'KEYI PANYOR': 'CAPITAL COMPLEX',
      'DARANG': 'DARRANG',
      'MARIGAON': 'MORIGAON',
      'SIBSAGAR': 'SIVASAGAR',
      'SRIBHUMI': 'KARIMGANJ',
      'WEST KARBI ANAGLONG': 'WEST KARBI ANGLONG',
      'KAMJANG': 'KAMJONG',
      'RIBHOI': 'RI BHOI',
      'GOMTI': 'GOMATI',
    };

    // Cross-category fallbacks: when a category lacks the field, try other categories
    // e.g., Assam's branch_network has no total_branch, but credit_deposit_ratio does
    const CROSS_CATEGORY_FALLBACKS = {
      'branch_network': ['credit_deposit_ratio', 'kcc', 'digital_transactions'],
    };

    // Get metric value from a district record, with cross-category fallback
    function getVal(record, cat, field, fallbacks) {
      // Try primary category
      var key = cat + '__' + field;
      var v = record[key];
      if (v != null && v !== '' && !isNaN(Number(v))) return Number(v);
      if (fallbacks) {
        for (var i = 0; i < fallbacks.length; i++) {
          v = record[cat + '__' + fallbacks[i]];
          if (v != null && v !== '' && !isNaN(Number(v))) return Number(v);
        }
      }
      // Try cross-category fallbacks
      var crossCats = CROSS_CATEGORY_FALLBACKS[cat];
      if (crossCats) {
        for (var c = 0; c < crossCats.length; c++) {
          v = record[crossCats[c] + '__' + field];
          if (v != null && v !== '' && !isNaN(Number(v))) return Number(v);
          if (fallbacks) {
            for (var j = 0; j < fallbacks.length; j++) {
              v = record[crossCats[c] + '__' + fallbacks[j]];
              if (v != null && v !== '' && !isNaN(Number(v))) return Number(v);
            }
          }
        }
      }
      return null;
    }

    // ── Build district → SLBC data lookup ──
    // Returns Map<normalizedDistrictName, { value, allMetrics }> for the current indicator/metric/quarter
    function buildDistrictLookup() {
      const ind = INDICATORS[currentIndicator];
      const metric = ind.metrics[currentMetricIdx];
      const lookup = new Map();

      for (const slug of Object.keys(slbcData)) {
        const records = slbcData[slug];
        if (!records || !records.length) continue;

        for (const rec of records) {
          if (rec.period !== currentQuarter) continue;
          const dn = normDist(rec.district);
          if (!dn) continue;

          const val = getVal(rec, currentIndicator, metric.field, metric.fallbacks);
          // Also get all metrics for tooltip
          const allVals = {};
          for (const m of ind.metrics) {
            allVals[m.label] = getVal(rec, currentIndicator, m.field, m.fallbacks);
          }
          lookup.set(dn, { value: val, metrics: allVals, district: rec.district });
        }
      }
      return lookup;
    }

    // ── Choropleth ──
    function getColor(value, breaks, ramp) {
      if (value === null || value === undefined) return '#e8e4dc';
      for (let i = breaks.length - 1; i >= 0; i--) {
        if (value >= breaks[i]) return ramp[i + 1] || ramp[ramp.length - 1];
      }
      return ramp[0];
    }

    function computeBreaks(values) {
      const sorted = values.filter(v => v !== null && !isNaN(v)).sort((a, b) => a - b);
      if (sorted.length < 5) return [0, 10, 50, 100, 500];
      const pcts = [0.2, 0.4, 0.6, 0.8, 0.95];
      return pcts.map(p => {
        const idx = Math.floor(p * sorted.length);
        return sorted[Math.min(idx, sorted.length - 1)];
      });
    }

    function buildChoropleth() {
      if (choroLayer) { map.removeLayer(choroLayer); choroLayer = null; }
      if (!distGeoJSON || !currentQuarter) return;

      const lookup = buildDistrictLookup();
      const ramp = getRamp(currentIndicator);
      const ind = INDICATORS[currentIndicator];
      const metric = ind.metrics[currentMetricIdx];

      // Collect all values for auto-breaks
      const allVals = [];
      lookup.forEach(v => { if (v.value !== null) allVals.push(v.value); });
      const breaks = computeBreaks(allVals);

      // Update legend
      updateLegend(metric.label, breaks, ramp);

      // Filter to NE states + optional state filter
      const filtered = {
        ...distGeoJSON,
        features: distGeoJSON.features.filter(f => {
          const st = f.properties.STATE_UT?.toUpperCase()?.trim();
          if (!NE_STATES.includes(st)) return false;
          if (stateFilter && st !== stateFilter) return false;
          return true;
        }),
      };

      choroLayer = L.geoJSON(filtered, {
        style: function(feature) {
          const dn = normDist(feature.properties.DISTRICT);
          const data = lookup.get(dn) || lookup.get(DISTRICT_ALIASES[dn]);
          const val = data ? data.value : null;
          return {
            fillColor: getColor(val, breaks, ramp),
            fillOpacity: val === null ? 0.5 : 0.78,
            color: '#c8bfb0',
            weight: 0.8,
            opacity: 0.7,
          };
        },
        onEachFeature: function(feature, layer) {
          const p = feature.properties;
          const dn = normDist(p.DISTRICT);
          const data = lookup.get(dn) || lookup.get(DISTRICT_ALIASES[dn]);

          layer.on({
            mouseover: function(e) {
              e.target.setStyle({ weight: 2.5, color: '#6b4c2a', fillOpacity: 0.92 });
              let tip = '<div class="dist-tooltip"><strong>' + p.DISTRICT + '</strong> '
                + '<span style="font-size:10px;color:#888078">' + p.STATE_UT + '</span>';
              if (data) {
                for (const [label, val] of Object.entries(data.metrics)) {
                  const formatted = val !== null ? fmtNum(val) : '—';
                  const isCurrent = label === metric.label;
                  tip += '<br><span style="' + (isCurrent ? 'font-weight:600;color:#1a1410' : 'color:#888078') + '">'
                    + label + ': <strong>' + formatted + '</strong></span>';
                }
              } else {
                tip += '<br><span style="color:#aaa09a">No data available</span>';
              }
              tip += '</div>';
              e.target.bindTooltip(tip, { sticky: true, className: '', offset: [10, 0] }).openTooltip();
            },
            mouseout: function(e) {
              choroLayer.resetStyle(e.target);
              e.target.closeTooltip();
            },
          });
        },
      }).addTo(map);

      updateStats(lookup, allVals);
    }

    function updateLegend(metricLabel, breaks, ramp) {
      document.getElementById('legend-title').textContent = metricLabel;
      const scale = document.getElementById('legend-scale');
      const labels = document.getElementById('legend-labels');
      scale.innerHTML = ramp.map(c => '<div class="choro-swatch" style="background:' + c + '"></div>').join('');
      const lbls = ['0'];
      breaks.forEach(b => lbls.push(fmtNum(b)));
      labels.innerHTML = lbls.map(l => '<span>' + l + '</span>').join('');
    }

    function updateStats(lookup, allVals) {
      const total = lookup.size;
      const withData = allVals.length;
      const avg = withData ? (allVals.reduce((a, b) => a + b, 0) / withData) : 0;
      const max = withData ? Math.max(...allVals) : 0;
      const min = withData ? Math.min(...allVals) : 0;
      const ind = INDICATORS[currentIndicator];
      const metric = ind.metrics[currentMetricIdx];

      document.getElementById('stats').innerHTML =
        '<strong>' + ind.title + '</strong><br>'
        + '<span style="font-size:9px;color:#888078">' + fmtQuarter(currentQuarter) + '</span><br>'
        + '<span style="color:#b8603e">' + withData + '</span> districts with data<br>'
        + 'Avg: <strong>' + fmtNum(avg) + '</strong><br>'
        + 'Min: ' + fmtNum(min) + ' · Max: ' + fmtNum(max);

      document.getElementById('btn-reset').style.display = stateFilter ? 'block' : 'none';
    }

    // ── District labels ──
    function buildDistrictLabels() {
      if (!distGeoJSON) return;
      distCentroids = [];
      distGeoJSON.features.forEach(function(f) {
        const st = f.properties.STATE_UT?.toUpperCase()?.trim();
        if (!NE_STATES.includes(st)) return;
        try {
          const tmp = L.geoJSON(f);
          const b = tmp.getBounds();
          distCentroids.push({ center: b.getCenter(), name: f.properties.DISTRICT, bounds: b, state: st });
        } catch(e) {}
      });
    }

    function updateLabelVisibility() {
      if (distLabelsLayer) { map.removeLayer(distLabelsLayer); distLabelsLayer = null; }
      const z = map.getZoom();
      if (z < 8) return;
      const viewBounds = map.getBounds();
      distLabelsLayer = L.layerGroup();
      const placed = [];
      distCentroids.forEach(function(d) {
        if (stateFilter && d.state !== stateFilter) return;
        if (!viewBounds.intersects(d.bounds)) return;
        const px = map.latLngToContainerPoint(d.center);
        const tooClose = placed.some(function(p) { return Math.abs(px.x - p.x) < 120 && Math.abs(px.y - p.y) < 30; });
        if (tooClose) return;
        placed.push(px);
        distLabelsLayer.addLayer(L.marker(d.center, {
          icon: L.divIcon({
            className: 'dist-label',
            html: d.name,
            iconSize: [0, 0],
            iconAnchor: [0, 0],
          }),
          interactive: false,
        }));
      });
      distLabelsLayer.addTo(map);
    }
    map.on('zoomend', updateLabelVisibility);
    map.on('moveend', updateLabelVisibility);

    // ── Populate dropdowns ──
    function populateMetrics() {
      const sel = document.getElementById('sel-metric');
      const ind = INDICATORS[currentIndicator];
      sel.innerHTML = '';
      ind.metrics.forEach(function(m, i) {
        const o = document.createElement('option');
        o.value = i;
        o.textContent = m.label;
        sel.appendChild(o);
      });
      sel.value = currentMetricIdx < ind.metrics.length ? currentMetricIdx : 0;
      currentMetricIdx = parseInt(sel.value);
    }

    function populateQuarters() {
      const qSet = new Set();
      for (const slug of Object.keys(slbcData)) {
        for (const rec of slbcData[slug]) {
          if (rec.period) qSet.add(rec.period);
        }
      }
      const quarters = [...qSet].sort();
      const sel = document.getElementById('sel-quarter');
      sel.innerHTML = '';
      quarters.reverse().forEach(function(q) {
        const o = document.createElement('option');
        o.value = q;
        o.textContent = fmtQuarter(q);
        sel.appendChild(o);
      });
      if (!currentQuarter && quarters.length) currentQuarter = quarters[0]; // latest
      if (currentQuarter) sel.value = currentQuarter;
    }

    // ── Event listeners ──
    document.getElementById('sel-indicator').addEventListener('change', function(e) {
      currentIndicator = e.target.value;
      currentMetricIdx = 0;
      populateMetrics();
      buildChoropleth();
    });

    document.getElementById('sel-metric').addEventListener('change', function(e) {
      currentMetricIdx = parseInt(e.target.value);
      buildChoropleth();
    });

    document.getElementById('sel-quarter').addEventListener('change', function(e) {
      currentQuarter = e.target.value;
      buildChoropleth();
    });

    document.getElementById('sel-state').addEventListener('change', function(e) {
      stateFilter = e.target.value;
      buildChoropleth();
      updateLabelVisibility();
      if (stateFilter) {
        // Fly to state
        const stateFts = distGeoJSON.features.filter(function(f) {
          return f.properties.STATE_UT?.toUpperCase()?.trim() === stateFilter;
        });
        if (stateFts.length) {
          const group = L.geoJSON({ type: 'FeatureCollection', features: stateFts });
          map.flyToBounds(group.getBounds(), { padding: [40, 40], maxZoom: 9, duration: 1.0 });
        }
      } else {
        map.flyToBounds(NE_BOUNDS, { padding: [20, 20], duration: 1.0 });
      }
    });

    document.getElementById('btn-reset').addEventListener('click', function() {
      stateFilter = '';
      document.getElementById('sel-state').value = '';
      map.flyToBounds(NE_BOUNDS, { padding: [20, 20], duration: 1.0 });
      buildChoropleth();
      updateLabelVisibility();
    });

    // ── Load data ──
    setStatus('Fetching data…');

    function flattenTimeseries(json) {
      if (Array.isArray(json)) return json;
      if (!json || !json.periods) return [];
      const records = [];
      for (const p of json.periods) {
        if (!p.districts) continue;
        for (const d of p.districts) {
          records.push(d);
        }
      }
      return records;
    }

    // Load GeoJSON + all 8 state timeseries
    const slugs = Object.values(STATE_SLUGS);
    Promise.all([
      fetch(DIST_URL).then(function(r) { return r.json(); }),
      ...slugs.map(function(slug) {
        return fetch(_B + 'slbc-data/' + slug + '/' + slug + '_fi_timeseries.json')
          .then(function(r) { return r.ok ? r.json() : null; })
          .then(function(json) { return { slug: slug, data: json }; })
          .catch(function() { return { slug: slug, data: null }; });
      }),
    ]).then(function(results) {
      distGeoJSON = results[0];

      for (let i = 1; i < results.length; i++) {
        const r = results[i];
        if (!r.data) { slbcData[r.slug] = []; continue; }
        const flat = flattenTimeseries(r.data);
        for (const rec of flat) {
          if (rec.period) rec.period = normalizePeriod(rec.period);
        }
        slbcData[r.slug] = flat;
      }

      setStatus('Building map…');
      populateMetrics();
      populateQuarters();
      buildDistrictLabels();
      buildChoropleth();
      updateLabelVisibility();
    }).catch(function(err) {
      setStatus('Error: ' + err.message);
    });

    function setStatus(msg) {
      document.getElementById('stats').textContent = msg;
    }
  </script>
</BaseLayout>

