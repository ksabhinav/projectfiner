---
import PageLayout from '../../../layouts/PageLayout.astro';
import StateDownload from '../../../components/StateDownload.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Arunachal Pradesh SLBC Data Download | Project FINER"
  pageTitle="Arunachal Pradesh — SLBC Financial Inclusion Data"
  subtitle={`District-level indicators from SLBC quarterly booklets. All amounts in Rs. Lakhs.<br><a href="${base}slbc-data">&larr; All states</a>`}
>
  <div class="stat-bar">
    <div class="stat-row">
      <div class="stat-item"><div class="stat-num">18</div><div class="stat-lbl">Quarters</div></div>
      <div class="stat-item"><div class="stat-num">25</div><div class="stat-lbl">Districts</div></div>
      <div class="stat-item"><div class="stat-num">520</div><div class="stat-lbl">CSV Files</div></div>
      <div class="stat-item"><div class="stat-num">Mar 2018</div><div class="stat-lbl">From</div></div>
      <div class="stat-item"><div class="stat-num">Mar 2025</div><div class="stat-lbl">To</div></div>
    </div>
  </div>

  <div class="container">
    <StateDownload client:load stateName="Arunachal Pradesh" stateSlug="arunachal-pradesh" />
  </div>
</PageLayout>

<style>
  .container { max-width: 960px; margin: 0 auto; padding: 32px 40px 60px; }
</style>
