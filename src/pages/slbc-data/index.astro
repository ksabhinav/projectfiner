---
import PageLayout from '../../layouts/PageLayout.astro';

const base = import.meta.env.BASE_URL;

const states = [
  { name: 'Assam', meta: '29 quarters · 35 districts · 44+ indicators · 947 CSVs', href: `${base}slbc-data/assam/download`, active: true },
  { name: 'Meghalaya', meta: '18 quarters · 12 districts · 44 indicators · 606 CSVs', href: `${base}slbc-data/meghalaya/download`, active: true },
  { name: 'Manipur', meta: '39 quarters · 16 districts · 642 CSVs', href: `${base}slbc-data/manipur/download`, active: true },
  { name: 'Arunachal Pradesh', meta: '18 quarters · 25 districts · 520 CSVs', href: `${base}slbc-data/arunachal-pradesh/download`, active: true },
  { name: 'Mizoram', meta: '22 quarters · 11 districts · 248 CSVs', href: `${base}slbc-data/mizoram/download`, active: true },
  { name: 'Tripura', meta: '28 quarters · 8 districts · 144 CSVs', href: `${base}slbc-data/tripura/download`, active: true },
  { name: 'Nagaland', meta: '7 quarters · 11 districts · 58 CSVs', href: `${base}slbc-data/nagaland/download`, active: true },
  { name: 'Sikkim', meta: '4 quarters · 6 districts · 39 CSVs', href: `${base}slbc-data/sikkim/download`, active: true },
];
---

<PageLayout
  title="SLBC Data — Financial Inclusion | Project FINER"
  pageTitle="SLBC Data — District-Level Financial Inclusion"
  subtitle="Machine-readable datasets extracted from State Level Bankers' Committee (SLBC) quarterly booklets. District-level indicators covering banking infrastructure, credit, government schemes, and more."
>
  <div class="container">
    <div class="section-label">North East Region</div>

    {states.map(state => (
      <a class:list={['state-card', { coming: !state.active }]} href={state.href}>
        <div class="state-inner">
          <div>
            <div class="state-name">{state.name}</div>
            <div class="state-meta">{state.meta}</div>
          </div>
          <div class="state-arrow">&rarr;</div>
        </div>
      </a>
    ))}
  </div>
</PageLayout>

<style>
  .container { max-width: 900px; margin: 0 auto; padding: 32px 40px 60px; }
  .state-card {
    display: block;
    background: #fff;
    border: 1px solid var(--border);
    padding: 0;
    margin-bottom: 12px;
    border-radius: 8px;
    box-shadow: var(--card-shadow);
    overflow: hidden;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .state-card:hover { box-shadow: var(--card-shadow-hover); transform: translateY(-1px); }
  .state-inner {
    padding: 24px 28px;
    border-left: 3px solid var(--accent);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .state-name { font-size: 16px; font-weight: 700; color: var(--text); }
  .state-meta { font-family: var(--font-sans); font-size: 11px; color: var(--muted); margin-top: 4px; }
  .state-arrow { font-family: var(--font-sans); font-size: 18px; color: #ccc; transition: color 0.2s; }
  .state-card:hover .state-arrow { color: var(--accent); }
  .coming { opacity: 0.4; pointer-events: none; }
  .coming .state-inner { border-left-color: #ccc; }
</style>
