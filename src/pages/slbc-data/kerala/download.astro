---
import PageLayout from '../../../layouts/PageLayout.astro';
import StateDownload from '../../../components/StateDownload.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Kerala SLBC Data Download | Project FINER"
  pageTitle="Kerala — SLBC Financial Inclusion Data"
  subtitle={`District-level indicators from SLBC Kerala quarterly agenda papers. All amounts in Rs. Lakhs.<br><a href="${base}slbc-data">&larr; All states</a>`}
>
  <div class="stat-bar">
    <div class="stat-row">
      <div class="stat-item"><div class="stat-num">23</div><div class="stat-lbl">Quarters</div></div>
      <div class="stat-item"><div class="stat-num">14</div><div class="stat-lbl">Districts</div></div>
      <div class="stat-item"><div class="stat-num">7</div><div class="stat-lbl">Indicators</div></div>
      <div class="stat-item"><div class="stat-num">Mar 2019</div><div class="stat-lbl">From</div></div>
      <div class="stat-item"><div class="stat-num">Sep 2025</div><div class="stat-lbl">To</div></div>
    </div>
  </div>

  <div class="container">
    <StateDownload client:load stateName="Kerala" stateSlug="kerala" />
  </div>
</PageLayout>

<style>
  .container { max-width: 960px; margin: 0 auto; padding: 32px 40px 60px; }
</style>
