---
import PageLayout from '../../../layouts/PageLayout.astro';
import StateDownload from '../../../components/StateDownload.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="West Bengal SLBC Data Download | Project FINER"
  pageTitle="West Bengal — SLBC Financial Inclusion Data"
  subtitle={`District-level indicators from SLBC West Bengal quarterly agenda papers. All amounts in Rs. Crore.<br><a href="${base}slbc-data">&larr; All states</a> &nbsp;&middot;&nbsp; Source: <a href="https://slbcbengal.pnb.bank.in/Background_Paper_Quarterly.asp" target="_blank">slbcbengal.pnb.bank.in</a>`}
>
  <div class="stat-bar">
    <div class="stat-row">
      <div class="stat-item"><div class="stat-num">38</div><div class="stat-lbl">Quarters</div></div>
      <div class="stat-item"><div class="stat-num">23</div><div class="stat-lbl">Districts</div></div>
      <div class="stat-item"><div class="stat-num">22+</div><div class="stat-lbl">Indicators</div></div>
      <div class="stat-item"><div class="stat-num">331</div><div class="stat-lbl">CSV Files</div></div>
      <div class="stat-item"><div class="stat-num">Dec 2015</div><div class="stat-lbl">From</div></div>
      <div class="stat-item"><div class="stat-num">Sep 2025</div><div class="stat-lbl">To</div></div>
    </div>
  </div>

  <div class="container">
    <StateDownload client:load stateName="West Bengal" stateSlug="west-bengal" />
  </div>
</PageLayout>

<style>
  .container { max-width: 960px; margin: 0 auto; padding: 32px 40px 60px; }
</style>
