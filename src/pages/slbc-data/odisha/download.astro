---
import PageLayout from '../../../layouts/PageLayout.astro';
import StateDownload from '../../../components/StateDownload.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Odisha SLBC Data Download | Project FINER"
  pageTitle="Odisha — SLBC Financial Inclusion Data"
  subtitle={`District-level indicators from SLBC Odisha quarterly booklets. All amounts in Rs. Lakhs.<br><a href="${base}slbc-data">&larr; All states</a> &nbsp;&middot;&nbsp; Source: <a href="https://slbcorissa.com/" target="_blank">slbcorissa.com</a>`}
>
  <div class="stat-bar">
    <div class="stat-row">
      <div class="stat-item"><div class="stat-num">8</div><div class="stat-lbl">Quarters</div></div>
      <div class="stat-item"><div class="stat-num">30</div><div class="stat-lbl">Districts</div></div>
      <div class="stat-item"><div class="stat-num">50</div><div class="stat-lbl">Indicators</div></div>
      <div class="stat-item"><div class="stat-num">175</div><div class="stat-lbl">CSV Files</div></div>
      <div class="stat-item"><div class="stat-num">Dec 2023</div><div class="stat-lbl">From</div></div>
      <div class="stat-item"><div class="stat-num">Dec 2025</div><div class="stat-lbl">To</div></div>
    </div>
  </div>

  <div class="container">
    <StateDownload client:load stateName="Odisha" stateSlug="odisha" />
  </div>
</PageLayout>

<style>
  .container { max-width: 960px; margin: 0 auto; padding: 32px 40px 60px; }
</style>
