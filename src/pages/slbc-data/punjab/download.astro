---
import PageLayout from '../../../layouts/PageLayout.astro';
import StateDownload from '../../../components/StateDownload.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Punjab SLBC Data Download | Project FINER"
  description="Download district-level Priority Sector Lending data for Punjab — quarterly ACP target / achievement tables across Agri, MSME, Other PS and Total PS for 23 districts. CSV, XLSX. Free and open data."
  pageTitle="Punjab — SLBC Financial Inclusion Data"
  subtitle={`District-level indicators extracted from Punjab SLBC quarterly meetings. All amounts in Rs. Lakhs.<br><a href="${base}downloads">&larr; All states</a> &nbsp;&middot;&nbsp; Source: <a href="https://slbcpunjab.pnb.bank.in" target="_blank" rel="noopener">slbcpunjab.pnb.bank.in</a> (Convenor: Punjab National Bank)`}
>
  <div class="stat-bar">
    <div class="stat-row">
      <div class="stat-item"><div class="stat-num">19</div><div class="stat-lbl">Quarters</div></div>
      <div class="stat-item"><div class="stat-num">23</div><div class="stat-lbl">Districts</div></div>
      <div class="stat-item"><div class="stat-num">1</div><div class="stat-lbl">Category</div></div>
      <div class="stat-item"><div class="stat-num">Sep 2020</div><div class="stat-lbl">From</div></div>
      <div class="stat-item"><div class="stat-num">Dec 2025</div><div class="stat-lbl">To</div></div>
    </div>
  </div>

  <div class="caveat">
    <strong>Source coverage caveat:</strong> Punjab SLBC publishes only
    <em>Priority Sector Lending</em> data at the district level (ACP
    target / achievement / % across Agri, MSME, Other PS, Total PS).
    CD ratio, branch network, KCC, PMJDY, SHG and digital coverage are
    reported only at state level (bank-wise). For Punjab branch counts
    use the homepage's <em>Banking Infrastructure (RBI · snapshot)</em>
    indicator which covers all 23 Punjab districts via the RBI DBIE
    locator.
  </div>

  <div class="container">
    <StateDownload client:load stateName="Punjab" stateSlug="punjab" />
  </div>
</PageLayout>

<style>
  .stat-bar {
    background: var(--paper-deep, #ECE5D6);
    border: 1px solid var(--rule, #D9D2C5);
    border-radius: 6px;
    padding: 18px 24px;
    margin: 0 0 18px;
  }
  .stat-row { display: flex; gap: 32px; flex-wrap: wrap; }
  .stat-item { display: flex; flex-direction: column; gap: 2px; }
  .stat-num {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 22px; font-weight: 400; color: var(--ink, #1B140E);
    line-height: 1;
  }
  .stat-lbl {
    font-family: var(--font-mono, 'IBM Plex Mono', monospace);
    font-size: 9.5px; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--mist, #6E665E);
  }
  .caveat {
    background: rgba(184, 74, 46, 0.06);
    border-left: 3px solid var(--vermillion, #B84A2E);
    padding: 12px 18px;
    margin: 0 0 24px;
    font-family: var(--font-body, 'Source Serif 4', Georgia, serif);
    font-size: 14px;
    color: var(--ink-soft, #3D332A);
    line-height: 1.5;
    border-radius: 4px;
  }
  .container { margin-top: 8px; }
</style>
