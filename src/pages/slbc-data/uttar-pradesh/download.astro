---
import PageLayout from '../../../layouts/PageLayout.astro';
import StateDownload from '../../../components/StateDownload.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Uttar Pradesh SLBC Data Download | Project FINER"
  description="Download district-level financial inclusion data for Uttar Pradesh — quarterly SLBC tables covering CD ratio, deposits, advances, branch network and other indicators where reported. CSV, XLSX. Free and open data."
  pageTitle="Uttar Pradesh — SLBC Financial Inclusion Data"
  subtitle={`District-level indicators extracted from Uttar Pradesh SLBC quarterly meetings. All amounts in Rs. Lakhs.<br><a href="${base}downloads">&larr; All states</a> &nbsp;&middot;&nbsp; Source: <a href="https://slbcup.com" target="_blank" rel="noopener">slbcup.com</a>`}
>
  <div class="stat-bar">
    <div class="stat-row">
      <div class="stat-item"><div class="stat-num">25</div><div class="stat-lbl">Quarters</div></div>
      <div class="stat-item"><div class="stat-num">75</div><div class="stat-lbl">Districts</div></div>
      <div class="stat-item"><div class="stat-num">16</div><div class="stat-lbl">Categories</div></div>
      <div class="stat-item"><div class="stat-num">Mar 2019</div><div class="stat-lbl">From</div></div>
      <div class="stat-item"><div class="stat-num">Dec 2025</div><div class="stat-lbl">To</div></div>
    </div>
  </div>

  <div class="container">
    <StateDownload client:load stateName="Uttar Pradesh" stateSlug="uttar-pradesh" />
  </div>
</PageLayout>

<style>
  .stat-bar {
    background: var(--paper-deep, #ECE5D6);
    border: 1px solid var(--rule, #D9D2C5);
    border-radius: 6px;
    padding: 18px 24px;
    margin: 0 0 28px;
  }
  .stat-row { display: flex; gap: 32px; flex-wrap: wrap; }
  .stat-item { display: flex; flex-direction: column; gap: 2px; }
  .stat-num {
    font-family: var(--font-display, 'Fraunces', Georgia, serif);
    font-size: 22px; font-weight: 400; color: var(--ink, #1B140E);
    line-height: 1;
  }
  .stat-lbl {
    font-family: var(--font-mono, 'IBM Plex Mono', monospace);
    font-size: 9.5px; font-weight: 500; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--mist, #6E665E);
  }
  .container { margin-top: 8px; }
</style>
