---
import PageLayout from '../../../layouts/PageLayout.astro';
import StateDownload from '../../../components/StateDownload.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Bihar SLBC Data Download | Project FINER"
  pageTitle="Bihar — SLBC Financial Inclusion Data"
  subtitle={`District-level indicators from SLBC Bihar quarterly agenda papers. All amounts in Rs. Lakhs.<br><a href="${base}slbc-data">&larr; All states</a> &nbsp;&middot;&nbsp; Source: <a href="https://www.slbcbihar.com/SlBCHeldMeeting.aspx" target="_blank">slbcbihar.com</a>`}
>
  <div class="stat-bar">
    <div class="stat-row">
      <div class="stat-item"><div class="stat-num">25</div><div class="stat-lbl">Quarters</div></div>
      <div class="stat-item"><div class="stat-num">38</div><div class="stat-lbl">Districts</div></div>
      <div class="stat-item"><div class="stat-num">60+</div><div class="stat-lbl">Indicators</div></div>
      <div class="stat-item"><div class="stat-num">334</div><div class="stat-lbl">CSV Files</div></div>
      <div class="stat-item"><div class="stat-num">Mar 2019</div><div class="stat-lbl">From</div></div>
      <div class="stat-item"><div class="stat-num">Sep 2025</div><div class="stat-lbl">To</div></div>
    </div>
  </div>

  <div class="container">
    <StateDownload client:load stateName="Bihar" stateSlug="bihar" />
  </div>
</PageLayout>

<style>
  .container { max-width: 960px; margin: 0 auto; padding: 32px 40px 60px; }
</style>
