---
import PageLayout from '../../../layouts/PageLayout.astro';
import StateDownload from '../../../components/StateDownload.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Manipur SLBC Data Download | Project FINER"
  pageTitle="Manipur — SLBC Financial Inclusion Data"
  subtitle={`District-level indicators from SLBC NE quarterly booklets. All amounts in Rs. Lakhs.<br><a href="${base}slbc-data">&larr; All states</a> &nbsp;&middot;&nbsp; Source: <a href="https://slbcne.nic.in/manipur/booklet.php" target="_blank">slbcne.nic.in</a>`}
>
  <div class="container">
    <StateDownload client:load stateName="Manipur" stateSlug="manipur" />
  </div>
</PageLayout>

<style>
  .container { max-width: 960px; margin: 0 auto; padding: 32px 40px 60px; }
</style>
