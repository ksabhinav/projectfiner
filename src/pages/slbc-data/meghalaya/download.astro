---
import PageLayout from '../../../layouts/PageLayout.astro';
import MeghalayaDownload from '../../../components/MeghalayaDownload.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Meghalaya SLBC Data Download | Project FINER"
  pageTitle="Meghalaya — SLBC Financial Inclusion Data"
  subtitle={`District-level indicators from SLBC NE quarterly booklets. All amounts in Rs. Lakhs.<br><a href="${base}slbc-data">&larr; All states</a> &nbsp;&middot;&nbsp; Source: <a href="https://slbcne.nic.in/meghalaya/booklet.php" target="_blank">slbcne.nic.in</a>`}
>
  <div class="stat-bar">
    <div class="stat-row">
      <div class="stat-item"><div class="stat-num">18</div><div class="stat-lbl">Quarters</div></div>
      <div class="stat-item"><div class="stat-num">12</div><div class="stat-lbl">Districts</div></div>
      <div class="stat-item"><div class="stat-num">44</div><div class="stat-lbl">Indicators</div></div>
      <div class="stat-item"><div class="stat-num">606</div><div class="stat-lbl">CSV Files</div></div>
      <div class="stat-item"><div class="stat-num">Jun 2020</div><div class="stat-lbl">From</div></div>
      <div class="stat-item"><div class="stat-num">Sep 2025</div><div class="stat-lbl">To</div></div>
    </div>
  </div>

  <div class="container">
    <MeghalayaDownload client:load />
  </div>
</PageLayout>

<style>
  .container { max-width: 960px; margin: 0 auto; padding: 32px 40px 60px; }
</style>
