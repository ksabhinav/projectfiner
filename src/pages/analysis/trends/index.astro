---
import PageLayout from '../../../layouts/PageLayout.astro';
import TrendTracker from '../../../components/analysis/TrendTracker.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Trend Tracker | Project FINER"
  pageTitle="Trend Tracker"
  subtitle="District profile view — track every financial inclusion indicator over time with sparklines and quarter-over-quarter change arrows."
  activeSubNav="trends"
>
  <div class="container">
    <TrendTracker client:load baseUrl={base} />
  </div>
</PageLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 32px 40px 60px; }
</style>
