---
import PageLayout from '../../layouts/PageLayout.astro';
import DistrictRankings from '../../components/analysis/DistrictRankings.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="District Rankings | Project FINER"
  pageTitle="Data Analysis"
  subtitle="Sortable leaderboard of districts ranked by any financial inclusion indicator, with traffic-light status badges."
  description="Sortable leaderboard of 800+ Indian districts ranked by 20+ financial inclusion indicators: CD ratio, PMJDY accounts, KCC issuance, SHG coverage, MUDRA, digital adoption, Aadhaar seeding. Traffic-light badges flag districts above and below RBI norms."
  activeSubNav="rankings"
>
  <div class="container">
    <DistrictRankings client:load baseUrl={base} />
  </div>
</PageLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 32px 40px 60px; }
</style>
