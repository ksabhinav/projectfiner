---
import PageLayout from '../../../layouts/PageLayout.astro';
import Insights from '../../../components/analysis/Insights.svelte';

const base = import.meta.env.BASE_URL;
---

<PageLayout
  title="Key Findings | Project FINER"
  pageTitle="Pre-built Insights"
  subtitle="Curated data stories highlighting key patterns, disparities, and trends from SLBC financial inclusion data across North Eastern states and Bihar."
  description="Curated district-level findings from Project FINER — concentration patterns, access gaps, regional disparities, and growth signals across India's financial inclusion data. Each story is backed by verifiable numbers from SLBC, RBI, NRLM, SHRUG and PhonePe Pulse."
  activeSubNav="insights"
>
  <Insights client:load baseUrl={base} />
</PageLayout>
