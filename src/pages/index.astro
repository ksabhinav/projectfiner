      'digital_transactions': ['digital_payments', 'digital_coverage_savings', 'digital_coverage_savings_p2', 'digital_coverage_business', 'women_finance'],
      'social_security': ['social_security_schemes', 'social_security_claims', 'social_security_2'],
      'pmjdy': ['pmjdy_p2', 'pmjdy_p3', 'pmjdy_p4', 'social_security_schemes', 'pmjdy_2', 'pmjdy_3'],
      'aadhaar_authentication': ['pmjdy'],
    };

    function normalizePeriod(p) {
      if (/^\d{4}-\d{2}$/.test(p)) return p;
      var mm = { january:'01', february:'02', march:'03', april:'04', may:'05', june:'06',
        july:'07', august:'08', september:'09', october:'10', november:'11', december:'12',
        jan:'01', feb:'02', mar:'03', apr:'04', jun:'06', jul:'07', aug:'08', sep:'09', sept:'09',
        oct:'10', nov:'11', dec:'12' };
      var parts = p.trim().toLowerCase().split(/\s+/);
      if (parts.length === 2 && mm[parts[0]] && /^\d{4}$/.test(parts[1])) return parts[1] + '-' + mm[parts[0]];
      return p;
    }

    function fmtQuarter(q) {
      var parts = q.split('-');
      if (parts.length !== 2) return q;
      var m = { '01':'Jan','02':'Feb','03':'Mar','04':'Apr','05':'May','06':'Jun',
        '07':'Jul','08':'Aug','09':'Sep','10':'Oct','11':'Nov','12':'Dec' };
      return (m[parts[1]] || parts[1]) + ' ' + parts[0];
    }

    function fmtNum(n) {
      if (n === null || n === undefined || isNaN(n)) return '—';
      if (Math.abs(n) >= 1e7) return (n / 1e7).toFixed(1) + ' Cr';
      if (Math.abs(n) >= 1e5) return (n / 1e5).toFixed(1) + ' L';
      if (Math.abs(n) >= 1e3) return (n / 1e3).toFixed(1) + 'K';
      if (n % 1 !== 0) return n.toFixed(1);
      return n.toLocaleString('en-IN');
    }

    function normDist(d) {
      return (d || '').trim().replace(/\r?\n/g, '').toUpperCase()
        .replace(/[^A-Z\s]/g, '').replace(/\s+/g, ' ').trim();
    }

    // Date suffix pattern for prefix matching — only match date-like suffixes
    // e.g. 'pct_coverage' matches 'pct_coverage_mar_24', 'pct_coverage_9688', etc.
    var DATE_SUFFIX_RE = /_(jan|feb|mar|apr|may|jun|jul|aug|sep|sept|oct|nov|dec|fy|2\d{3}|\d{2,4})$/i;

    function tryFieldWithPrefix(record, catField) {
      // First try exact match
      var v = record[catField];
      if (v != null && v !== '' && !isNaN(Number(v))) return Number(v);
      // Then try prefix match — but only if the suffix looks like a date/number
      // This prevents 'total' from matching 'total_advance' while allowing
      // 'pct_coverage' to match 'pct_coverage_mar_24'
      var keys = Object.keys(record);
      for (var k = 0; k < keys.length; k++) {
        var key = keys[k];
        if (key.length > catField.length + 1 && key.indexOf(catField + '_') === 0) {
          var suffix = key.substring(catField.length);
          if (DATE_SUFFIX_RE.test(suffix)) {
            v = record[key];
            if (v != null && v !== '' && !isNaN(Number(v))) return Number(v);
          }
        }
      }
      return null;
    }

    function getVal(record, cat, field, fallbacks) {
      // 1. Try primary category + field (exact then prefix)
      var v = tryFieldWithPrefix(record, cat + '__' + field);
      if (v !== null) return v;

      // 2. Try primary category + fallback fields
      if (fallbacks) {
        for (var i = 0; i < fallbacks.length; i++) {
          v = tryFieldWithPrefix(record, cat + '__' + fallbacks[i]);
          if (v !== null) return v;
        }
      }

      // 3. Try cross-category fallbacks
      var crossCats = CROSS_CATEGORY_FALLBACKS[cat];
      if (crossCats) {
        for (var c = 0; c < crossCats.length; c++) {
          v = tryFieldWithPrefix(record, crossCats[c] + '__' + field);
          if (v !== null) return v;
          if (fallbacks) {
            for (var j = 0; j < fallbacks.length; j++) {
              v = tryFieldWithPrefix(record, crossCats[c] + '__' + fallbacks[j]);
              if (v !== null) return v;
            }
          }
        }
      }
      return null;
    }

    function buildDistrictLookup() {
      var ind = INDICATORS[currentIndicator];
      var metric = ind.metrics[currentMetricIdx];
      var lookup = new Map();

      for (var slug of Object.keys(slbcData)) {
        var records = slbcData[slug];
        if (!records || !records.length) continue;

        var stateQuarters = [];
        var seen = {};
        records.forEach(function(r) {
          if (r.period && r.period <= currentQuarter && !seen[r.period]) {
            seen[r.period] = true;
            stateQuarters.push(r.period);
          }
        });
        stateQuarters.sort();
        if (!stateQuarters.length) continue;

        var useQuarter = null;
        for (var qi = stateQuarters.length - 1; qi >= 0; qi--) {
          var q = stateQuarters[qi];
          var qRecords = records.filter(function(r) { return r.period === q; });
          var hasIndicatorData = qRecords.some(function(r) {
            return getVal(r, currentIndicator, metric.field, metric.fallbacks) !== null;
          });
          if (hasIndicatorData) {
            useQuarter = q;
            break;
          }
        }
        if (!useQuarter) continue;

        for (var ri = 0; ri < records.length; ri++) {
          var rec = records[ri];
          if (rec.period !== useQuarter) continue;
          var dn = normDist(rec.district);
          if (!dn) continue;

          var val = getVal(rec, currentIndicator, metric.field, metric.fallbacks);
          var allVals = {};
          for (var mi = 0; mi < ind.metrics.length; mi++) {
            var m = ind.metrics[mi];
            allVals[m.label] = getVal(rec, currentIndicator, m.field, m.fallbacks);
          }
          var entry = { value: val, metrics: allVals, district: rec.district };
          if (useQuarter !== currentQuarter) {
            entry.fallbackQuarter = useQuarter;
          }
          lookup.set(dn, entry);
        }
      }
      return lookup;
    }

    function getColor(value, breaks, ramp) {
      if (value === null || value === undefined) return '#e8e4dc';
      for (var i = breaks.length - 1; i >= 0; i--) {
        if (value >= breaks[i]) return ramp[i + 1] || ramp[ramp.length - 1];
      }
      return ramp[0];
    }

    function computeBreaks(values) {
      var sorted = values.filter(function(v) { return v !== null && !isNaN(v); }).sort(function(a, b) { return a - b; });
      if (sorted.length < 5) return [0, 10, 50, 100, 500];
      var pcts = [0.2, 0.4, 0.6, 0.8, 0.95];
      return pcts.map(function(p) {
        var idx = Math.floor(p * sorted.length);
        return sorted[Math.min(idx, sorted.length - 1)];
      });
    }

    function buildChoropleth_banking() {
      if (choroLayer) { map.removeLayer(choroLayer); choroLayer = null; }
      if (!distGeoJSON || !currentQuarter) return;

      var lookup = buildDistrictLookup();
      var ramp = getRamp(currentIndicator);
      var ind = INDICATORS[currentIndicator];
      var metric = ind.metrics[currentMetricIdx];

      // In Focus NE scope, filter to 8 NE states only
      var NE_ALL = ['ASSAM','MEGHALAYA','MANIPUR','ARUNACHAL PRADESH','MIZORAM','TRIPURA','NAGALAND','SIKKIM'];
      var filtered = {
        type: distGeoJSON.type,
        features: distGeoJSON.features.filter(function(f) {
          var st = f.properties.STATE_UT?.toUpperCase()?.trim();
          if (!NE_STATES.includes(st)) return false;
          if (currentScope === 'ne' && NE_ALL.indexOf(st) < 0) return false;
          if (bankingStateFilter && st !== bankingStateFilter) return false;
          return true;
        }),
      };

      var allVals = [];
      filtered.features.forEach(function(f) {
        var dn = normDist(f.properties.DISTRICT);
        var data = lookup.get(dn) || lookup.get(DISTRICT_ALIASES[dn]);
        if (data && data.value !== null) allVals.push(data.value);
      });
      var breaks = computeBreaks(allVals);

      updateLegend_banking(metric.label, breaks, ramp);

      choroLayer = L.geoJSON(filtered, {
        style: function(feature) {
          var dn = normDist(feature.properties.DISTRICT);
          var data = lookup.get(dn) || lookup.get(DISTRICT_ALIASES[dn]);
          var val = data ? data.value : null;
          return {
            fillColor: getColor(val, breaks, ramp),
            fillOpacity: val === null ? 0.5 : 0.78,
            color: '#c8bfb0',
            weight: 0.8,
            opacity: 0.7,
          };
        },
        onEachFeature: function(feature, layer) {
          var p = feature.properties;
          var dn = normDist(p.DISTRICT);
          var data = lookup.get(dn) || lookup.get(DISTRICT_ALIASES[dn]);

          layer.on({
            mouseover: function(e) {
              e.target.setStyle({ weight: 2.5, color: '#6b4c2a', fillOpacity: 0.92 });
              var tip = '<div class="dist-tooltip">'
                + '<div class="dtt-head">'
                + '<div class="dtt-name">' + p.DISTRICT + '</div>'
                + '<div class="dtt-state">' + p.STATE_UT + '</div>'
                + '</div>';
              if (data) {
                if (data.fallbackQuarter) {
                  tip += '<div class="dtt-fallback">Data from ' + fmtQuarter(data.fallbackQuarter) + '</div>';
                }
                tip += '<div class="dtt-metrics">';
                for (var label in data.metrics) {
                  var val = data.metrics[label];
                  var formatted = val !== null ? fmtNum(val) : '—';
                  var isCurrent = label === metric.label;
                  tip += '<div class="dtt-row' + (isCurrent ? ' dtt-active' : '') + '">'
                    + '<span class="dtt-label">' + label + '</span>'
                    + '<span class="dtt-val">' + formatted + '</span>'
                    + '</div>';
                }
                tip += '</div>';
              } else {
                tip += '<div class="dtt-empty">No data available</div>';
              }
              tip += '</div>';
              e.target.bindTooltip(tip, { sticky: true, className: '', offset: [10, 0] }).openTooltip();
            },
            mouseout: function(e) {
              choroLayer.resetStyle(e.target);
              e.target.closeTooltip();
            },
            dblclick: function(e) {
              L.DomEvent.stopPropagation(e);
              L.DomEvent.preventDefault(e);
              focusDistrict(normDist(p.DISTRICT), p.STATE_UT);
            },
          });
        },
      }).addTo(map);

      updateStats_banking(lookup, allVals);
      if (focusedDistrict) updateFocusPanel();
    }

    function updateLegend_banking(metricLabel, breaks, ramp) {
      document.getElementById('legend-title').textContent = metricLabel;
      var scale = document.getElementById('legend-scale');
      var labels = document.getElementById('legend-labels');
      scale.innerHTML = ramp.map(function(c) { return '<div class="choro-swatch" style="background:' + c + '"></div>'; }).join('');
      var lbls = ['0'];
      breaks.forEach(function(b) { lbls.push(fmtNum(b)); });
      labels.innerHTML = lbls.map(function(l) { return '<span>' + l + '</span>'; }).join('');
    }

    function updateStats_banking(lookup, allVals) {
      var total = lookup ? lookup.size : 0;
      var withData = allVals ? allVals.length : 0;
      var avg = withData ? (allVals.reduce(function(a, b) { return a + b; }, 0) / withData) : 0;
      var max = withData ? Math.max.apply(null, allVals) : 0;
      var min = withData ? Math.min.apply(null, allVals) : 0;
      var ind = INDICATORS[currentIndicator];
      var metric = ind.metrics[currentMetricIdx];

      document.getElementById('stats-banking').innerHTML =
        '<strong>' + ind.title + '</strong><br>'
        + '<span style="font-size:9px;color:#888078">' + fmtQuarter(currentQuarter) + '</span><br>'
        + '<span style="color:#3d7a8e">' + withData + '</span> districts with data<br>'
        + 'Avg: <strong>' + fmtNum(avg) + '</strong><br>'
        + 'Min: ' + fmtNum(min) + ' · Max: ' + fmtNum(max);

      document.getElementById('btn-reset-banking').style.display = bankingStateFilter ? 'block' : 'none';
    }

    // ── District Focus Mode ──
    var focusedDistrict = null;
    var focusedState = null;

    function geoToSVGPath(geometry, width, height) {
      var coords = [];
      function collectCoords(c) {
        if (typeof c[0] === 'number') { coords.push(c); return; }
        for (var i = 0; i < c.length; i++) collectCoords(c[i]);
      }
      collectCoords(geometry.coordinates);
      if (coords.length === 0) return '';

      var minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
      for (var i = 0; i < coords.length; i++) {
        if (coords[i][0] < minX) minX = coords[i][0];
        if (coords[i][0] > maxX) maxX = coords[i][0];
        if (coords[i][1] < minY) minY = coords[i][1];
        if (coords[i][1] > maxY) maxY = coords[i][1];
      }
      var geoW = maxX - minX || 1;
      var geoH = maxY - minY || 1;
      var pad = 30;
      var scale = Math.min((width - pad * 2) / geoW, (height - pad * 2) / geoH);
      var cx = width / 2, cy = height / 2;
      var geoCx = (minX + maxX) / 2, geoCy = (minY + maxY) / 2;

      function px(lng) { return cx + (lng - geoCx) * scale; }
      function py(lat) { return cy - (lat - geoCy) * scale; }

      function ringToPath(ring) {
        var d = '';
        for (var j = 0; j < ring.length; j++) {
          d += (j === 0 ? 'M' : 'L') + px(ring[j][0]).toFixed(1) + ',' + py(ring[j][1]).toFixed(1);
        }
        return d + 'Z';
      }

      var path = '';
      var type = geometry.type;
      var c = geometry.coordinates;
      if (type === 'Polygon') {
        for (var ri = 0; ri < c.length; ri++) path += ringToPath(c[ri]);
      } else if (type === 'MultiPolygon') {
        for (var pi = 0; pi < c.length; pi++) {
          for (var ri2 = 0; ri2 < c[pi].length; ri2++) path += ringToPath(c[pi][ri2]);
        }
      }
      return path;
    }

    function focusDistrict(districtName, stateName) {
      if (!distGeoJSON) return;
      var feature = distGeoJSON.features.find(function(f) {
        return normDist(f.properties.DISTRICT) === districtName;
      });
      if (!feature) return;

      focusedDistrict = districtName;
      focusedState = stateName || feature.properties.STATE_UT;

      var svgPath = geoToSVGPath(feature.geometry, 400, 400);
      document.getElementById('focus-path').setAttribute('d', svgPath);

      updateFocusPanel();
      document.getElementById('district-focus').classList.add('active');
    }

    function updateFocusPanel() {
      if (!focusedDistrict) return;
      var lookup = buildDistrictLookup();
      var ind = INDICATORS[currentIndicator];
      var metric = ind.metrics[currentMetricIdx];
      var data = lookup.get(focusedDistrict) || lookup.get(DISTRICT_ALIASES[focusedDistrict]);
      var ramp = getRamp(currentIndicator);

      var val = data ? data.value : null;
      var breaks = [];
      lookup.forEach(function(d) { if (d.value !== null) breaks.push(d.value); });
      breaks = computeBreaks(breaks);
      var color = getColor(val, breaks, ramp);

      document.getElementById('focus-path').style.fill = color;
      document.getElementById('focus-name').textContent = focusedDistrict.split(' ').map(function(w) {
        return w.charAt(0) + w.slice(1).toLowerCase();
      }).join(' ');
      document.getElementById('focus-state').textContent = focusedState || '';
      document.getElementById('focus-metric-label').textContent = metric.label;
      document.getElementById('focus-value').textContent = val !== null ? fmtNum(val) : 'No data';
      document.getElementById('focus-quarter').textContent = fmtQuarter(currentQuarter);

      // Update stroke color to match indicator ramp
      document.getElementById('focus-path').style.stroke = ramp[4] || '#b8603e';
    }

    function exitFocus() {
      focusedDistrict = null;
      focusedState = null;
      document.getElementById('district-focus').classList.remove('active');
    }

    // Focus mode event listeners
    document.getElementById('focus-close').addEventListener('click', function(e) {
      e.stopPropagation();
      exitFocus();
    });
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && focusedDistrict) exitFocus();
    });
    document.getElementById('district-focus').addEventListener('click', function(e) {
      if (e.target === this) exitFocus(); // Click on backdrop
    });

    // Banking district labels
    function buildDistrictLabels_banking() {
      if (!distGeoJSON) return;
      bankingCentroids = [];
      distGeoJSON.features.forEach(function(f) {
        var st = f.properties.STATE_UT?.toUpperCase()?.trim();
        if (!NE_STATES.includes(st)) return;
        try {
          var tmp = L.geoJSON(f);
          var b = tmp.getBounds();
          bankingCentroids.push({ center: b.getCenter(), name: f.properties.DISTRICT, bounds: b, state: st });
        } catch(e) {}
      });
    }

    function updateLabelVisibility_banking() {
      if (currentMode !== 'banking') return;
      if (distLabelsLayer) { map.removeLayer(distLabelsLayer); distLabelsLayer = null; }
      var z = map.getZoom();
      if (z < 8) return;
      var viewBounds = map.getBounds();
      distLabelsLayer = L.layerGroup();
      var placed = [];
      bankingCentroids.forEach(function(d) {
        if (bankingStateFilter && d.state !== bankingStateFilter) return;
        if (!viewBounds.intersects(d.bounds)) return;
        var px = map.latLngToContainerPoint(d.center);
        var tooClose = placed.some(function(p) { return Math.abs(px.x - p.x) < 120 && Math.abs(px.y - p.y) < 30; });
        if (tooClose) return;
        placed.push(px);
        distLabelsLayer.addLayer(L.marker(d.center, {
          icon: L.divIcon({
            className: 'dist-label',
            html: d.name,
            iconSize: [0, 0],
            iconAnchor: [0, 0],
          }),
          interactive: false,
        }));
      });
      distLabelsLayer.addTo(map);
    }

    function populateMetrics() {
      var sel = document.getElementById('sel-metric');
      var ind = INDICATORS[currentIndicator];
      sel.innerHTML = '';
      ind.metrics.forEach(function(m, i) {
        var o = document.createElement('option');
        o.value = i;
        o.textContent = m.label;
        sel.appendChild(o);
      });
      sel.value = currentMetricIdx < ind.metrics.length ? currentMetricIdx : 0;
      currentMetricIdx = parseInt(sel.value);
    }

    var currentQIdx = 0;

    function setTimelinePosition(idx) {
      if (idx < 0 || idx >= sortedQuarters.length) return;
      currentQIdx = idx;
      currentQuarter = sortedQuarters[idx];
      document.getElementById('quarter-label').textContent = fmtQuarter(currentQuarter);
      var pct = sortedQuarters.length > 1 ? (idx / (sortedQuarters.length - 1)) * 100 : 0;
      document.getElementById('timeline-fill').style.height = pct + '%';
      document.getElementById('timeline-thumb').style.top = pct + '%';
      var dots = document.querySelectorAll('.tl-dot');
      dots.forEach(function(d, i) { d.classList.toggle('active', i === idx); });
      // Hide endpoint label when thumb is near it
      var startEl = document.getElementById('tl-start-label');
      var endEl = document.getElementById('tl-end-label');
      if (startEl) startEl.style.opacity = pct < 15 ? '0' : '1';
      if (endEl) endEl.style.opacity = pct > 85 ? '0' : '1';
    }

    function populateSlider() {
      var qSet = new Set();
      for (var slug of Object.keys(slbcData)) {
        for (var ri = 0; ri < slbcData[slug].length; ri++) {
          var rec = slbcData[slug][ri];
          if (rec.period) qSet.add(rec.period);
        }
      }
      sortedQuarters = Array.from(qSet).sort().reverse();
      currentQIdx = 0;
      currentQuarter = sortedQuarters[currentQIdx];
      document.getElementById('quarter-label').textContent = fmtQuarter(currentQuarter);

      // Set endpoint labels (top=latest, bottom=earliest — time flows up)
      if (sortedQuarters.length > 0) {
        document.getElementById('tl-start-label').textContent = sortedQuarters[0].substring(0, 4);
        document.getElementById('tl-end-label').textContent = sortedQuarters[sortedQuarters.length - 1].substring(0, 4);
      }

      // Build tick marks (subtle year markers, no labels on dots)
      var dotsEl = document.getElementById('timeline-dots');
      dotsEl.innerHTML = '';
      var prevYear = '';
      for (var i = 0; i < sortedQuarters.length; i++) {
        var q = sortedQuarters[i];
        var pct = sortedQuarters.length > 1 ? (i / (sortedQuarters.length - 1)) * 100 : 0;
        var yr = q.substring(0, 4);
        var isNewYear = yr !== prevYear;
        prevYear = yr;
        var dot = document.createElement('div');
        dot.className = 'tl-dot' + (isNewYear ? ' year-dot' : '') + (i === currentQIdx ? ' active' : '');
        dot.style.top = pct + '%';
        dot.dataset.idx = i;
        dot.addEventListener('click', function(e) {
          var idx = parseInt(this.dataset.idx);
          setTimelinePosition(idx);
          clearTimeout(sliderTimer);
          sliderTimer = setTimeout(function() { buildChoropleth_banking(); }, 120);
        });
        dotsEl.appendChild(dot);
      }
      setTimelinePosition(currentQIdx);
    }

    function flattenTimeseries(json) {
      if (Array.isArray(json)) return json;
      if (!json || !json.periods) return [];
      var records = [];
      for (var pi = 0; pi < json.periods.length; pi++) {
        var p = json.periods[pi];
        if (!p.districts) continue;
        for (var di = 0; di < p.districts.length; di++) {
          records.push(p.districts[di]);
        }
      }
      return records;
    }

    function loadBankingData() {
      var slugs = Object.values(STATE_SLUGS);
      Promise.all(slugs.map(function(slug) {
        return fetch(_B + 'slbc-data/' + slug + '/' + slug + '_fi_slim.json')
          .then(function(r) { return r.ok ? r.json() : null; })
          .then(function(json) { return { slug: slug, data: json }; })
          .catch(function() { return { slug: slug, data: null }; });
      })).then(function(results) {
        for (var i = 0; i < results.length; i++) {
          var r = results[i];
          if (!r.data) { slbcData[r.slug] = []; continue; }
          var flat = flattenTimeseries(r.data);
          for (var fi = 0; fi < flat.length; fi++) {
            if (flat[fi].period) flat[fi].period = normalizePeriod(flat[fi].period);
          }
          slbcData[r.slug] = flat;
        }
        slbcLoaded = true;
        populateMetrics();
        populateSlider();
        updateTimelineColor();
        buildDistrictLabels_banking();
        buildChoropleth_banking();
        updateLabelVisibility_banking();
        flyToNE(false);
      }).catch(function(err) {
        document.getElementById('stats-banking').textContent = 'Error: ' + err.message;
      });
    }

    // Banking event listeners
    // Dynamic timeline color — matches choropleth ramp
    function updateTimelineColor() {
      var ramp = getRamp(currentIndicator);
      var accent = ramp[4]; // e.g. #b8603e, #3a8a2a, #2a6a8e
      // Parse hex to RGB for rgba usage
      var r = parseInt(accent.slice(1,3),16), g = parseInt(accent.slice(3,5),16), b = parseInt(accent.slice(5,7),16);
      var fill = document.getElementById('timeline-fill');
      var thumb = document.getElementById('timeline-thumb');
      var label = document.getElementById('quarter-label');
      if (fill) fill.style.background = 'rgba('+r+','+g+','+b+',0.35)';
      if (thumb) thumb.style.background = accent;
      if (label) label.style.color = accent;
      // Update CSS custom properties for hover/active states via a style tag
      var styleEl = document.getElementById('tl-dynamic-style');
      if (!styleEl) { styleEl = document.createElement('style'); styleEl.id = 'tl-dynamic-style'; document.head.appendChild(styleEl); }
      styleEl.textContent =
        '.tl-dot:hover{background:rgba('+r+','+g+','+b+',0.3)!important}' +
        '.tl-dot.year-dot.active{background:rgba('+r+','+g+','+b+',0.4)!important}' +
        '#timeline-thumb:hover{box-shadow:0 0 8px rgba('+r+','+g+','+b+',0.3)!important}' +
        '#timeline-thumb:active{box-shadow:0 0 10px rgba('+r+','+g+','+b+',0.4)!important}';
    }

    document.getElementById('sel-indicator').addEventListener('change', function(e) {
      currentIndicator = e.target.value;
      currentMetricIdx = 0;
      populateMetrics();
      updateTimelineColor();
      if (slbcLoaded) buildChoropleth_banking();
    });

    document.getElementById('sel-metric').addEventListener('change', function(e) {
      currentMetricIdx = parseInt(e.target.value);
      if (slbcLoaded) buildChoropleth_banking();
      // Hide popover on change
      document.getElementById('info-popover').classList.remove('visible');
    });

    // Info tooltip popover
    (function() {
      var popover = document.getElementById('info-popover');
      var activeBtn = null;

      function showInfo(type) {
        var ind = INDICATORS[currentIndicator];
        var text = '';
        if (type === 'indicator') {
          text = ind.desc || '';
        } else {
          var metric = ind.metrics[currentMetricIdx];
          text = metric ? (metric.desc || '') : '';
        }
        if (!text) { popover.classList.remove('visible'); return; }
        popover.textContent = text;
        popover.classList.add('visible');
        activeBtn = type;
      }

      document.getElementById('info-indicator').addEventListener('click', function(e) {
        e.stopPropagation();
        if (activeBtn === 'indicator' && popover.classList.contains('visible')) {
          popover.classList.remove('visible'); activeBtn = null;
        } else {
          showInfo('indicator');
        }
      });
      document.getElementById('info-metric').addEventListener('click', function(e) {
        e.stopPropagation();
        if (activeBtn === 'metric' && popover.classList.contains('visible')) {
          popover.classList.remove('visible'); activeBtn = null;
        } else {
          showInfo('metric');
        }
      });
      document.addEventListener('click', function() {
        popover.classList.remove('visible'); activeBtn = null;
      });
    })();

    // Timeline drag interaction
    (function() {
      var track = document.getElementById('timeline-track');
      var thumb = document.getElementById('timeline-thumb');
      var dragging = false;

      function posToIdx(clientY) {
        var rect = track.getBoundingClientRect();
        var pct = Math.max(0, Math.min(1, (clientY - rect.top) / rect.height));
        return Math.round(pct * (sortedQuarters.length - 1));
      }

      thumb.addEventListener('mousedown', function(e) { dragging = true; e.preventDefault(); });
      track.addEventListener('mousedown', function(e) {
        dragging = true;
        var idx = posToIdx(e.clientY);
        setTimelinePosition(idx);
        clearTimeout(sliderTimer);
        sliderTimer = setTimeout(function() { buildChoropleth_banking(); }, 120);
      });
      document.addEventListener('mousemove', function(e) {
        if (!dragging || sortedQuarters.length === 0) return;
        e.preventDefault();
        var idx = posToIdx(e.clientY);
        if (idx !== currentQIdx) {
          setTimelinePosition(idx);
          clearTimeout(sliderTimer);
          sliderTimer = setTimeout(function() { buildChoropleth_banking(); }, 120);
        }
      });
      document.addEventListener('selectstart', function(e) { if (dragging) e.preventDefault(); });
      document.addEventListener('mouseup', function() { dragging = false; });

      // Touch support
      thumb.addEventListener('touchstart', function(e) { dragging = true; e.preventDefault(); }, {passive:false});
      track.addEventListener('touchstart', function(e) {
        dragging = true;
        var idx = posToIdx(e.touches[0].clientY);
        setTimelinePosition(idx);
        clearTimeout(sliderTimer);
        sliderTimer = setTimeout(function() { buildChoropleth_banking(); }, 120);
      }, {passive:false});
      document.addEventListener('touchmove', function(e) {
        if (!dragging || sortedQuarters.length === 0) return;
        var idx = posToIdx(e.touches[0].clientY);
        if (idx !== currentQIdx) {
          setTimelinePosition(idx);
          clearTimeout(sliderTimer);
          sliderTimer = setTimeout(function() { buildChoropleth_banking(); }, 120);
        }
      });
      document.addEventListener('touchend', function() { dragging = false; });
    })();

    document.getElementById('sel-state').addEventListener('change', function(e) {
      bankingStateFilter = e.target.value;
      if (slbcLoaded) {
        buildChoropleth_banking();
        updateLabelVisibility_banking();
      }
      if (bankingStateFilter) {
        var stateFts = distGeoJSON ? distGeoJSON.features.filter(function(f) {
          return f.properties.STATE_UT?.toUpperCase()?.trim() === bankingStateFilter;
        }) : [];
        if (stateFts.length) {
          var group = L.geoJSON({ type: 'FeatureCollection', features: stateFts });
          map.flyToBounds(group.getBounds(), { padding: [40, 40], maxZoom: 9, duration: 1.0 });
        }
      } else {
        flyToNE();
      }
    });

    document.getElementById('btn-reset-banking').addEventListener('click', function() {
      bankingStateFilter = '';
      document.getElementById('sel-state').value = '';
      flyToNE();
      if (slbcLoaded) {
        buildChoropleth_banking();
        updateLabelVisibility_banking();
      }
    });

    // ══════════════════════════════════════════
    // Section 4 — Mode switching
    // ══════════════════════════════════════════
    function switchMode(mode) {
      if (mode === currentMode) return;
      currentMode = mode;

      // Update toggle buttons
      document.getElementById('mode-capital').className = 'view-btn' + (mode === 'capital' ? ' active' : '');
      document.getElementById('mode-banking').className = 'view-btn' + (mode === 'banking' ? ' active' : '');

      // Show/hide control sections
      document.getElementById('controls-capital').style.display = mode === 'capital' ? 'block' : 'none';
      document.getElementById('controls-banking').style.display = mode === 'banking' ? 'block' : 'none';

      // Show/hide time slider
      document.getElementById('time-slider').style.display = mode === 'banking' ? 'flex' : 'none';

      // Clean up outgoing mode layers
      if (choroLayer) { map.removeLayer(choroLayer); choroLayer = null; }
      if (distLabelsLayer) { map.removeLayer(distLabelsLayer); distLabelsLayer = null; }

      if (mode === 'capital') {
        // Hide banking legend, show appropriate capital legend
        document.getElementById('choro-legend-banking').style.display = 'none';
        // Restore capital mode
        setView(currentView);
        map.flyToBounds(INDIA_BOUNDS, { padding: [20, 20], duration: 1.0 });
      } else {
        // Hide capital layers
        [clusterCDSL, clusterNSDL, clusterMFDI, clusterMFDC].forEach(function(c) { if (c._map) map.removeLayer(c); });
        document.getElementById('legend').style.display = 'none';
        document.getElementById('choro-legend-capital').style.display = 'none';
        document.getElementById('btn-back').style.display = 'none';
        drilldownActive = false;

        // Show banking legend
        document.getElementById('choro-legend-banking').style.display = 'block';

        if (!slbcLoaded) {
          document.getElementById('stats-banking').textContent = 'Loading FI data…';
          loadBankingData();
          // flyToNE will be called after data loads in loadBankingData callback
        } else {
          buildChoropleth_banking();
          updateLabelVisibility_banking();
          flyToNE();
        }
      }
    }

    // Mode toggle event listeners
    document.getElementById('mode-capital').addEventListener('click', function() { switchMode('capital'); });
    document.getElementById('mode-banking').addEventListener('click', function() { switchMode('banking'); });

    // ══════════════════════════════════════════
    // Section 4b — Focus NE (block-level) scope toggle
    // ══════════════════════════════════════════
    function switchScope(scope) {
      if (scope === currentScope) return;
      currentScope = scope;
      document.getElementById('scope-label-india').classList.toggle('active', scope === 'india');
      document.getElementById('scope-label-ne').classList.toggle('active', scope === 'ne');
      document.getElementById('scope-switch').checked = (scope === 'ne');

      var selState = document.getElementById('sel-state');
      if (scope === 'ne') {
        // Restrict state dropdown to 8 NE states
        var NE_ALL = ['ASSAM','MEGHALAYA','MANIPUR','ARUNACHAL PRADESH','MIZORAM','TRIPURA','NAGALAND','SIKKIM'];
        Array.from(selState.options).forEach(function(opt) {
          if (opt.value === '') { opt.textContent = 'All NE States'; opt.style.display = ''; }
          else { opt.style.display = NE_ALL.indexOf(opt.value) >= 0 ? '' : 'none'; }
        });
        if (selState.value && NE_ALL.indexOf(selState.value) < 0) {
          selState.value = '';
        }
        // Use district-level choropleth filtered to NE states + zoom to NE
        bankingStateFilter = selState.value; // '' means all (but only NE visible in dropdown)
        buildChoropleth_banking();
        map.flyToBounds(NE_FOCUS_BOUNDS, { duration: 1.0, padding: [20, 20] });
      } else {
        // Restore state dropdown to all 22 states
        Array.from(selState.options).forEach(function(opt) {
          if (opt.value === '') opt.textContent = 'All States';
          opt.style.display = '';
        });
        buildChoropleth_banking();
        flyToNE();
      }
    }

    function loadBlockData() {
      var statsEl = document.getElementById('stats-banking');
      if (statsEl) statsEl.textContent = 'Loading block-level data…';

      var blockGeoURL = _B + 'data/ne_subdistrict_boundaries.geojson';
      var blockStates = ['assam','manipur','mizoram','nagaland','tripura','sikkim'];
      var fetches = [fetch(blockGeoURL).then(function(r){return r.json();})];
      blockStates.forEach(function(s) {
        var url = _B + 'slbc-data/' + s + '/' + s + '_block_timeseries.json';
        fetches.push(
          fetch(url).then(function(r){return r.ok ? r.json() : null;}).catch(function(){return null;})
        );
      });

      Promise.all(fetches).then(function(results) {
        blockGeoJSON = results[0];
        // Merge block timeseries from all states
        var allBlocks = {};
        for (var i = 1; i < results.length; i++) {
          if (!results[i]) continue;
          var ts = results[i];
          var slug = blockStates[i-1];
          if (ts.periods) {
            ts.periods.forEach(function(p) {
              var qkey = normalizePeriod(p.period);
              if (!allBlocks[qkey]) allBlocks[qkey] = [];
              (p.blocks || []).forEach(function(b) {
                b._period_normalized = qkey;
                allBlocks[qkey].push(b);
              });
            });
          }
        }
        blockData = allBlocks;
        blockLoaded = true;
        buildChoropleth_block();
        map.flyToBounds(NE_FOCUS_BOUNDS, { duration: 1.0 });
      }).catch(function(err) {
        console.error('Block data load failed:', err);
        if (statsEl) statsEl.textContent = 'Block data not available yet';
      });
    }

    function buildChoropleth_block() {
      if (!blockGeoJSON || !blockData) return;
      if (choroLayer) { map.removeLayer(choroLayer); choroLayer = null; }
      if (distLabelsLayer) { map.removeLayer(distLabelsLayer); distLabelsLayer = null; }

      var indicator = document.getElementById('sel-indicator').value;
      var metricSel = document.getElementById('sel-metric');
      var metric = metricSel ? metricSel.value : '';
      var stateFilter = document.getElementById('sel-state').value;

      // Find the best available quarter in block data
      var availableQ = Object.keys(blockData).sort().reverse();
      var qkey = currentQuarter || availableQ[0] || '';
      // Fallback to nearest available quarter
      if (!blockData[qkey] && availableQ.length) {
        for (var qi = 0; qi < availableQ.length; qi++) {
          if (availableQ[qi] <= qkey) { qkey = availableQ[qi]; break; }
        }
        if (!blockData[qkey]) qkey = availableQ[0];
      }

      var blocks = blockData[qkey] || [];

      // Build lookup: block_key → record
      var lookup = {};
      blocks.forEach(function(b) {
        var key = (b.district || '').toUpperCase() + '__' + (b.block || '').toUpperCase();
        lookup[key] = b;
      });

      // Collect values for color scale
      var vals = [];
      var features = blockGeoJSON.features || [];

      features.forEach(function(f) {
        var props = f.properties;
        if (stateFilter && props.STATE_UT !== stateFilter) return;
        var key = props.DISTRICT + '__' + props.SUB_DIST;
        var rec = lookup[key];
        if (!rec) return;
        var v = getVal(rec, indicator, metric);
        if (v !== null && v !== undefined && !isNaN(v)) vals.push(v);
      });

      if (vals.length === 0) {
        var statsEl = document.getElementById('stats-banking');
        if (statsEl) statsEl.innerHTML = '<em>No block-level data for this indicator/quarter</em>';
        return;
      }

      vals.sort(function(a,b){return a-b;});
      var breaks = computeBreaks(vals);
      var ramp = getRamp(indicator);

      choroLayer = L.geoJSON(blockGeoJSON, {
        filter: function(feature) {
          if (stateFilter && feature.properties.STATE_UT !== stateFilter) return false;
          return NE_FOCUS_STATES.indexOf(feature.properties.STATE_UT) >= 0;
        },
        style: function(feature) {
          var props = feature.properties;
          var key = props.DISTRICT + '__' + props.SUB_DIST;
          var rec = lookup[key];
          var v = rec ? getVal(rec, indicator, metric) : null;
          var color = (v !== null && v !== undefined && !isNaN(v)) ?
            getColor(v, breaks, ramp) : '#e0ddd8';
          return {
            fillColor: color,
            fillOpacity: 0.75,
            color: '#fff',
            weight: 0.5,
            opacity: 0.8
          };
        },
        onEachFeature: function(feature, layer) {
          var props = feature.properties;
          var key = props.DISTRICT + '__' + props.SUB_DIST;
          var rec = lookup[key];
          var v = rec ? getVal(rec, indicator, metric) : null;
          var vStr = (v !== null && v !== undefined && !isNaN(v)) ?
            (v >= 1000 ? Math.round(v).toLocaleString() : v.toFixed(2)) : 'N/A';
          var metricLabel = metricSel ? metricSel.options[metricSel.selectedIndex].text : metric;
          layer.bindTooltip(
            '<strong>' + props.SUB_DIST + '</strong><br>' +
            '<span style="font-size:9px;color:#888">' + props.DISTRICT + ', ' + props.STATE_UT + '</span><br>' +
            '<span style="font-size:11px">' + metricLabel + ': <b>' + vStr + '</b></span>',
            { sticky: true, className: 'choro-tip' }
          );
        }
      }).addTo(map);

      // Update stats
      var avg = vals.reduce(function(a,b){return a+b;},0) / vals.length;
      var statsEl = document.getElementById('stats-banking');
      if (statsEl) {
        statsEl.innerHTML = '<b>Focus NE — Block Level</b><br>' +
          vals.length + ' blocks with data<br>' +
          'Avg: ' + avg.toFixed(1) + ' · Min: ' + vals[0].toFixed(1) +
          ' · Max: ' + vals[vals.length-1].toFixed(1);
      }

      // Update legend
      var metricLabel = metricSel ? metricSel.options[metricSel.selectedIndex].text : metric;
      updateLegend_banking(metricLabel, breaks, ramp);
    }

    document.getElementById('scope-switch').addEventListener('change', function() {
      switchScope(this.checked ? 'ne' : 'india');
    });

    // ══════════════════════════════════════════
    // Section 5 — URL parameter support
    // ══════════════════════════════════════════
    // (auto-switch is handled after capital data loads above)

    // ══════════════════════════════════════════
    // Section 6 — Mobile bottom sheet
    // ══════════════════════════════════════════
    if (window.innerWidth <= 640) {
      const panel = document.getElementById('panel');
      const handle = document.getElementById('panel-handle');
      panel.classList.add('collapsed');

      // Toggle on handle tap
      handle.addEventListener('click', function() {
        panel.classList.toggle('collapsed');
      });

      // Also collapse on panel-head tap
      document.getElementById('panel-head').addEventListener('click', function() {
        panel.classList.toggle('collapsed');
      });

      // Swipe gestures
      let startY = 0, startTime = 0;
      panel.addEventListener('touchstart', function(e) {
        startY = e.touches[0].clientY;
        startTime = Date.now();
      }, { passive: true });
      panel.addEventListener('touchend', function(e) {
        const dy = e.changedTouches[0].clientY - startY;
        const dt = Date.now() - startTime;
        if (dt < 400) {
          if (dy > 40) panel.classList.add('collapsed');     // swipe down → collapse
          else if (dy < -40) panel.classList.remove('collapsed'); // swipe up → expand
        }
      }, { passive: true });

      // Collapse sheet when map is tapped
      document.getElementById('map').addEventListener('click', function() {
        if (!panel.classList.contains('collapsed')) {
          panel.classList.add('collapsed');
        }
      });
    }
  </script>
</BaseLayout>

