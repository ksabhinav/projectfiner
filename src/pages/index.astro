    // Cross-category fallbacks — when a field isn't found under the primary category,
    // try these alternative categories (different states store the same data under different names)
    var CROSS_CATEGORY_FALLBACKS = {
      'branch_network': ['credit_deposit_ratio', 'kcc', 'fi_kcc', 'digital_transactions', 'branch_network_p2', 'branch_network_p3', 'branch_network_p4', 'atm_network', 'business_correspondents'],
      'credit_deposit_ratio': ['key_indicators', 'district_misc', 'cd_ratio'],
