    // Color ramps
    var RAMP_DEFAULT = ['#faf6f0','#f0e0c8','#e8c89a','#d4a06a','#b8603e','#8a3a1a'];
    var RAMP_GREEN   = ['#f5f9f0','#d4eac0','#a8d48a','#6ab04c','#3a8a2a','#1a5a10'];
    var RAMP_BLUE    = ['#f0f5fa','#c8ddf0','#8ab8d4','#4a90b8','#2a6a8e','#104060'];

    function getRamp(indicator) {
      if (indicator === 'credit_deposit_ratio') return RAMP_GREEN;
      if (indicator === 'digital_transactions') return RAMP_BLUE;
      return RAMP_DEFAULT;
    }

    // Banking state
    var slbcData = {};
    var currentIndicator = 'credit_deposit_ratio';
    var currentMetricIdx = 0;
    var currentQuarter = '';
    var bankingStateFilter = '';
    var slbcLoaded = false;
    var sortedQuarters = [];
