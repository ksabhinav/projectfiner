---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Project FINER — Financial Inclusion in the North East Region">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />

  <div id="map"></div>

  <div id="panel">
    <div id="panel-head">
      <h1>Project FINER</h1>
      <p class="panel-sub">Financial Inclusion in the North East Region</p>
    </div>

    <nav class="panel-nav">
      <a href={`${base}slbc-data`} class="nav-pill">SLBC Data</a>
      <a href={`${base}capital-markets/data-download`} class="nav-pill">Downloads</a>
      <a href={`${base}analysis`} class="nav-pill">Analysis</a>
    </nav>

    <div id="panel-body">
      <!-- Mode toggle -->
      <div class="mode-row" style="margin-bottom:10px">
        <button class="view-btn active" id="mode-capital">Capital Market Access</button>
        <button class="view-btn" id="mode-banking">Banking Access</button>
      </div>

      <!-- ═══ Capital controls ═══ -->
      <div id="controls-capital">
        <div class="view-row" style="margin-bottom:10px">
          <button class="view-btn active" id="vbtn-choro">Access Map</button>
          <button class="view-btn" id="vbtn-dots">Points</button>
        </div>

        <div class="grp open dpsc-active" id="grp-dpsc">
          <div class="grp-master" id="grp-dpsc-master">
            <div class="master-dot"></div>
            <span class="grp-title">DP Service Centres</span>
            <span class="grp-arrow">&#9662;</span>
          </div>
          <div class="grp-subs">
            <button class="sub-btn on-cdsl" id="tog-cdsl"><span class="sub-dot"></span>CDSL</button>
            <button class="sub-btn on-nsdl" id="tog-nsdl"><span class="sub-dot"></span>NSDL</button>
          </div>
        </div>
        <div class="grp open mfd-active" id="grp-mfd">
          <div class="grp-master" id="grp-mfd-master">
            <div class="master-dot"></div>
            <span class="grp-title">MF Distributors</span>
            <span class="grp-arrow">&#9662;</span>
          </div>
          <div class="grp-subs">
            <button class="sub-btn on-mfdi" id="tog-mfdi"><span class="sub-dot"></span>Individual</button>
            <button class="sub-btn on-mfdc" id="tog-mfdc"><span class="sub-dot"></span>Corporate</button>
          </div>
        </div>

        <div style="height:1px;background:#e8e5e0;margin:10px 0"></div>

        <div class="field">
          <span class="flabel">Search</span>
          <input class="finput" type="text" id="search-dp" placeholder="Search by name…" />
        </div>
        <div class="field" style="position:relative">
          <span class="flabel">Go to city</span>
          <input class="finput" type="text" id="search-loc" placeholder="e.g. Shillong, Tura…" autocomplete="off" />
          <div id="loc-sugg"></div>
        </div>
        <div class="field">
          <span class="flabel">State</span>
          <select class="finput" id="state-select">
            <option value="">All India</option>
          </select>
        </div>

        <div id="stats-capital">Loading…</div>
        <button id="btn-reset-capital">&#8634; Reset</button>
      </div>

      <!-- ═══ Banking controls ═══ -->
      <div id="controls-banking" style="display:none">
        <div class="field">
          <span class="flabel">Indicator</span>
          <select class="finput banking-input" id="sel-indicator">
            <option value="credit_deposit_ratio">Credit-Deposit Ratio</option>
            <option value="pmjdy">PM Jan Dhan Yojana</option>
            <option value="branch_network">Branch Network</option>
            <option value="kcc">Kisan Credit Card</option>
            <option value="shg">Self Help Groups</option>
            <option value="digital_transactions">Digital Transactions</option>
            <option value="aadhaar_authentication">Aadhaar Authentication</option>
          </select>
        </div>

        <div class="field">
          <span class="flabel">Metric</span>
          <select class="finput banking-input" id="sel-metric"></select>
        </div>

        <div class="field" id="field-quarter">
          <span class="flabel">Quarter</span>
          <div class="slider-wrap">
            <input type="range" id="quarter-slider" min="0" max="0" value="0" />
            <div id="quarter-label" class="slider-val">&mdash;</div>
          </div>
        </div>

        <div style="height:1px;background:#e8e5e0;margin:10px 0"></div>

        <div class="field">
          <span class="flabel">State</span>
          <select class="finput banking-input" id="sel-state">
            <option value="">All NE States</option>
            <option value="ASSAM">Assam</option>
            <option value="MEGHALAYA">Meghalaya</option>
            <option value="MANIPUR">Manipur</option>
            <option value="ARUNACHAL PRADESH">Arunachal Pradesh</option>
            <option value="MIZORAM">Mizoram</option>
            <option value="TRIPURA">Tripura</option>
            <option value="NAGALAND">Nagaland</option>
            <option value="SIKKIM">Sikkim</option>
          </select>
        </div>

        <div id="stats-banking">Select Banking Access to view FI data</div>
        <button id="btn-reset-banking">&#8634; Reset</button>
      </div>
    </div>
  </div>

  <button id="btn-back">&larr; Back to map</button>

  <!-- Dot legend (capital points view) -->
  <div id="legend">
    <div class="lr"><div class="ldot" style="background:#b8603e"></div>CDSL service centre</div>
    <div class="lr"><div class="ldot" style="background:#3d7a8e"></div>NSDL service centre</div>
    <div class="lr"><div class="ldot" style="background:#5a7a3a"></div>MFD individual</div>
    <div class="lr"><div class="ldot" style="background:#8b6914"></div>MFD corporate</div>
  </div>

  <!-- Capital choropleth legend -->
  <div id="choro-legend-capital">
    <div style="font-size:8px;letter-spacing:0.1em;text-transform:uppercase;color:#aaa09a;margin-bottom:4px">Total access points per district</div>
    <div class="choro-scale">
      <div class="choro-swatch" style="background:#f7f4ef"></div>
      <div class="choro-swatch" style="background:#e8d5b7"></div>
      <div class="choro-swatch" style="background:#d4a96a"></div>
      <div class="choro-swatch" style="background:#b8603e"></div>
      <div class="choro-swatch" style="background:#7a2010"></div>
    </div>
    <div class="choro-labels"><span>0</span><span>10</span><span>100</span><span>1k</span><span>10k+</span></div>
    <div style="display:flex;align-items:center;gap:5px;margin-top:6px;padding-top:5px;border-top:1px solid #e8e5e0">
      <div style="width:12px;height:12px;background:#e8e4dc;border:1px solid #ccc8c0;flex-shrink:0"></div>
      <span style="font-size:8px;color:#aaa09a;letter-spacing:0.04em">No coverage</span>
    </div>
  </div>

  <!-- Banking choropleth legend (dynamic) -->
  <div id="choro-legend-banking" style="display:none">
    <div id="legend-title" style="font-size:8px;letter-spacing:0.1em;text-transform:uppercase;color:#aaa09a;margin-bottom:4px">Overall CD Ratio</div>
    <div class="choro-scale" id="legend-scale"></div>
    <div class="choro-labels" id="legend-labels"></div>
    <div style="display:flex;align-items:center;gap:5px;margin-top:6px;padding-top:5px;border-top:1px solid #e8e5e0">
      <div style="width:12px;height:12px;background:#e8e4dc;border:1px solid #ccc8c0;flex-shrink:0"></div>
      <span style="font-size:8px;color:#aaa09a;letter-spacing:0.04em">No data</span>
    </div>
  </div>

  <div id="wm">Project FINER</div>
  <div id="dl-link"><a href={`${base}capital-markets/data-download`}>&darr; Download Data</a></div>

  <script is:inline define:vars={{ base }}>
    window.__FINER_BASE = base;
  </script>

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
  <script is:inline>
    // ══════════════════════════════════════════
    // Section 1 — Shared
    // ══════════════════════════════════════════
    var _B = window.__FINER_BASE;
    var CDSL_URL   = _B + 'DPSCs/cdsl_dp_centres.json';
    var NSDL_URL   = _B + 'DPSCs/nsdl_dp_centres.json';
    var COORDS_URL = _B + 'pincode_coords.json';
    var MFDI_URL   = _B + 'MFDs/mfd_individual.json';
    var MFDC_URL   = _B + 'MFDs/mfd_corporate.json';
    var DIST_URL   = _B + 'data/district_boundaries.geojson';

    var INDIA_BOUNDS = L.latLngBounds(L.latLng(6.5,68.0), L.latLng(37.5,97.5));
    var NE_BOUNDS    = L.latLngBounds(L.latLng(21.5, 88.0), L.latLng(29.5, 97.5));
    var NE_CODES     = ['AS','ML','MN','MZ','NL','TR','AR','SK'];
    var NE_STATES    = ['ASSAM','MEGHALAYA','MANIPUR','MIZORAM','NAGALAND','TRIPURA','ARUNACHAL PRADESH','SIKKIM'];
    var STATE_SLUGS  = {
      'ASSAM': 'assam', 'MEGHALAYA': 'meghalaya', 'MANIPUR': 'manipur',
      'MIZORAM': 'mizoram', 'NAGALAND': 'nagaland', 'TRIPURA': 'tripura',
      'ARUNACHAL PRADESH': 'arunachal-pradesh', 'SIKKIM': 'sikkim',
    };

    // Map init — single map, center India at zoom 5
    var map = L.map('map',{center:[22.5,82.5],zoom:5,minZoom:4,maxZoom:18,maxBounds:INDIA_BOUNDS,maxBoundsViscosity:1.0,attributionControl:false,zoomControl:false});
    L.control.zoom({position:'topright'}).addTo(map);

    // White canvas tile
    (new (L.GridLayer.extend({createTile:function(){var t=document.createElement('canvas');t.width=t.height=256;var c=t.getContext('2d');c.fillStyle='#fff';c.fillRect(0,0,256,256);return t;}}))).addTo(map);

    // India outline
    fetch('https://raw.githubusercontent.com/datameet/maps/master/Country/india-land-simplified.geojson')
      .then(function(r){return r.json();}).then(function(geo){
        L.geoJSON(geo,{style:{fillColor:'#faf9f7',fillOpacity:1,color:'#ccc8c0',weight:1.2,opacity:0.6},interactive:false}).addTo(map);
      }).catch(function(){});

    // State name → code mapping
    var STATE_NAME_CODE={'ANDHRA PRADESH':'AP','ARUNACHAL PRADESH':'AR','ASSAM':'AS','BIHAR':'BR','CHHATTISGARH':'CT','GOA':'GA','GUJARAT':'GJ','HARYANA':'HR','HIMACHAL PRADESH':'HP','JHARKHAND':'JH','KARNATAKA':'KA','KERALA':'KL','MADHYA PRADESH':'MP','MAHARASHTRA':'MH','MANIPUR':'MN','MEGHALAYA':'ML','MIZORAM':'MZ','NAGALAND':'NL','ODISHA':'OR','PUNJAB':'PB','RAJASTHAN':'RJ','SIKKIM':'SK','TAMIL NADU':'TN','TELANGANA':'TS','TRIPURA':'TR','UTTAR PRADESH':'UP','UTTARAKHAND':'UK','WEST BENGAL':'WB','JAMMU AND KASHMIR':'JK','LADAKH':'JK','DELHI':'DL','CHANDIGARH':'CH','PUDUCHERRY':'PY','ANDAMAN & NICOBAR':'AN','LAKSHADWEEP':'LD','DADRA & NAGAR HAVELI & DAMAN & DIU':'DN'};
    function stateCodeMatch(stateName,code){return STATE_NAME_CODE[stateName?.toUpperCase()]===code;}

    // Shared variables
    var distGeoJSON = null;
    var choroLayer = null;
    var distLabelsLayer = null;
    var distCentroids = [];
    var currentMode = 'capital';

    // ══════════════════════════════════════════
    // Section 2 — Capital Markets mode
    // ══════════════════════════════════════════
    function makeCluster(fill,text){
      return L.markerClusterGroup({chunkedLoading:true,maxClusterRadius:45,showCoverageOnHover:false,
        iconCreateFunction:function(c){var n=c.getChildCount(),s=n>1000?46:n>100?36:28;
          return L.divIcon({html:'<div style="background:'+fill+';width:'+s+'px;height:'+s+'px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:'+text+';font-weight:700;font-size:'+(s>36?11:9)+'px;font-family:Georgia,serif;border:2px solid rgba(255,255,255,0.85)">'+( n>999?'1k+':n)+'</div>',className:'',iconSize:[s,s]});}
      }).addTo(map);
    }
    var clusterCDSL = makeCluster('#b8603e','#fff');
    var clusterNSDL = makeCluster('#3d7a8e','#fff');
    var clusterMFDI = makeCluster('#5a7a3a','#fff');
    var clusterMFDC = makeCluster('#8b6914','#fff');

    function makeIcon(color){return L.divIcon({html:'<div style="width:7px;height:7px;border-radius:50%;background:'+color+';border:1.5px solid rgba(255,255,255,0.9)"></div>',className:'',iconSize:[7,7],iconAnchor:[3,3]});}
    var iconCDSL=makeIcon('#b8603e'), iconNSDL=makeIcon('#3d7a8e'), iconMFDI=makeIcon('#5a7a3a'), iconMFDC=makeIcon('#8b6914');

    var cdslData=[],nsdlData=[],mfdiData=[],mfdcData=[],coordsMap={};
    var showCDSL=true,showNSDL=true,showMFDI=true,showMFDC=true,dpQuery='',capitalStateFilter='';
    var currentView='choro';
    var drilldownActive=false;
    var markerCache={cdsl:[],nsdl:[],mfdi:[],mfdc:[]};

    function choroColor(total){if(total===0)return'#e8e4dc';if(total<5)return'#f0e6d2';if(total<20)return'#e8d5b7';if(total<100)return'#d4a96a';if(total<500)return'#b8603e';return'#7a2010';}
    function getFilteredTotal(props){var t=0;if(showCDSL)t+=props.cdsl_cnt||0;if(showNSDL)t+=props.nsdl_cnt||0;if(showMFDI)t+=props.mfdi_cnt||0;if(showMFDC)t+=props.mfdc_cnt||0;return t;}
    function choroStyle(feature){var total=getFilteredTotal(feature.properties);return{fillColor:choroColor(total),fillOpacity:total===0?0.6:0.78,color:'#c8bfb0',weight:0.5,opacity:0.7};}

    function buildChoropleth_capital(){
      if(choroLayer){map.removeLayer(choroLayer);choroLayer=null;}
      if(!distGeoJSON||currentView!=='choro')return;
      var sf=capitalStateFilter;
      var filtered={type:distGeoJSON.type,features:distGeoJSON.features.filter(function(f){if(!sf)return true;if(sf==='_NE')return NE_CODES.some(function(code){return stateCodeMatch(f.properties.STATE_UT,code);});return stateCodeMatch(f.properties.STATE_UT,sf);})};
      choroLayer=L.geoJSON(filtered,{style:choroStyle,onEachFeature:function(feature,layer){var p=feature.properties;var total=getFilteredTotal(p);layer.on({mouseover:function(e){e.target.setStyle({weight:2,color:'#6b4c2a',fillOpacity:0.9});e.target.bindTooltip('<div class="dist-tooltip"><strong>'+p.DISTRICT+'</strong> <span style="font-size:10px;color:#888078">'+p.STATE_UT+'</span><br>Total: <strong>'+total.toLocaleString()+'</strong><br><span style="color:#b8603e">CDSL '+(showCDSL?p.cdsl_cnt:'-')+'</span> · <span style="color:#3d7a8e">NSDL '+(showNSDL?p.nsdl_cnt:'-')+'</span> · <span style="color:#5a7a3a">MFD-I '+(showMFDI?p.mfdi_cnt:'-')+'</span> · <span style="color:#8b6914">MFD-C '+(showMFDC?p.mfdc_cnt:'-')+'</span></div>',{sticky:true,className:'',offset:[10,0]}).openTooltip();},mouseout:function(e){choroLayer.resetStyle(e.target);e.target.closeTooltip();},click:function(e){drillInto(feature,layer);}});}}).addTo(map);
    }

    // Capital district labels
    var capitalCentroids=[];
    function buildDistrictLabels_capital(){if(!distGeoJSON)return;capitalCentroids=[];distGeoJSON.features.forEach(function(f){try{var tmp=L.geoJSON(f);var b=tmp.getBounds();capitalCentroids.push({center:b.getCenter(),name:f.properties.DISTRICT,bounds:b});}catch(e){}});}
    function updateLabelVisibility_capital(){if(currentMode!=='capital')return;if(distLabelsLayer){map.removeLayer(distLabelsLayer);distLabelsLayer=null;}var z=map.getZoom();if(z<8||(currentView!=='choro'&&!drilldownActive))return;var viewBounds=map.getBounds();distLabelsLayer=L.layerGroup();var placed=[];capitalCentroids.forEach(function(d){if(!viewBounds.intersects(d.bounds))return;var px=map.latLngToContainerPoint(d.center);var tooClose=placed.some(function(p){return Math.abs(px.x-p.x)<120&&Math.abs(px.y-p.y)<30;});if(tooClose)return;placed.push(px);distLabelsLayer.addLayer(L.marker(d.center,{icon:L.divIcon({className:'dist-label',html:d.name,iconSize:[0,0],iconAnchor:[0,0]}),interactive:false}));});distLabelsLayer.addTo(map);}

    function drillInto(feature,layer){var p=feature.properties;drilldownActive=true;document.getElementById('btn-back').style.display='block';document.getElementById('legend').style.display='block';var stateCode=STATE_NAME_CODE[p.STATE_UT?.toUpperCase()];if(stateCode){capitalStateFilter=stateCode;document.getElementById('state-select').value=stateCode;}map.getContainer().classList.add('clusters-hidden');map.getContainer().classList.remove('clusters-visible');[clusterCDSL,clusterNSDL,clusterMFDI,clusterMFDC].forEach(function(c){if(!c._map)c.addTo(map);});renderMarkers();var total=getFilteredTotal(p);document.getElementById('stats-capital').innerHTML='<strong>'+p.DISTRICT+'</strong><br><span style="font-size:9px;color:#888078">'+p.STATE_UT+'</span><br>'+total.toLocaleString()+' access points';map.flyToBounds(layer.getBounds(),{padding:[40,40],maxZoom:12,duration:1.0});map.once('moveend',function(){map.getContainer().classList.remove('clusters-hidden');map.getContainer().classList.add('clusters-visible');});}

    function exitDrilldown(){drilldownActive=false;document.getElementById('btn-back').style.display='none';map.getContainer().classList.remove('clusters-visible');map.getContainer().classList.add('clusters-hidden');setTimeout(function(){if(currentView==='choro'){[clusterCDSL,clusterNSDL,clusterMFDI,clusterMFDC].forEach(function(c){if(c._map)map.removeLayer(c);});document.getElementById('legend').style.display='none';}map.getContainer().classList.remove('clusters-hidden');capitalStateFilter='';document.getElementById('state-select').value='';map.flyToBounds(INDIA_BOUNDS,{padding:[20,20],duration:1.0});renderMarkers();},400);}

    function setView(mode){currentView=mode;document.getElementById('vbtn-choro').className='view-btn'+(mode==='choro'?' active':'');document.getElementById('vbtn-dots').className='view-btn'+(mode==='dots'?' active':'');document.getElementById('legend').style.display=mode==='dots'?'block':'none';document.getElementById('choro-legend-capital').style.display=mode==='choro'?'block':'none';if(mode==='choro'){[clusterCDSL,clusterNSDL,clusterMFDI,clusterMFDC].forEach(function(c){if(c._map)map.removeLayer(c);});buildChoropleth_capital();}else{if(choroLayer){map.removeLayer(choroLayer);choroLayer=null;}[clusterCDSL,clusterNSDL,clusterMFDI,clusterMFDC].forEach(function(c){if(!c._map)c.addTo(map);});renderMarkers();}}

    function buildMarkersOnce(data,icon,popupFn){return data.map(function(c){var ll=coordsMap[c.p];if(!ll)return null;var m=L.marker([ll[0]+(Math.random()-0.5)*0.002,ll[1]+(Math.random()-0.5)*0.002],{icon:icon});m.on('click',function(){if(!this._pb){this.bindPopup(popupFn(c),{maxWidth:260}).openPopup();this._pb=true;}});m._data=c;return m;}).filter(Boolean);}

    function buildPopup(c,dep){var email=c.e?'<a href="mailto:'+c.e+'">'+c.e+'</a>':'—';var type=c.t?'<div style="font-size:9px;color:#888078;font-style:italic;margin-bottom:4px">'+c.t+'</div>':'';return'<div class="pname">'+c.n+'</div><span class="pbadge '+dep+'">'+dep.toUpperCase()+'</span>'+type+'<div class="paddr">'+c.a.slice(0,140)+'</div><div class="pmeta">✉ '+email+'<br>Pin '+c.p+'</div>';}
    function buildMFDPopup(c,type){var cls=type==='Corporate'?'mfdc':'mfdi';return'<div class="pname">'+c.n+'</div><span class="pbadge '+cls+'">MFD '+type+'</span><div style="font-size:9px;color:#888078;margin-bottom:4px">'+(c.c||'')+'</div><div class="pmeta">ARN: '+c.arn+'<br>Pin: '+c.p+'</div>';}

    // Load capital markets data
    setCapitalStatus('Fetching data…');
    Promise.all([fetch(CDSL_URL).then(function(r){return r.json();}),fetch(NSDL_URL).then(function(r){return r.json();}),fetch(COORDS_URL).then(function(r){return r.json();}),fetch(MFDI_URL).then(function(r){return r.json();}),fetch(MFDC_URL).then(function(r){return r.json();}),fetch(DIST_URL).then(function(r){return r.json();})]).then(function(results){
      cdslData=results[0];nsdlData=results[1];coordsMap=results[2];mfdiData=results[3];mfdcData=results[4];distGeoJSON=results[5];
      setCapitalStatus('Building markers…');
      markerCache.cdsl=buildMarkersOnce(cdslData,iconCDSL,function(c){return buildPopup(c,'cdsl');});
      markerCache.nsdl=buildMarkersOnce(nsdlData,iconNSDL,function(c){return buildPopup(c,'nsdl');});
      markerCache.mfdi=buildMarkersOnce(mfdiData,iconMFDI,function(c){return buildMFDPopup(c,'Individual');});
      markerCache.mfdc=buildMarkersOnce(mfdcData,iconMFDC,function(c){return buildMFDPopup(c,'Corporate');});
      clusterCDSL.addLayers(markerCache.cdsl);clusterNSDL.addLayers(markerCache.nsdl);clusterMFDI.addLayers(markerCache.mfdi);clusterMFDC.addLayers(markerCache.mfdc);
      [clusterCDSL,clusterNSDL,clusterMFDI,clusterMFDC].forEach(function(c){map.removeLayer(c);});
      buildStateDropdown([].concat(cdslData,nsdlData,mfdiData,mfdcData));
      buildChoropleth_capital();
      buildDistrictLabels_capital();
      updateLabelVisibility_capital();
      updateStats_capital();

      // Check URL param for auto-switch
      var params = new URLSearchParams(window.location.search);
      if (params.get('mode') === 'banking') {
        switchMode('banking');
      }
    }).catch(function(err){setCapitalStatus('Error: '+err.message);});

    var renderTimer=null;
    function renderMarkers(){clearTimeout(renderTimer);renderTimer=setTimeout(_doRender,80);}
    function _doRender(){if(currentView==='choro'&&!drilldownActive){buildChoropleth_capital();updateStats_capital();return;}if(currentView==='choro'&&drilldownActive){buildChoropleth_capital();}var dq=dpQuery,sf=capitalStateFilter;function passes(c){if(dq&&!c.n.toLowerCase().includes(dq))return false;if(sf==='_NE')return NE_CODES.includes(c.st);if(sf&&sf!=='_SEP')return c.st===sf;return true;}[{cache:markerCache.cdsl,cluster:clusterCDSL,show:showCDSL},{cache:markerCache.nsdl,cluster:clusterNSDL,show:showNSDL},{cache:markerCache.mfdi,cluster:clusterMFDI,show:showMFDI},{cache:markerCache.mfdc,cluster:clusterMFDC,show:showMFDC}].forEach(function(o){o.cluster.clearLayers();if(!o.show)return;o.cluster.addLayers(o.cache.filter(function(m){return passes(m._data);}));});updateStats_capital();}

