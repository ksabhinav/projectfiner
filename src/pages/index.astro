---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Project FINER — Financial Inclusion in the North East Region">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />

  <div id="map"></div>

  <div id="panel">
    <div id="panel-head">
      <h1>Project FINER</h1>
      <p class="panel-sub">Financial Inclusion in the North East Region</p>
    </div>

    <nav class="panel-nav">
      <a href={`${base}fi-indicators`} class="nav-pill">FI Indicators</a>
      <a href={`${base}slbc-data`} class="nav-pill">SLBC Data</a>
      <a href={`${base}capital-markets/data-download`} class="nav-pill">Downloads</a>
      <a href={`${base}analysis`} class="nav-pill">Analysis</a>
    </nav>

    <div id="panel-body">
      <div class="view-row" style="margin-bottom:10px">
        <button class="view-btn active" id="vbtn-choro">Access Map</button>
        <button class="view-btn" id="vbtn-dots">Points</button>
      </div>

      <div class="grp open dpsc-active" id="grp-dpsc">
        <div class="grp-master" id="grp-dpsc-master">
          <div class="master-dot"></div>
          <span class="grp-title">DP Service Centres</span>
          <span class="grp-arrow">&#9662;</span>
        </div>
        <div class="grp-subs">
          <button class="sub-btn on-cdsl" id="tog-cdsl"><span class="sub-dot"></span>CDSL</button>
          <button class="sub-btn on-nsdl" id="tog-nsdl"><span class="sub-dot"></span>NSDL</button>
        </div>
      </div>
      <div class="grp open mfd-active" id="grp-mfd">
        <div class="grp-master" id="grp-mfd-master">
          <div class="master-dot"></div>
          <span class="grp-title">MF Distributors</span>
          <span class="grp-arrow">&#9662;</span>
        </div>
        <div class="grp-subs">
          <button class="sub-btn on-mfdi" id="tog-mfdi"><span class="sub-dot"></span>Individual</button>
          <button class="sub-btn on-mfdc" id="tog-mfdc"><span class="sub-dot"></span>Corporate</button>
        </div>
      </div>

      <div style="height:1px;background:#e8e5e0;margin:10px 0"></div>

      <div class="field">
        <span class="flabel">Search</span>
        <input class="finput" type="text" id="search-dp" placeholder="Search by name…" />
      </div>
      <div class="field" style="position:relative">
        <span class="flabel">Go to city</span>
        <input class="finput" type="text" id="search-loc" placeholder="e.g. Shillong, Tura…" autocomplete="off" />
        <div id="loc-sugg"></div>
      </div>
      <div class="field">
        <span class="flabel">State</span>
        <select class="finput" id="state-select">
          <option value="">All India</option>
        </select>
      </div>

      <div id="stats">Loading…</div>
      <button id="btn-reset">&#8634; Reset</button>
    </div>
  </div>

  <button id="btn-back">&larr; Back to map</button>

  <div id="legend">
    <div class="lr"><div class="ldot" style="background:#b8603e"></div>CDSL service centre</div>
    <div class="lr"><div class="ldot" style="background:#3d7a8e"></div>NSDL service centre</div>
    <div class="lr"><div class="ldot" style="background:#5a7a3a"></div>MFD individual</div>
    <div class="lr"><div class="ldot" style="background:#8b6914"></div>MFD corporate</div>
  </div>

  <div id="choro-legend">
    <div style="font-size:8px;letter-spacing:0.1em;text-transform:uppercase;color:#aaa09a;margin-bottom:4px">Total access points per district</div>
    <div class="choro-scale">
      <div class="choro-swatch" style="background:#f7f4ef"></div>
      <div class="choro-swatch" style="background:#e8d5b7"></div>
      <div class="choro-swatch" style="background:#d4a96a"></div>
      <div class="choro-swatch" style="background:#b8603e"></div>
      <div class="choro-swatch" style="background:#7a2010"></div>
    </div>
    <div class="choro-labels"><span>0</span><span>10</span><span>100</span><span>1k</span><span>10k+</span></div>
    <div style="display:flex;align-items:center;gap:5px;margin-top:6px;padding-top:5px;border-top:1px solid #e8e5e0">
      <div style="width:12px;height:12px;background:#e8e4dc;border:1px solid #ccc8c0;flex-shrink:0"></div>
      <span style="font-size:8px;color:#aaa09a;letter-spacing:0.04em">No coverage</span>
    </div>
  </div>

  <div id="wm">Project FINER</div>
  <div id="dl-link"><a href={`${base}capital-markets/data-download`}>&darr; Download Data</a></div>

  <script is:inline define:vars={{ base }}>
    window.__FINER_BASE = base;
  </script>

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
  <script is:inline>
    const _B = window.__FINER_BASE;
    const CDSL_URL   = _B + 'DPSCs/cdsl_dp_centres.json';
    const NSDL_URL   = _B + 'DPSCs/nsdl_dp_centres.json';
    const COORDS_URL = _B + 'pincode_coords.json';
    const MFDI_URL   = _B + 'MFDs/mfd_individual.json';
    const MFDC_URL   = _B + 'MFDs/mfd_corporate.json';
    const DIST_URL   = _B + 'data/district_boundaries.geojson';

    const INDIA_BOUNDS = L.latLngBounds(L.latLng(6.5,68.0), L.latLng(37.5,97.5));
    const NE_CODES = ['AS','ML','MN','MZ','NL','TR','AR','SK'];

    const map = L.map('map',{center:[22.5,82.5],zoom:5,minZoom:4,maxZoom:18,maxBounds:INDIA_BOUNDS,maxBoundsViscosity:1.0,attributionControl:false,zoomControl:false});
    L.control.zoom({position:'topright'}).addTo(map);

    (new (L.GridLayer.extend({createTile:function(){const t=document.createElement('canvas');t.width=t.height=256;const c=t.getContext('2d');c.fillStyle='#fff';c.fillRect(0,0,256,256);return t;}}))).addTo(map);

    fetch('https://raw.githubusercontent.com/datameet/maps/master/Country/india-land-simplified.geojson')
      .then(r=>r.json()).then(geo=>{
        L.geoJSON(geo,{style:{fillColor:'#faf9f7',fillOpacity:1,color:'#ccc8c0',weight:1.2,opacity:0.6},interactive:false}).addTo(map);
      }).catch(()=>{});

    function makeCluster(fill,text){
      return L.markerClusterGroup({chunkedLoading:true,maxClusterRadius:45,showCoverageOnHover:false,
        iconCreateFunction:c=>{const n=c.getChildCount(),s=n>1000?46:n>100?36:28;
          return L.divIcon({html:'<div style="background:'+fill+';width:'+s+'px;height:'+s+'px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:'+text+';font-weight:700;font-size:'+(s>36?11:9)+'px;font-family:Georgia,serif;border:2px solid rgba(255,255,255,0.85)">'+( n>999?'1k+':n)+'</div>',className:'',iconSize:[s,s]});}
      }).addTo(map);
    }
    const clusterCDSL = makeCluster('#b8603e','#fff');
    const clusterNSDL = makeCluster('#3d7a8e','#fff');
    const clusterMFDI = makeCluster('#5a7a3a','#fff');
    const clusterMFDC = makeCluster('#8b6914','#fff');

    function makeIcon(color){return L.divIcon({html:'<div style="width:7px;height:7px;border-radius:50%;background:'+color+';border:1.5px solid rgba(255,255,255,0.9)"></div>',className:'',iconSize:[7,7],iconAnchor:[3,3]});}
    const iconCDSL=makeIcon('#b8603e'), iconNSDL=makeIcon('#3d7a8e'), iconMFDI=makeIcon('#5a7a3a'), iconMFDC=makeIcon('#8b6914');

    let cdslData=[],nsdlData=[],mfdiData=[],mfdcData=[],coordsMap={},distGeoJSON=null;
    let showCDSL=true,showNSDL=true,showMFDI=true,showMFDC=true,dpQuery='',stateFilter='';
    let currentView='choro';
    let choroLayer=null, drilldownActive=false, distLabelsLayer=null;
    const markerCache={cdsl:[],nsdl:[],mfdi:[],mfdc:[]};

    function choroColor(total){if(total===0)return'#e8e4dc';if(total<5)return'#f0e6d2';if(total<20)return'#e8d5b7';if(total<100)return'#d4a96a';if(total<500)return'#b8603e';return'#7a2010';}
    function getFilteredTotal(props){let t=0;if(showCDSL)t+=props.cdsl_cnt||0;if(showNSDL)t+=props.nsdl_cnt||0;if(showMFDI)t+=props.mfdi_cnt||0;if(showMFDC)t+=props.mfdc_cnt||0;return t;}
    function choroStyle(feature){const total=getFilteredTotal(feature.properties);return{fillColor:choroColor(total),fillOpacity:total===0?0.6:0.78,color:'#c8bfb0',weight:0.5,opacity:0.7};}

    const STATE_NAME_CODE={'ANDHRA PRADESH':'AP','ARUNACHAL PRADESH':'AR','ASSAM':'AS','BIHAR':'BR','CHHATTISGARH':'CT','GOA':'GA','GUJARAT':'GJ','HARYANA':'HR','HIMACHAL PRADESH':'HP','JHARKHAND':'JH','KARNATAKA':'KA','KERALA':'KL','MADHYA PRADESH':'MP','MAHARASHTRA':'MH','MANIPUR':'MN','MEGHALAYA':'ML','MIZORAM':'MZ','NAGALAND':'NL','ODISHA':'OR','PUNJAB':'PB','RAJASTHAN':'RJ','SIKKIM':'SK','TAMIL NADU':'TN','TELANGANA':'TS','TRIPURA':'TR','UTTAR PRADESH':'UP','UTTARAKHAND':'UK','WEST BENGAL':'WB','JAMMU AND KASHMIR':'JK','LADAKH':'JK','DELHI':'DL','CHANDIGARH':'CH','PUDUCHERRY':'PY','ANDAMAN & NICOBAR':'AN','LAKSHADWEEP':'LD','DADRA & NAGAR HAVELI & DAMAN & DIU':'DN'};
    function stateCodeMatch(stateName,code){return STATE_NAME_CODE[stateName?.toUpperCase()]===code;}

    function buildChoropleth(){
      if(choroLayer){map.removeLayer(choroLayer);choroLayer=null;}
      if(!distGeoJSON||currentView!=='choro')return;
      const sf=stateFilter;
      const filtered={...distGeoJSON,features:distGeoJSON.features.filter(f=>{if(!sf)return true;if(sf==='_NE')return NE_CODES.some(code=>stateCodeMatch(f.properties.STATE_UT,code));return stateCodeMatch(f.properties.STATE_UT,sf);})};
      choroLayer=L.geoJSON(filtered,{style:choroStyle,onEachFeature:(feature,layer)=>{const p=feature.properties;const total=getFilteredTotal(p);layer.on({mouseover:e=>{e.target.setStyle({weight:2,color:'#6b4c2a',fillOpacity:0.9});e.target.bindTooltip('<div class="dist-tooltip"><strong>'+p.DISTRICT+'</strong> <span style="font-size:10px;color:#888078">'+p.STATE_UT+'</span><br>Total: <strong>'+total.toLocaleString()+'</strong><br><span style="color:#b8603e">CDSL '+(showCDSL?p.cdsl_cnt:'-')+'</span> · <span style="color:#3d7a8e">NSDL '+(showNSDL?p.nsdl_cnt:'-')+'</span> · <span style="color:#5a7a3a">MFD-I '+(showMFDI?p.mfdi_cnt:'-')+'</span> · <span style="color:#8b6914">MFD-C '+(showMFDC?p.mfdc_cnt:'-')+'</span></div>',{sticky:true,className:'',offset:[10,0]}).openTooltip();},mouseout:e=>{choroLayer.resetStyle(e.target);e.target.closeTooltip();},click:e=>drillInto(feature,layer)});}}).addTo(map);
    }

    let distCentroids=[];
    function buildDistrictLabels(){if(!distGeoJSON)return;distCentroids=[];distGeoJSON.features.forEach(f=>{try{const tmp=L.geoJSON(f);const b=tmp.getBounds();distCentroids.push({center:b.getCenter(),name:f.properties.DISTRICT,bounds:b});}catch(e){}});}
    function updateLabelVisibility(){if(distLabelsLayer){map.removeLayer(distLabelsLayer);distLabelsLayer=null;}const z=map.getZoom();if(z<8||(currentView!=='choro'&&!drilldownActive))return;const viewBounds=map.getBounds();distLabelsLayer=L.layerGroup();const placed=[];distCentroids.forEach(d=>{if(!viewBounds.intersects(d.bounds))return;const px=map.latLngToContainerPoint(d.center);const tooClose=placed.some(p=>Math.abs(px.x-p.x)<120&&Math.abs(px.y-p.y)<30);if(tooClose)return;placed.push(px);distLabelsLayer.addLayer(L.marker(d.center,{icon:L.divIcon({className:'dist-label',html:d.name,iconSize:[0,0],iconAnchor:[0,0]}),interactive:false}));});distLabelsLayer.addTo(map);}
    map.on('zoomend',updateLabelVisibility);map.on('moveend',updateLabelVisibility);
    map.on('zoomend',function(){if(drilldownActive&&map.getZoom()<=8)exitDrilldown();});

    function drillInto(feature,layer){const p=feature.properties;drilldownActive=true;document.getElementById('btn-back').style.display='block';document.getElementById('legend').style.display='block';const stateCode=STATE_NAME_CODE[p.STATE_UT?.toUpperCase()];if(stateCode){stateFilter=stateCode;document.getElementById('state-select').value=stateCode;}map.getContainer().classList.add('clusters-hidden');map.getContainer().classList.remove('clusters-visible');[clusterCDSL,clusterNSDL,clusterMFDI,clusterMFDC].forEach(c=>{if(!c._map)c.addTo(map);});renderMarkers();const total=getFilteredTotal(p);document.getElementById('stats').innerHTML='<strong>'+p.DISTRICT+'</strong><br><span style="font-size:9px;color:#888078">'+p.STATE_UT+'</span><br>'+total.toLocaleString()+' access points';map.flyToBounds(layer.getBounds(),{padding:[40,40],maxZoom:12,duration:1.0});map.once('moveend',function(){map.getContainer().classList.remove('clusters-hidden');map.getContainer().classList.add('clusters-visible');});}

    function exitDrilldown(){drilldownActive=false;document.getElementById('btn-back').style.display='none';map.getContainer().classList.remove('clusters-visible');map.getContainer().classList.add('clusters-hidden');setTimeout(function(){if(currentView==='choro'){[clusterCDSL,clusterNSDL,clusterMFDI,clusterMFDC].forEach(c=>{if(c._map)map.removeLayer(c);});document.getElementById('legend').style.display='none';}map.getContainer().classList.remove('clusters-hidden');stateFilter='';document.getElementById('state-select').value='';map.flyToBounds(INDIA_BOUNDS,{padding:[20,20],duration:1.0});renderMarkers();},400);}

    function setView(mode){currentView=mode;document.getElementById('vbtn-choro').className='view-btn'+(mode==='choro'?' active':'');document.getElementById('vbtn-dots').className='view-btn'+(mode==='dots'?' active':'');document.getElementById('legend').style.display=mode==='dots'?'block':'none';document.getElementById('choro-legend').style.display=mode==='choro'?'block':'none';if(mode==='choro'){[clusterCDSL,clusterNSDL,clusterMFDI,clusterMFDC].forEach(c=>{if(c._map)map.removeLayer(c);});buildChoropleth();}else{if(choroLayer){map.removeLayer(choroLayer);choroLayer=null;}[clusterCDSL,clusterNSDL,clusterMFDI,clusterMFDC].forEach(c=>{if(!c._map)c.addTo(map);});renderMarkers();}}

    function buildMarkersOnce(data,icon,popupFn){return data.map(c=>{const ll=coordsMap[c.p];if(!ll)return null;const m=L.marker([ll[0]+(Math.random()-0.5)*0.002,ll[1]+(Math.random()-0.5)*0.002],{icon});m.on('click',function(){if(!this._pb){this.bindPopup(popupFn(c),{maxWidth:260}).openPopup();this._pb=true;}});m._data=c;return m;}).filter(Boolean);}

    function buildPopup(c,dep){const email=c.e?'<a href="mailto:'+c.e+'">'+c.e+'</a>':'—';const type=c.t?'<div style="font-size:9px;color:#888078;font-style:italic;margin-bottom:4px">'+c.t+'</div>':'';return'<div class="pname">'+c.n+'</div><span class="pbadge '+dep+'">'+dep.toUpperCase()+'</span>'+type+'<div class="paddr">'+c.a.slice(0,140)+'</div><div class="pmeta">✉ '+email+'<br>Pin '+c.p+'</div>';}
    function buildMFDPopup(c,type){const cls=type==='Corporate'?'mfdc':'mfdi';return'<div class="pname">'+c.n+'</div><span class="pbadge '+cls+'">MFD '+type+'</span><div style="font-size:9px;color:#888078;margin-bottom:4px">'+(c.c||'')+'</div><div class="pmeta">ARN: '+c.arn+'<br>Pin: '+c.p+'</div>';}

    setStatus('Fetching data…');
    Promise.all([fetch(CDSL_URL).then(r=>r.json()),fetch(NSDL_URL).then(r=>r.json()),fetch(COORDS_URL).then(r=>r.json()),fetch(MFDI_URL).then(r=>r.json()),fetch(MFDC_URL).then(r=>r.json()),fetch(DIST_URL).then(r=>r.json())]).then(([cdsl,nsdl,coords,mfdi,mfdc,dist])=>{cdslData=cdsl;nsdlData=nsdl;coordsMap=coords;mfdiData=mfdi;mfdcData=mfdc;distGeoJSON=dist;setStatus('Building markers…');markerCache.cdsl=buildMarkersOnce(cdsl,iconCDSL,c=>buildPopup(c,'cdsl'));markerCache.nsdl=buildMarkersOnce(nsdl,iconNSDL,c=>buildPopup(c,'nsdl'));markerCache.mfdi=buildMarkersOnce(mfdi,iconMFDI,c=>buildMFDPopup(c,'Individual'));markerCache.mfdc=buildMarkersOnce(mfdc,iconMFDC,c=>buildMFDPopup(c,'Corporate'));clusterCDSL.addLayers(markerCache.cdsl);clusterNSDL.addLayers(markerCache.nsdl);clusterMFDI.addLayers(markerCache.mfdi);clusterMFDC.addLayers(markerCache.mfdc);[clusterCDSL,clusterNSDL,clusterMFDI,clusterMFDC].forEach(c=>map.removeLayer(c));buildStateDropdown([...cdsl,...nsdl,...mfdi,...mfdc]);buildChoropleth();buildDistrictLabels();updateLabelVisibility();updateStats();}).catch(err=>setStatus('Error: '+err.message));

    let renderTimer=null;
    function renderMarkers(){clearTimeout(renderTimer);renderTimer=setTimeout(_doRender,80);}
    function _doRender(){if(currentView==='choro'&&!drilldownActive){buildChoropleth();updateStats();return;}if(currentView==='choro'&&drilldownActive){buildChoropleth();}const dq=dpQuery,sf=stateFilter;function passes(c){if(dq&&!c.n.toLowerCase().includes(dq))return false;if(sf==='_NE')return NE_CODES.includes(c.st);if(sf&&sf!=='_SEP')return c.st===sf;return true;}[{cache:markerCache.cdsl,cluster:clusterCDSL,show:showCDSL},{cache:markerCache.nsdl,cluster:clusterNSDL,show:showNSDL},{cache:markerCache.mfdi,cluster:clusterMFDI,show:showMFDI},{cache:markerCache.mfdc,cluster:clusterMFDC,show:showMFDC}].forEach(({cache,cluster,show})=>{cluster.clearLayers();if(!show)return;cluster.addLayers(cache.filter(m=>passes(m._data)));});updateStats();}

    function updateStats(){const dq=dpQuery,sf=stateFilter;function passes(c){if(dq&&!c.n.toLowerCase().includes(dq))return false;if(sf==='_NE')return NE_CODES.includes(c.st);if(sf&&sf!=='_SEP')return c.st===sf;return true;}if(drilldownActive)return;const pC=showCDSL?markerCache.cdsl.filter(m=>passes(m._data)).length:0;const pN=showNSDL?markerCache.nsdl.filter(m=>passes(m._data)).length:0;const pM=showMFDI?markerCache.mfdi.filter(m=>passes(m._data)).length:0;const pMC=showMFDC?markerCache.mfdc.filter(m=>passes(m._data)).length:0;document.getElementById('stats').innerHTML='Showing <strong>'+(pC+pN+pM+pMC).toLocaleString()+'</strong> total<br><span style="color:#b8603e">CDSL '+pC.toLocaleString()+'</span> · <span style="color:#3d7a8e">NSDL '+pN.toLocaleString()+'</span><br><span style="color:#5a7a3a">MFD-I '+pM.toLocaleString()+'</span> · <span style="color:#8b6914">MFD-C '+pMC.toLocaleString()+'</span>';const any=dpQuery||stateFilter||document.getElementById('search-loc').value.trim();document.getElementById('btn-reset').style.display=any?'block':'none';}

    function buildStateDropdown(all){const NAMES={AS:'Assam',ML:'Meghalaya',MN:'Manipur',MZ:'Mizoram',NL:'Nagaland',TR:'Tripura',AR:'Arunachal Pradesh',SK:'Sikkim',DL:'Delhi',MH:'Maharashtra',GJ:'Gujarat',KA:'Karnataka',TN:'Tamil Nadu',KL:'Kerala',AP:'Andhra Pradesh',TS:'Telangana',WB:'West Bengal',UP:'Uttar Pradesh',RJ:'Rajasthan',MP:'Madhya Pradesh',HR:'Haryana',PB:'Punjab',BR:'Bihar',JH:'Jharkhand',OR:'Odisha',HP:'Himachal Pradesh',UK:'Uttarakhand',GA:'Goa',CH:'Chandigarh',CT:'Chhattisgarh',JK:'J&K / Ladakh'};const counts={};all.forEach(c=>{if(c.st)counts[c.st]=(counts[c.st]||0)+1;});const sel=document.getElementById('state-select');const neOpt=document.createElement('option');neOpt.value='_NE';neOpt.textContent='── North East India';sel.appendChild(neOpt);NE_CODES.forEach(code=>{if(!counts[code])return;const o=document.createElement('option');o.value=code;o.textContent=(NAMES[code]||code)+' ('+counts[code].toLocaleString()+')';sel.appendChild(o);});const sep=document.createElement('option');sep.value='_SEP';sep.textContent='──────────────';sel.appendChild(sep);Object.entries(counts).filter(([k])=>!NE_CODES.includes(k)).sort((a,b)=>b[1]-a[1]).forEach(([code,cnt])=>{const o=document.createElement('option');o.value=code;o.textContent=(NAMES[code]||code)+' ('+cnt.toLocaleString()+')';sel.appendChild(o);});}

    // Event listeners
    document.getElementById('vbtn-choro').addEventListener('click',()=>setView('choro'));
    document.getElementById('vbtn-dots').addEventListener('click',()=>setView('dots'));
    document.getElementById('search-dp').addEventListener('input',e=>{dpQuery=e.target.value.trim().toLowerCase();renderMarkers();});
    document.getElementById('state-select').addEventListener('change',e=>{const val=e.target.value;if(val==='_SEP'){e.target.value=stateFilter;return;}stateFilter=val;renderMarkers();if(!val){map.flyToBounds(INDIA_BOUNDS,{padding:[20,20],duration:1.2});return;}const lats=[],lons=[];[...(showCDSL?markerCache.cdsl:[]),...(showNSDL?markerCache.nsdl:[]),...(showMFDI?markerCache.mfdi:[]),...(showMFDC?markerCache.mfdc:[])].forEach(m=>{const c=m._data;const match=val==='_NE'?NE_CODES.includes(c.st):c.st===val;if(!match)return;const ll=coordsMap[c.p];if(ll){lats.push(ll[0]);lons.push(ll[1]);}});if(!lats.length)return;map.flyToBounds([[Math.min(...lats)-0.3,Math.min(...lons)-0.3],[Math.max(...lats)+0.3,Math.max(...lons)+0.3]],{padding:[40,40],maxZoom:10,duration:1.2});});
    document.getElementById('btn-reset').addEventListener('click',()=>{dpQuery='';stateFilter='';drilldownActive=false;document.getElementById('search-dp').value='';document.getElementById('search-loc').value='';document.getElementById('state-select').value='';document.getElementById('btn-back').style.display='none';document.getElementById('loc-sugg').style.display='none';showCDSL=showNSDL=showMFDI=showMFDC=true;['cdsl','nsdl'].forEach(l=>{document.getElementById('tog-'+l).className='sub-btn on-'+l;});document.getElementById('tog-mfdi').className='sub-btn on-mfdi';document.getElementById('tog-mfdc').className='sub-btn on-mfdc';document.getElementById('grp-dpsc').className='grp open dpsc-active';document.getElementById('grp-mfd').className='grp open mfd-active';map.flyToBounds(INDIA_BOUNDS,{padding:[20,20],duration:1.2});setView('choro');});
    document.getElementById('btn-back').addEventListener('click',exitDrilldown);

    // Layer toggles
    document.getElementById('grp-dpsc-master').addEventListener('click',()=>{const el=document.getElementById('grp-dpsc');const isOpen=el.classList.contains('open');el.classList.toggle('open',!isOpen);showCDSL=showNSDL=!isOpen;el.classList.toggle('dpsc-active',!isOpen);['cdsl','nsdl'].forEach(l=>{document.getElementById('tog-'+l).className='sub-btn '+(!isOpen?'on-'+l:'off');});renderMarkers();});
    document.getElementById('grp-mfd-master').addEventListener('click',()=>{const el=document.getElementById('grp-mfd');const isOpen=el.classList.contains('open');el.classList.toggle('open',!isOpen);showMFDI=showMFDC=!isOpen;el.classList.toggle('mfd-active',!isOpen);document.getElementById('tog-mfdi').className='sub-btn '+(!isOpen?'on-mfdi':'off');document.getElementById('tog-mfdc').className='sub-btn '+(!isOpen?'on-mfdc':'off');renderMarkers();});
    ['cdsl','nsdl','mfdi','mfdc'].forEach(layer=>{document.getElementById('tog-'+layer).addEventListener('click',e=>{e.stopPropagation();const cls='on-'+layer;if(layer==='cdsl')showCDSL=!showCDSL;if(layer==='nsdl')showNSDL=!showNSDL;if(layer==='mfdi')showMFDI=!showMFDI;if(layer==='mfdc')showMFDC=!showMFDC;const isOn=layer==='cdsl'?showCDSL:layer==='nsdl'?showNSDL:layer==='mfdc'?showMFDC:showMFDI;document.getElementById('tog-'+layer).className='sub-btn '+(isOn?cls:'off');renderMarkers();});});

    // Location search
    let locTimer=null;const locInput=document.getElementById('search-loc');const locSugg=document.getElementById('loc-sugg');
    locInput.addEventListener('input',e=>{const v=e.target.value;clearTimeout(locTimer);if(v.length<2){locSugg.style.display='none';return;}locTimer=setTimeout(()=>{fetch('https://photon.komoot.io/api/?q='+encodeURIComponent(v+' India')+'&limit=6&lang=en').then(r=>r.json()).then(data=>{const fs=(data.features||[]).filter(f=>{const[lon,lat]=f.geometry.coordinates;return lon>=68&&lon<=97&&lat>=6&&lat<=38;}).slice(0,5);if(!fs.length){locSugg.style.display='none';return;}locSugg.innerHTML=fs.map(f=>{const p=f.properties,name=p.name||p.city||p.state||'';const sub=[p.city,p.state].filter(Boolean).join(', ');const[lon,lat]=f.geometry.coordinates;return'<div class="sugg-item" data-lat="'+lat+'" data-lon="'+lon+'" data-name="'+name.replace(/"/g,'&quot;')+'"><span>'+name+'</span><small>'+sub+'</small></div>';}).join('');locSugg.style.display='block';}).catch(()=>{locSugg.style.display='none';});},350);});
    locSugg.addEventListener('click',e=>{const item=e.target.closest('.sugg-item');if(!item)return;const lat=parseFloat(item.dataset.lat),lon=parseFloat(item.dataset.lon);map.flyTo([lat,lon],12,{duration:1.2});locSugg.style.display='none';locInput.value=item.dataset.name;document.getElementById('btn-reset').style.display='block';});
    locInput.addEventListener('keydown',e=>{if(e.key==='Enter'){const f=locSugg.querySelector('.sugg-item');if(f)f.click();}if(e.key==='Escape')locSugg.style.display='none';});
    document.addEventListener('click',e=>{if(!e.target.closest('#panel'))locSugg.style.display='none';});

    function setStatus(msg){document.getElementById('stats').textContent=msg;}
  </script>
</BaseLayout>

