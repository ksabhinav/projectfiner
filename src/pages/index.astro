      z-index:1100!important;
    }
    #panel.collapsed{transform:translateY(calc(100% - 90px))}
    #panel.collapsed #panel-body{pointer-events:none;opacity:0;height:0;overflow:hidden}

    /* Drag handle */
    #panel-handle{display:flex;justify-content:center;padding:8px 0 0;cursor:grab}
