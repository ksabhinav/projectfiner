  #panel-handle{display:none}

  /* ── Mobile responsive — bottom sheet ── */
  @media (max-width: 640px) {
    /* Bottom sheet positioning */
    #panel{
      position:fixed!important;top:auto!important;bottom:0;left:0!important;right:0;
