    document.getElementById('state-select').addEventListener('change',function(e){var val=e.target.value;if(val==='_SEP'){e.target.value=capitalStateFilter;return;}capitalStateFilter=val;renderMarkers();if(!val){map.flyToBounds(INDIA_BOUNDS,{padding:[20,20],duration:1.2});return;}var lats=[],lons=[];[].concat(showCDSL?markerCache.cdsl:[],showNSDL?markerCache.nsdl:[],showMFDI?markerCache.mfdi:[],showMFDC?markerCache.mfdc:[]).forEach(function(m){var c=m._data;var match=val==='_NE'?NE_CODES.includes(c.st):c.st===val;if(!match)return;var ll=coordsMap[c.p];if(ll){lats.push(ll[0]);lons.push(ll[1]);}});if(!lats.length)return;map.flyToBounds([[Math.min.apply(null,lats)-0.3,Math.min.apply(null,lons)-0.3],[Math.max.apply(null,lats)+0.3,Math.max.apply(null,lons)+0.3]],{padding:[40,40],maxZoom:10,duration:1.2});});
    document.getElementById('btn-reset-capital').addEventListener('click',function(){dpQuery='';capitalStateFilter='';drilldownActive=false;document.getElementById('search-dp').value='';document.getElementById('search-loc').value='';document.getElementById('state-select').value='';document.getElementById('btn-back').style.display='none';document.getElementById('loc-sugg').style.display='none';showCDSL=showNSDL=showMFDI=showMFDC=true;['cdsl','nsdl'].forEach(function(l){document.getElementById('tog-'+l).className='sub-btn on-'+l;});document.getElementById('tog-mfdi').className='sub-btn on-mfdi';document.getElementById('tog-mfdc').className='sub-btn on-mfdc';document.getElementById('grp-dpsc').className='grp open dpsc-active';document.getElementById('grp-mfd').className='grp open mfd-active';map.flyToBounds(INDIA_BOUNDS,{padding:[20,20],duration:1.2});setView('choro');});
