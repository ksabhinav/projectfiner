    locInput.addEventListener('input',function(e){var v=e.target.value;clearTimeout(locTimer);if(v.length<2){locSugg.style.display='none';return;}locTimer=setTimeout(function(){fetch('https://photon.komoot.io/api/?q='+encodeURIComponent(v+' India')+'&limit=6&lang=en').then(function(r){return r.json();}).then(function(data){var fs=(data.features||[]).filter(function(f){var coords=f.geometry.coordinates;return coords[0]>=68&&coords[0]<=97&&coords[1]>=6&&coords[1]<=38;}).slice(0,5);if(!fs.length){locSugg.style.display='none';return;}locSugg.innerHTML=fs.map(function(f){var p=f.properties,name=p.name||p.city||p.state||'';var sub=[p.city,p.state].filter(Boolean).join(', ');var coords=f.geometry.coordinates;return'<div class="sugg-item" data-lat="'+coords[1]+'" data-lon="'+coords[0]+'" data-name="'+name.replace(/"/g,'&quot;')+'"><span>'+name+'</span><small>'+sub+'</small></div>';}).join('');locSugg.style.display='block';}).catch(function(){locSugg.style.display='none';});},350);});
