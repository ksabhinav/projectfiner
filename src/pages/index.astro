      if (canonical2 && canonical2 !== dn) {
        if (stateSlug) {
          var sqEntry2 = lookup.get(stateSlug + '|' + canonical2);
          if (sqEntry2) return sqEntry2;
        }
        // If canonical doesn't have a state-qualified entry, do NOT
        // fall through to plain canonical lookup — that's where the
        // cross-state contamination happens. Continue to plain-name
        // and DISTRICT_ALIASES fallbacks below, which are bounded to
        // the polygon's own name.
      }
      return lookup.get(dn) || lookup.get(DISTRICT_ALIASES[dn]) || null;
    }

    // Date suffix pattern for prefix matching — only match date-like suffixes
    // e.g. 'pct_coverage' matches 'pct_coverage_mar_24', 'pct_coverage_9688', etc.
    var DATE_SUFFIX_RE = /_(jan|feb|mar|apr|may|jun|jul|aug|sep|sept|oct|nov|dec|fy|2\d{3}|\d{2,4})$/i;

    function tryFieldWithPrefix(record, catField) {
      // First try exact match
      var v = record[catField];
      if (v != null && v !== '' && !isNaN(Number(v))) return Number(v);
      // Then try prefix match — but only if the suffix looks like a date/number
      // This prevents 'total' from matching 'total_advance' while allowing
      // 'pct_coverage' to match 'pct_coverage_mar_24'
      var keys = Object.keys(record);
      for (var k = 0; k < keys.length; k++) {
        var key = keys[k];
        if (key.length > catField.length + 1 && key.indexOf(catField + '_') === 0) {
          var suffix = key.substring(catField.length);
          if (DATE_SUFFIX_RE.test(suffix)) {
            v = record[key];
            if (v != null && v !== '' && !isNaN(Number(v))) return Number(v);
          }
        }
      }
      return null;
    }

    function getVal(record, cat, field, fallbacks) {
      // 1. Try primary category + field (exact then prefix)
      var v = tryFieldWithPrefix(record, cat + '__' + field);
      if (v !== null) return v;

      // 2. Try primary category + fallback fields
      if (fallbacks) {
        for (var i = 0; i < fallbacks.length; i++) {
          v = tryFieldWithPrefix(record, cat + '__' + fallbacks[i]);
          if (v !== null) return v;
        }
      }

      // 3. Try cross-category fallbacks
      var crossCats = CROSS_CATEGORY_FALLBACKS[cat];
      if (crossCats) {
        for (var c = 0; c < crossCats.length; c++) {
          v = tryFieldWithPrefix(record, crossCats[c] + '__' + field);
          if (v !== null) return v;
          if (fallbacks) {
            for (var j = 0; j < fallbacks.length; j++) {
              v = tryFieldWithPrefix(record, crossCats[c] + '__' + fallbacks[j]);
              if (v !== null) return v;
            }
          }
        }
      }
      return null;
    }

    function buildDistrictLookup() {
      var ind = INDICATORS[currentIndicator];
      var metric = ind.metrics[currentMetricIdx];
      var lookup = new Map();

      if (!currentIndicatorData || !currentIndicatorData.districts) return lookup;

      var districts = currentIndicatorData.districts;
      for (var i = 0; i < districts.length; i++) {
        var rec = districts[i];
        var dn = normDist(rec.district);
        if (!dn) continue;

        // Note: state focus filtering is now applied at render time (style function)
        // rather than at lookup time, so all districts retain data and non-focus
        // states can be rendered as dimmed context.

        // Get the primary metric value
        var val = null;
        // Try primary field, then fallbacks
        var tryFields = [metric.field].concat(metric.fallbacks || []);
        for (var fi = 0; fi < tryFields.length; fi++) {
          var fv = rec[tryFields[fi]];
          if (fv !== undefined && fv !== null && fv !== '') {
            val = parseFloat(String(fv).replace(/,/g, ''));
            if (!isNaN(val)) break;
            val = null;
          }
        }

        // Build all metric values for tooltip
        var allVals = {};
        var allUnits = {};
        for (var mi = 0; mi < ind.metrics.length; mi++) {
          var m = ind.metrics[mi];
          var mval = null;
          var mFields = [m.field].concat(m.fallbacks || []);
          for (var mfi = 0; mfi < mFields.length; mfi++) {
            var mv = rec[mFields[mfi]];
            if (mv !== undefined && mv !== null && mv !== '') {
              mval = parseFloat(String(mv).replace(/,/g, ''));
              if (!isNaN(mval)) break;
              mval = null;
            }
          }
          allVals[m.label] = mval;
          allUnits[m.label] = m.unit || '';
        }

        var entry = { value: val, metrics: allVals, units: allUnits, district: rec.district, state: rec.state };
        // Check if data is from a fallback quarter
        if (currentIndicatorData.quarter && currentIndicatorData.quarter !== currentQuarter) {
          entry.fallbackQuarter = currentIndicatorData.quarter;
        }
        // State-qualified key (primary, prevents cross-state name collisions
        // — e.g. Bilaspur exists in both HP and CG; without this both polygons
        // would resolve to whichever record was stored last under "BILASPUR").
        var recStateSlug = normStateSlug(rec.state);
        if (recStateSlug) lookup.set(recStateSlug + '|' + dn, entry);
        // Plain-name fallback key — only useful for indicators where the
        // polygon's state doesn't normalize to the record's state slug.
        lookup.set(dn, entry);
        // Also key by LGD code for direct matching (NRLM, RBI BSR data)
        if (rec.lgd) lookup.set('__lgd__' + String(rec.lgd), entry);
      }
      return lookup;
    }

    function getColor(value, breaks, ramp) {
      if (value === null || value === undefined) return '#e8e4dc';
      for (var i = breaks.length - 1; i >= 0; i--) {
        if (value >= breaks[i]) return ramp[i + 1] || ramp[ramp.length - 1];
      }
      return ramp[0];
    }

    function computeBreaks(values) {
      var sorted = values.filter(function(v) { return v !== null && !isNaN(v); }).sort(function(a, b) { return a - b; });
      if (sorted.length < 5) return [0, 10, 50, 100, 500];
      var pcts = [0.2, 0.4, 0.6, 0.8, 0.95];
      return pcts.map(function(p) {
        var idx = Math.floor(p * sorted.length);
        return sorted[Math.min(idx, sorted.length - 1)];
      });
    }

    function buildChoropleth_banking() {
      if (choroLayer) { map.removeLayer(choroLayer); choroLayer = null; }
      if (!distGeoJSON || !currentQuarter) return;

      var lookup = buildDistrictLookup();
      var ramp = getRamp(currentIndicator);
      var ind = INDICATORS[currentIndicator];
      var metric = ind.metrics[currentMetricIdx];

      // In Focus NE scope, filter to 8 NE states only
      var NE_ALL = ['ASSAM','MEGHALAYA','MANIPUR','ARUNACHAL PRADESH','MIZORAM','TRIPURA','NAGALAND','SIKKIM'];
      var filtered = {
        type: distGeoJSON.type,
        features: distGeoJSON.features.filter(function(f) {
          var st = f.properties.STATE_UT?.toUpperCase()?.trim();
          if (!NE_STATES.includes(st)) return false;
          if (currentScope === 'ne' && NE_ALL.indexOf(st) < 0) return false;
          // When state focus is active, keep ALL features (don't filter) — non-focus
          // states will be rendered in dim context style.
          return true;
        }),
      };

      // Collect values for break computation. When a state is focused, compute
      // breaks from only that state's distribution so within-state contrast is preserved.
      var allVals = [];
      filtered.features.forEach(function(f) {
        var st = f.properties.STATE_UT?.toUpperCase()?.trim();
        if (bankingStateFilter && st !== bankingStateFilter) return;
        var data = resolveLookup(f, lookup);
        if (data && data.value !== null) allVals.push(data.value);
      });
      var breaks = computeBreaks(allVals);

      var legendLabel = metric.label + (metric.unit === '₹' ? ' (₹ Lakhs)' : metric.unit === '%' ? ' (%)' : '');
      if (bankingStateFilter) {
        // Annotate legend with focused state name (Title Case)
        var stTitle = bankingStateFilter.toLowerCase().replace(/\b\w/g, function(c){return c.toUpperCase();});
        legendLabel = legendLabel + ' · ' + stTitle;
      }
      updateLegend_banking(legendLabel, breaks, ramp);

      choroLayer = L.geoJSON(filtered, {
        style: function(feature) {
          var st = feature.properties.STATE_UT?.toUpperCase()?.trim();
          var data = resolveLookup(feature, lookup);
          var val = data ? data.value : null;
          // Non-focus states: render as dim grey context
          if (bankingStateFilter && st !== bankingStateFilter) {
            return {
              fillColor: '#E2DAC8',
              fillOpacity: 0.35,
              color: '#B8AC95',
              weight: 0.5,
              opacity: 0.45,
            };
          }
          return {
            fillColor: getColor(val, breaks, ramp),
            fillOpacity: val === null ? 0.5 : 0.78,
            color: '#c8bfb0',
            weight: 0.8,
            opacity: 0.7,
          };
        },
        onEachFeature: function(feature, layer) {
          var p = feature.properties;
          var st = p.STATE_UT?.toUpperCase()?.trim();
          // Skip event binding for dim non-focus states (no hover, no click)
          if (bankingStateFilter && st !== bankingStateFilter) {
            // Click on dim state in main map should focus that state
            layer.on('click', function(e) {
              L.DomEvent.stopPropagation(e);
              window.dispatchEvent(new CustomEvent('finer:stateFilterChange', { detail: { state: st } }));
            });
            return;
          }
          var data = resolveLookup(feature, lookup);

          layer.on({
            mouseover: function(e) {
              e.target.setStyle({ weight: 2.5, color: '#6b4c2a', fillOpacity: 0.92 });
              // Atlas tooltip — district name, italic state, big Fraunces stat
              // for the active metric, mono meta line at foot.
              var tip = '<div class="dist-tooltip">'
                + '<div class="dtt-head">'
                + '<div class="dtt-name">' + p.DISTRICT + '</div>'
                + '<div class="dtt-state">' + p.STATE_UT + '</div>'
                + '</div>';
              if (data) {
                // Find the active metric value
                var activeLabel = metric.label;
                var activeVal = data.metrics[activeLabel];
                var activeUnit = data.units ? data.units[activeLabel] : '';
                var activeFmt = activeVal !== null && activeVal !== undefined
                  ? fmtWithUnit(activeVal, activeUnit) : '—';
                // Split formatted value into number + unit suffix for typographic styling
                var unitMatch = activeFmt.match(/^([^A-Za-z%₹]*[\d.,]+)\s*(.*)$/);
                var bigNum = unitMatch ? unitMatch[1].trim() : activeFmt;
                var bigUnit = unitMatch ? unitMatch[2].trim() : '';
                tip += '<div class="dtt-stat-block">'
                  + '<div class="dtt-stat">' + bigNum
                  + (bigUnit ? '<span class="dtt-stat-unit">' + bigUnit + '</span>' : '')
                  + '</div>'
                  + '<div class="dtt-stat-label">' + activeLabel + '</div>'
                  + '</div>';
                // Other metrics as a tight list
                var otherCount = 0;
                var others = '';
                for (var label in data.metrics) {
                  if (label === activeLabel) continue;
                  var val = data.metrics[label];
                  var u = data.units ? data.units[label] : '';
                  var formatted = val !== null && val !== undefined ? fmtWithUnit(val, u) : '—';
                  others += '<div class="dtt-row">'
                    + '<span class="dtt-label">' + label + '</span>'
                    + '<span class="dtt-val">' + formatted + '</span>'
                    + '</div>';
                  otherCount++;
                  if (otherCount >= 4) break;
                }
                if (otherCount) tip += '<div class="dtt-others">' + others + '</div>';
                // Source line — Atlas mono meta
                var sourceQ = data.fallbackQuarter || currentQuarter;
                var indKey = (window.__FINER && window.__FINER.indicator) ? window.__FINER.indicator.replace(/_/g, ' ') : 'SLBC';
                tip += '<div class="dtt-meta">'
                  + '<span>' + indKey.toUpperCase() + '</span>'
                  + '<span>' + fmtQuarter(sourceQ).toUpperCase() + '</span>'
                  + '</div>';
                if (data.fallbackQuarter) {
                  tip += '<div class="dtt-fallback">' + fmtQuarter(data.fallbackQuarter) + ' (latest available)</div>';
                }
                if (data.inheritedFrom) {
                  // New (post-2020) district whose SLBC source still reports
                  // under the pre-reorg parent. Disclose the inheritance so
                  // the colour isn't misread as the carved district's own data.
                  tip += '<div class="dtt-fallback">Reported under '
                    + data.inheritedFrom + ' (pre-reorg SLBC structure)</div>';
                }
              } else {
                tip += '<div class="dtt-empty">No data available</div>';
              }
              tip += '</div>';
              e.target.bindTooltip(tip, { sticky: true, className: '', offset: [10, 0] }).openTooltip();
            },
            mouseout: function(e) {
              choroLayer.resetStyle(e.target);
              e.target.closeTooltip();
            },
            dblclick: function(e) {
              L.DomEvent.stopPropagation(e);
              L.DomEvent.preventDefault(e);
              focusDistrict(normDist(p.DISTRICT), p.STATE_UT);
            },
          });
        },
      }).addTo(map);

      updateStats_banking(lookup, allVals);
      if (focusedDistrict) updateFocusPanel();
    }

    function updateLegend_banking(metricLabel, breaks, ramp) {
      // Dispatch to MapLegend.svelte
      var unit = '';
      if (metricLabel.indexOf('(₹') >= 0) unit = '₹';
      else if (metricLabel.indexOf('(%)') >= 0) unit = '%';
      window.__FINER.legendData = { title: metricLabel, breaks: breaks, ramp: ramp, unit: unit };
      window.dispatchEvent(new CustomEvent('finer:legendUpdate', { detail: { title: metricLabel, breaks: breaks, ramp: ramp, unit: unit, indicator: currentIndicator } }));
    }

    function updateStats_banking(lookup, allVals) {
      var total = lookup ? lookup.size : 0;
      var withData = allVals ? allVals.length : 0;
      var avg = withData ? (allVals.reduce(function(a, b) { return a + b; }, 0) / withData) : 0;
      var max = withData ? Math.max.apply(null, allVals) : 0;
      var min = withData ? Math.min.apply(null, allVals) : 0;
      var ind = INDICATORS[currentIndicator];
      var metric = ind.metrics[currentMetricIdx];

      var u = metric.unit || '';
      var unitLabel = u === '₹' ? ' (₹ Lakhs)' : u === '%' ? ' (%)' : '';
      var html = '<strong>' + ind.title + '</strong><br>'
        + '<span style="font-size:9px;color:#888078">' + fmtQuarter(currentQuarter) + unitLabel + '</span><br>'
        + '<span style="color:#3d7a8e">' + withData + '</span> districts with data<br>'
        + 'Avg: <strong>' + fmtWithUnit(avg, u) + '</strong><br>'
        + 'Min: ' + fmtWithUnit(min, u) + ' · Max: ' + fmtWithUnit(max, u);

      var el = document.getElementById('stats-banking');
      if (el) el.innerHTML = html;
      window.dispatchEvent(new CustomEvent('finer:bankingStatsUpdate', { detail: { html: html, showReset: !!bankingStateFilter } }));
    }

    // ── District Focus Mode ──
    var focusedDistrict = null;
    var focusedSvgPath = '';   // cached SVG path so timeline/indicator changes don't blank the polygon
    var focusedState = null;

    function geoToSVGPath(geometry, width, height) {
      var coords = [];
      function collectCoords(c) {
        if (typeof c[0] === 'number') { coords.push(c); return; }
        for (var i = 0; i < c.length; i++) collectCoords(c[i]);
      }
      collectCoords(geometry.coordinates);
      if (coords.length === 0) return '';

      var minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
      for (var i = 0; i < coords.length; i++) {
        if (coords[i][0] < minX) minX = coords[i][0];
        if (coords[i][0] > maxX) maxX = coords[i][0];
        if (coords[i][1] < minY) minY = coords[i][1];
        if (coords[i][1] > maxY) maxY = coords[i][1];
      }
      var geoW = maxX - minX || 1;
      var geoH = maxY - minY || 1;
      var pad = 30;
      var scale = Math.min((width - pad * 2) / geoW, (height - pad * 2) / geoH);
      var cx = width / 2, cy = height / 2;
      var geoCx = (minX + maxX) / 2, geoCy = (minY + maxY) / 2;

      function px(lng) { return cx + (lng - geoCx) * scale; }
      function py(lat) { return cy - (lat - geoCy) * scale; }

      function ringToPath(ring) {
        var d = '';
        for (var j = 0; j < ring.length; j++) {
          d += (j === 0 ? 'M' : 'L') + px(ring[j][0]).toFixed(1) + ',' + py(ring[j][1]).toFixed(1);
        }
        return d + 'Z';
      }

      var path = '';
      var type = geometry.type;
      var c = geometry.coordinates;
      if (type === 'Polygon') {
        for (var ri = 0; ri < c.length; ri++) path += ringToPath(c[ri]);
      } else if (type === 'MultiPolygon') {
        for (var pi = 0; pi < c.length; pi++) {
          for (var ri2 = 0; ri2 < c[pi].length; ri2++) path += ringToPath(c[pi][ri2]);
        }
      }
      return path;
    }

    function focusDistrict(districtName, stateName) {
      if (!distGeoJSON) return;
      var feature = distGeoJSON.features.find(function(f) {
        var dn = normDist(f.properties.DISTRICT);
        if (dn === districtName) return true;
        var canonical = lgdNameToCanonical[dn];
        if (canonical === districtName) return true;
        canonical = lgdNameToCanonical[districtName];
        if (canonical && canonical === dn) return true;
        return DISTRICT_ALIASES[dn] === districtName;
      });
      if (!feature) return;

      focusedDistrict = districtName;
      focusedState = stateName || feature.properties.STATE_UT;

      // Cache the path so timeline/indicator changes don't blank it
      focusedSvgPath = geoToSVGPath(feature.geometry, 400, 400);
      updateFocusPanel(focusedSvgPath);
    }

    function updateFocusPanel(svgPathOverride) {
      if (!focusedDistrict) return;
      var lookup = buildDistrictLookup();
      var ind = INDICATORS[currentIndicator];
      var metric = ind.metrics[currentMetricIdx];
      // Same resolver as choropleth: state-qualified, then parent-district
      // fallback for post-2020 carved districts, then name-only as last resort.
      var fState = normStateSlug(focusedState);
      var data = null;
      if (fState) {
        data = lookup.get(fState + '|' + focusedDistrict);
        if (!data) {
          var aliasD = DISTRICT_ALIASES[focusedDistrict];
          if (aliasD) data = lookup.get(fState + '|' + aliasD);
        }
        if (!data) {
          // New-district parent fallback
          var parentInfo = NEW_DISTRICT_PARENTS[focusedDistrict];
          if (parentInfo && parentInfo[1] === fState) {
            var pEntry = lookup.get(fState + '|' + parentInfo[0]);
            if (pEntry) {
              data = {};
              for (var pk in pEntry) { data[pk] = pEntry[pk]; }
              data.inheritedFrom = NEW_DISTRICT_PARENTS_DISPLAY[focusedDistrict] || parentInfo[0];
            }
          }
        }
      }
      if (!data) {
        data = lookup.get(focusedDistrict) || lookup.get(DISTRICT_ALIASES[focusedDistrict]);
      }
      var ramp = getRamp(currentIndicator);

      var val = data ? data.value : null;
      var breaks = [];
      lookup.forEach(function(d) { if (d.value !== null) breaks.push(d.value); });
      breaks = computeBreaks(breaks);
      var color = getColor(val, breaks, ramp);

      var titleCased = focusedDistrict.split(' ').map(function(w) {
        return w.charAt(0) + w.slice(1).toLowerCase();
      }).join(' ');

      // Always reuse the cached focusedSvgPath unless an override was passed
      var pathToUse = svgPathOverride || focusedSvgPath;

      var focusDetail = {
        active: true,
        district: titleCased,
        state: focusedState || '',
        svgPath: pathToUse,
        svgViewBox: '0 0 400 400',
        fillColor: color,
        strokeColor: ramp[4] || '#B84A2E',
        metricLabel: metric.label,
        value: val !== null ? fmtWithUnit(val, metric.unit) : 'No data',
        quarter: fmtQuarter(currentQuarter),
      };
      window.__FINER.focus = focusDetail;
      window.dispatchEvent(new CustomEvent('finer:focusUpdate', { detail: focusDetail }));
    }

    function exitFocus() {
      focusedDistrict = null;
      focusedState = null;
      focusedSvgPath = '';
      window.__FINER.focus = { active: false };
      window.dispatchEvent(new CustomEvent('finer:focusUpdate', { detail: { active: false, district: '', state: '', svgPath: '', svgViewBox: '0 0 400 400', fillColor: '', strokeColor: '', metricLabel: '', value: '', quarter: '' } }));
    }

    // Focus mode — FocusOverlay.svelte handles its own event listeners (close, ESC, backdrop)
    window.addEventListener('finer:exitFocus', function() { exitFocus(); });

    // Atlas: SearchPalette fires this after picking a district from ⌘K
    window.addEventListener('finer:focusDistrict', function(e) {
      var d = (e.detail && e.detail.district) || '';
      var st = (e.detail && e.detail.state) || '';
      if (!d) return;
      // Wait briefly so the state-filter event has time to apply (map fly-to)
      setTimeout(function() {
        focusDistrict(normDist(d.toUpperCase()), st);
      }, 250);
    });

    // Banking district labels
    function buildDistrictLabels_banking() {
      if (!distGeoJSON) return;
      bankingCentroids = [];
      distGeoJSON.features.forEach(function(f) {
        var st = f.properties.STATE_UT?.toUpperCase()?.trim();
        if (!NE_STATES.includes(st)) return;
        try {
          var tmp = L.geoJSON(f);
          var b = tmp.getBounds();
          bankingCentroids.push({ center: b.getCenter(), name: f.properties.DISTRICT, bounds: b, state: st });
        } catch(e) {}
      });
    }

    function updateLabelVisibility_banking() {
      if (currentMode !== 'banking') return;
      if (distLabelsLayer) { map.removeLayer(distLabelsLayer); distLabelsLayer = null; }
      var z = map.getZoom();
      if (z < 8) return;
      var viewBounds = map.getBounds();
      distLabelsLayer = L.layerGroup();
      var placed = [];
      bankingCentroids.forEach(function(d) {
        if (bankingStateFilter && d.state !== bankingStateFilter) return;
        if (!viewBounds.intersects(d.bounds)) return;
        var px = map.latLngToContainerPoint(d.center);
        var tooClose = placed.some(function(p) { return Math.abs(px.x - p.x) < 120 && Math.abs(px.y - p.y) < 30; });
        if (tooClose) return;
        placed.push(px);
        distLabelsLayer.addLayer(L.marker(d.center, {
          icon: L.divIcon({
            className: 'dist-label',
            html: d.name,
            iconSize: [0, 0],
            iconAnchor: [0, 0],
          }),
          interactive: false,
        }));
      });
      distLabelsLayer.addTo(map);
    }

    function populateMetrics() {
      // Metrics dropdown is now handled by MapPanel.svelte
      var ind = INDICATORS[currentIndicator];
      if (!ind) return;
      if (currentMetricIdx >= ind.metrics.length) currentMetricIdx = 0;
      // Update __FINER so Svelte can read it
      window.__FINER.indicators = INDICATORS;
      window.__FINER.indicator = currentIndicator;
      window.__FINER.metricIdx = currentMetricIdx;
      window.dispatchEvent(new CustomEvent('finer:indicatorsReady', { detail: { indicators: INDICATORS } }));
    }

    var currentQIdx = 0;

    // setTimelinePosition — now handled by TimelineSlider.svelte
    function setTimelinePosition(idx) {
      // Keep internal state in sync
      if (idx < 0 || idx >= sortedQuarters.length) return;
      currentQIdx = idx;
      currentQuarter = sortedQuarters[idx];
    }

    function populateSlider() {
      // Use manifest quarters if available (progressive loading), otherwise scan slbcData (legacy)
      if (manifestData && manifestData.quarters && manifestData.quarters.length > 0) {
        sortedQuarters = manifestData.quarters.slice(); // already sorted latest-first
        manifestQuarters = sortedQuarters.slice();      // save for restoring after per-indicator time points
      } else {
        var qSet = new Set();
        for (var slug of Object.keys(slbcData)) {
          for (var ri = 0; ri < slbcData[slug].length; ri++) {
            var rec = slbcData[slug][ri];
            if (rec.period) qSet.add(rec.period);
          }
        }
        sortedQuarters = Array.from(qSet).sort().reverse();
        manifestQuarters = sortedQuarters.slice();
      }
      currentQIdx = 0;
      currentQuarter = sortedQuarters[currentQIdx];

      // Update __FINER and notify TimelineSlider.svelte
      window.__FINER.sortedQuarters = sortedQuarters;
      window.__FINER.quarter = currentQuarter;
      window.dispatchEvent(new CustomEvent('finer:quartersReady', { detail: { quarters: sortedQuarters } }));
    }

    // Switch timeline slider to a per-indicator set of time points (e.g. NFHS-5 vs NFHS-4)
    function switchSliderToTimePoints(pts) {
      sortedQuarters = pts.slice();
      currentQIdx = 0;
