    /* Mobile quick-nav row inside panel head */

    /* Body */
    #panel-body{padding:8px 20px 24px;transition:opacity 0.2s;overflow-y:auto;max-height:calc(75vh - 90px)}
    .mode-row,.view-row{margin-bottom:8px}
