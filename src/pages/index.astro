---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import IndicatorStrip from '../components/map/IndicatorStrip.svelte';
import MapLegend from '../components/map/MapLegend.svelte';
import TimelineSlider from '../components/map/TimelineSlider.svelte';
import FocusOverlay from '../components/map/FocusOverlay.svelte';
import SearchPalette from '../components/map/SearchPalette.svelte';
// FactCard renders the "A finding" modal triggered by the strip button.
import FactCard from '../components/map/FactCard.svelte';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Project FINER">
  <Header title="" transparent />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <div id="map"></div>

  <!-- Atlas loading state — shown until first indicator data lands -->
  <div id="map-loading" aria-live="polite">
    <svg class="ml-mark" viewBox="0 0 36 50" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="0" y="4"  width="14" height="6" fill="#B84A2E"/>
      <rect x="0" y="14" width="22" height="6" fill="#1B140E"/>
      <rect x="0" y="24" width="36" height="6" fill="#1B140E"/>
      <rect x="0" y="34" width="20" height="6" fill="#D4A24A"/>
    </svg>
    <div class="ml-text">Loading <span class="em">Project FINER</span>…</div>
    <div class="ml-detail" id="ml-detail">FETCHING DISTRICTS</div>
    <div class="ml-dots"><span></span><span></span><span></span></div>
  </div>
  <!-- State inset removed — Where cell in IndicatorStrip handles state focus. -->
  <IndicatorStrip client:load />
  <MapLegend client:load />

  <!-- Vertical timeline (Svelte component) -->
  <TimelineSlider client:load />

  {/* Old watermark removed — brand is in the Header */}

  <!-- District Focus Mode overlay (Svelte component) -->
  <FocusOverlay client:load />

  <!-- ⌘K search palette -->
  <SearchPalette client:load />
  <!-- "A finding" card — fired by FindingButton on the indicator strip -->
  <FactCard client:load />


  <script is:inline define:vars={{ base }}>
    window.__FINER_BASE = base;
    // Initialize shared state for Svelte components (they read from this in onMount)
    window.__FINER = {
      mode: 'banking',
      scope: 'ne',
      indicator: 'digital_transactions',
      metricIdx: 0,
      quarter: '',
      stateFilter: '',
      sortedQuarters: [],
      stats: {},
      legendData: { title: '', breaks: [], ramp: [], unit: '' },
      focus: { active: false },
      indicators: {},
      manifest: null,
    };
  </script>

  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline>
    // ══════════════════════════════════════════
    // Section 1 — Shared
    // ══════════════════════════════════════════
    var _B = window.__FINER_BASE;

    var _isMobile = window.innerWidth <= 640;
    // Desktop north widened to 46°N so the +72 strip-padding can
    // actually slide content down (Leaflet's _limitCenter clamps
    // against maxBounds; with north=40°N the padding silently no-op'd).
    // Mobile kept at the original 45°N — bumping it added unwanted
    // whitespace above India on phones.
    var INDIA_BOUNDS = _isMobile
      ? L.latLngBounds(L.latLng(0, 48.0), L.latLng(45, 115.0))
      : L.latLngBounds(L.latLng(2, 50.0), L.latLng(46, 115.0));
    var NE_BOUNDS    = L.latLngBounds(L.latLng(17.5, 79.5), L.latLng(29.5, 97.5));
    var ALL_STATES_BOUNDS = L.latLngBounds(L.latLng(6.5, 67.5), L.latLng(37.5, 98)); // Full India incl J&K/Ladakh (north ~37.1°N), Kutch, A&N (south ~6.75°N)
    var NE_CENTER    = [20, 82.5]; // Visual center of all 19 states (lat 8-30, lng 68-97.5)
    var NE_CODES     = ['AS','ML','MN','MZ','NL','TR','AR','SK','BR','WB','JH','OR','CT','KL','KA','TN','RJ','GJ','MH','HR','TS','UK'];
    var NE_STATES    = ['ASSAM','MEGHALAYA','MANIPUR','MIZORAM','NAGALAND','TRIPURA','ARUNACHAL PRADESH','SIKKIM','BIHAR','WEST BENGAL','JHARKHAND','ODISHA','CHHATTISGARH','KERALA','KARNATAKA','TAMIL NADU','RAJASTHAN','GUJARAT','MAHARASHTRA','HARYANA','TELANGANA','UTTARAKHAND','ANDHRA PRADESH','MADHYA PRADESH','UTTAR PRADESH','PUNJAB','HIMACHAL PRADESH','JAMMU AND KASHMIR','GOA','DELHI','CHANDIGARH','PUDUCHERRY','ANDAMAN AND NICOBAR ISLANDS','DADRA & NAGAR HAVELI & DAMAN & DIU','LADAKH','LAKSHADWEEP'];
    var STATE_SLUGS  = {
      'ASSAM': 'assam', 'MEGHALAYA': 'meghalaya', 'MANIPUR': 'manipur',
      'MIZORAM': 'mizoram', 'NAGALAND': 'nagaland', 'TRIPURA': 'tripura',
      'ARUNACHAL PRADESH': 'arunachal-pradesh', 'SIKKIM': 'sikkim',
      'BIHAR': 'bihar', 'WEST BENGAL': 'west-bengal', 'JHARKHAND': 'jharkhand',
      'ODISHA': 'odisha', 'CHHATTISGARH': 'chhattisgarh',
      'KERALA': 'kerala', 'KARNATAKA': 'karnataka', 'TAMIL NADU': 'tamil-nadu',
      'RAJASTHAN': 'rajasthan', 'GUJARAT': 'gujarat', 'MAHARASHTRA': 'maharashtra',
      'HARYANA': 'haryana', 'TELANGANA': 'telangana', 'UTTARAKHAND': 'uttarakhand',
      'ANDHRA PRADESH': 'andhra-pradesh', 'MADHYA PRADESH': 'madhya-pradesh',
      'UTTAR PRADESH': 'uttar-pradesh', 'PUNJAB': 'punjab',
      'HIMACHAL PRADESH': 'himachal-pradesh', 'JAMMU AND KASHMIR': 'jammu-kashmir',
      'GOA': 'goa', 'DELHI': 'delhi', 'CHANDIGARH': 'chandigarh',
      'PUDUCHERRY': 'puducherry', 'ANDAMAN AND NICOBAR ISLANDS': 'andaman-nicobar',
      'DADRA & NAGAR HAVELI & DAMAN & DIU': 'dadra-nagar-haveli',
      'LADAKH': 'ladakh', 'LAKSHADWEEP': 'lakshadweep',
    };

    // Map init — use fitBounds immediately to avoid layout shift when data loads
    var map = L.map('map',{center:[22,82.5],zoom:5,minZoom:4,maxZoom:18,zoomSnap:0,zoomDelta:1,maxBounds:INDIA_BOUNDS,maxBoundsViscosity:1.0,attributionControl:false,zoomControl:false,preferCanvas:true,doubleClickZoom:false});

    // Atlas: chrome is now header (52px) + strip (56px) = 108px on top, no left panel
    function getPanelPadding() {
      var isMobile = window.innerWidth <= 640;
      var headerEl = document.querySelector('header');
      var strip = document.getElementById('indicator-strip');
      var headerH = headerEl ? headerEl.offsetHeight : 52;
      var stripH = strip ? strip.offsetHeight : 56;
      if (isMobile) {
        // Mobile: just enough room below the strip + standard bottom for
        // the docked horizontal timeline. Tight here was fine.
        return { paddingTopLeft: [10, headerH + stripH + 12], paddingBottomRight: [10, 80] };
      }
      // Desktop: J&K / Ladakh's northern fingers were grazing the strip's
      // bottom edge on the default All-India view. Bigger top buffer so
      // there's visible whitespace above the northernmost polygons.
      var sliderW = 65; // timeline slider + zoom controls + margin
      return { paddingTopLeft: [10, headerH + stripH + 72], paddingBottomRight: [sliderW, 10] };
    }

    // Position map immediately — strip mounts above the map, no width to wait for
    function fitMapWhenReady() {
      map.invalidateSize({ animate: false });
      var pad = getPanelPadding();
      map.fitBounds(ALL_STATES_BOUNDS, Object.assign({}, pad, { animate: false }));
      // Re-fit once strip has rendered to grab actual height
      setTimeout(function() {
        map.invalidateSize({ animate: false });
        map.fitBounds(ALL_STATES_BOUNDS, Object.assign({}, getPanelPadding(), { animate: false }));
      }, 200);
    }
    fitMapWhenReady();

    // Refit on window resize (debounced)
    var resizeTimer;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function() {
        map.invalidateSize({ animate: false });
        var pad = getPanelPadding();
        map.fitBounds(ALL_STATES_BOUNDS, Object.assign({}, pad, { animate: false }));
      }, 200);
    });

    L.control.zoom({position:'topright'}).addTo(map);

    // Fly to NE with panel-aware centering (single smooth animation)
    function flyToNE(animate) {
      map.invalidateSize({ animate: false });
      var pad = getPanelPadding();
      if (animate !== false) {
        map.flyToBounds(ALL_STATES_BOUNDS, Object.assign({}, pad, { duration: 1.2 }));
      } else {
        map.fitBounds(ALL_STATES_BOUNDS, Object.assign({}, pad, { animate: false }));
      }
    }

    // Atlas: paper canvas tile so empty regions and ocean show paper color
    var paperCanvasTile = new (L.GridLayer.extend({createTile:function(){var t=document.createElement('canvas');var r=window.devicePixelRatio||1;t.width=t.height=256*r;t.style.width=t.style.height='256px';var c=t.getContext('2d');c.scale(r,r);c.fillStyle='#F4EFE6';c.fillRect(0,0,256,256);return t;}}));
    paperCanvasTile.addTo(map);

    // India outline layer — Atlas paper-deep fill so unmapped districts blend
    var indiaOutlineLayer = null;
    fetch(_B + 'Maps/india-outline.geojson')
      .then(function(r){return r.json();}).then(function(geo){
        indiaOutlineLayer = L.geoJSON(geo,{style:{fillColor:'#ECE5D6',fillOpacity:1,color:'#B8AC95',weight:1,opacity:0.5},interactive:false}).addTo(map);
      }).catch(function(){});

    // State name → code mapping
    var STATE_NAME_CODE={'ANDHRA PRADESH':'AP','ARUNACHAL PRADESH':'AR','ASSAM':'AS','BIHAR':'BR','CHHATTISGARH':'CT','GOA':'GA','GUJARAT':'GJ','HARYANA':'HR','HIMACHAL PRADESH':'HP','JHARKHAND':'JH','KARNATAKA':'KA','KERALA':'KL','MADHYA PRADESH':'MP','MAHARASHTRA':'MH','MANIPUR':'MN','MEGHALAYA':'ML','MIZORAM':'MZ','NAGALAND':'NL','ODISHA':'OR','PUNJAB':'PB','RAJASTHAN':'RJ','SIKKIM':'SK','TAMIL NADU':'TN','TELANGANA':'TS','TRIPURA':'TR','UTTAR PRADESH':'UP','UTTARAKHAND':'UK','WEST BENGAL':'WB','JAMMU AND KASHMIR':'JK','LADAKH':'JK','DELHI':'DL','CHANDIGARH':'CH','PUDUCHERRY':'PY','ANDAMAN & NICOBAR':'AN','LAKSHADWEEP':'LD','DADRA & NAGAR HAVELI & DAMAN & DIU':'DN'};
    function stateCodeMatch(stateName,code){return STATE_NAME_CODE[stateName?.toUpperCase()]===code;}

    // Shared variables
    var distGeoJSON = null;
    var choroLayer = null;
    var distLabelsLayer = null;
    var distCentroids = [];
    var currentMode = 'banking';

    // Block-level (Focus NE) variables
    var currentScope = 'india'; // 'india' or 'ne'
    var blockGeoJSON = null;
    var blockData = {};  // slug -> flat block records
    var blockLoaded = false;
    var BLOCK_ALIASES = {};
    var NE_FOCUS_STATES = ['ASSAM','MANIPUR','MIZORAM','NAGALAND','TRIPURA','SIKKIM'];
    var NE_FOCUS_BOUNDS = L.latLngBounds(L.latLng(21.5, 88), L.latLng(29.5, 97.5));

    window.addEventListener('finer:stateFilterChange', function(e) {
      bankingStateFilter = e.detail.state;
      // syncUrl() (defined further down) writes state + indicator + metric +
      // quarter together; we call it lazily here in case the listener fires
      // before syncUrl is defined on first page load.
      if (typeof syncUrl === 'function') syncUrl();
      if (slbcLoaded) { buildChoropleth_banking(); updateLabelVisibility_banking(); }
      // Update inset highlight
      if (typeof updateInsetHighlight === 'function') updateInsetHighlight();
      if (bankingStateFilter) {
        var stateFts = distGeoJSON ? distGeoJSON.features.filter(function(f) {
          return f.properties.STATE_UT?.toUpperCase()?.trim() === bankingStateFilter;
        }) : [];
        if (stateFts.length) {
          var group = L.geoJSON({ type: 'FeatureCollection', features: stateFts });
          map.flyToBounds(group.getBounds(), { padding: [40, 40], maxZoom: 9, duration: 1.0 });
        }
      } else if (currentScope === 'ne') {
        flyToNE();
      } else {
        // Return to All India view
        var pad = window.innerWidth < 768 ? { padding: [10, 10] } : { padding: [40, 40] };
        map.flyToBounds(ALL_STATES_BOUNDS, Object.assign({}, pad, { duration: 1.0 }));
      }
    });

    // Map zoom/move events for banking labels
    map.on('zoomend', function() { if (currentMode === 'banking') updateLabelVisibility_banking(); });
    map.on('moveend', function() { if (currentMode === 'banking') updateLabelVisibility_banking(); });

    // ══════════════════════════════════════════
    // Section 3 — Banking mode
    // ══════════════════════════════════════════
    var INDICATORS = {
      credit_deposit_ratio: {
        title: 'Credit-Deposit Ratio',
        desc: 'Ratio of bank credit (loans) to deposits in a district. A higher ratio means banks are lending more relative to what they collect. Below 40% signals credit-starved regions where deposits flow out to fund lending elsewhere.',
        metrics: [
          { field: 'overall_cd_ratio', label: 'Overall CD Ratio (%)', unit: '%', desc: 'Total advances divided by total deposits, expressed as a percentage. The single most important measure of whether a district is a net borrower or net saver.', fallbacks: ['cd_ratio', 'current_c_d_ratio', 'cdr', 'overall', 'cd_ratio_incl_pou'] },
          { field: 'total_deposit', label: 'Total Deposits', unit: '₹', desc: 'Aggregate deposits held in all bank branches in the district, in Rs. Lakhs. Includes savings, current, term, and recurring deposits.', fallbacks: ['deposit', 'deposits_rural', 'september_2025_total_deposit', 'total_deposits'] },
          { field: 'total_advance', label: 'Total Advances', unit: '₹', desc: 'Total outstanding bank credit (loans disbursed) across all branches in the district, in Rs. Lakhs. Includes agriculture, MSME, personal, and housing loans.', fallbacks: ['advance', 'advances', 'total_advance_utilized_in_the_state', 'total_advances'] },
          { field: 'total_branch', label: 'Total Branches', unit: '', desc: 'Number of bank branches operating in the district across all bank types (public, private, RRBs, cooperative).', fallbacks: ['total', 'no_of_brs', 'total_branches'] },
        ],
      },
      pmjdy: {
        title: 'PM Jan Dhan Yojana',
        desc: 'India\'s flagship financial inclusion scheme launched in 2014 to provide universal bank account access. Every household gets a zero-balance account with a RuPay debit card, accident insurance, and overdraft facility.',
        metrics: [
          { field: 'total_pmjdy_no', label: 'Total PMJDY Accounts', unit: '', desc: 'Total number of Jan Dhan accounts opened in the district. These are basic savings accounts (BSBD) with zero minimum balance, aimed at the unbanked population.', fallbacks: ['total_no_pmjdy', 'pmjdy_no', 'total_no', 'no_of_pmjdy_accounts', 'pmjdy', 'total', 'number_of_pmjdy_accounts_rural', 'total_pmjdy_a_c', 'total_no_pmjdy_a_c', 'total_a_c', 'sum_of_total_a_c', 'pmjdy_total_accounts'] },
          { field: 'no_of_zero_balance_a_c', label: 'Zero Balance Accounts', unit: '', desc: 'PMJDY accounts with zero balance — no deposits ever made. A high count signals accounts opened but never used, indicating inclusion on paper but not in practice.', fallbacks: ['zero_balance', 'zero_balance_a_c', 'zero_balance_account_2', 'zero_balance_account'] },
          { field: 'no_of_aadhaar_seeded', label: 'Aadhaar Seeded', unit: '', desc: 'PMJDY accounts where Aadhaar has been linked. Required for receiving Direct Benefit Transfer (DBT) payments and using Aadhaar-based services like AePS.', fallbacks: ['aadhaar_seeded', 'aadhaar_seeding_pct', 'sum_of_aadhaar_seeded'] },
          { field: 'no_of_rupay_card_issued', label: 'RuPay Cards Issued', unit: '', desc: 'Number of RuPay debit cards issued to PMJDY account holders. Each card includes Rs. 2 lakh accidental insurance cover under PMSBY.', fallbacks: ['rupay_card_issued', 'rupaycard_account', 'rupay_card_account', 'ar_cu_psaycard_issued'] },
          { field: 'female_no', label: 'Female Accounts', unit: '', desc: 'PMJDY accounts held by women. Over 55% of all Jan Dhan accounts nationally are held by women, making it the largest women\'s financial inclusion program.', fallbacks: ['no_of_women_pmjdy_accounts', 'female', 'female_a_c', 'sum_of_female_a_c'] },
          { field: 'rural_no', label: 'Rural Accounts', unit: '', desc: 'PMJDY accounts opened in rural and semi-urban branches. About 67% of all Jan Dhan accounts are in rural areas nationally.', fallbacks: ['rural', 'rural_a_c', 'sum_of_rural_a_c'] },
        ],
      },
      branch_network: {
        title: 'Branch Network',
        desc: 'Physical banking infrastructure — branches, ATMs, and Business Correspondents (BCs). Branch density per capita is a core measure of banking access, especially in rural areas.',
        metrics: [
          { field: 'total_branch', label: 'Total Branches', unit: '', desc: 'Total bank branches across all types — public sector, private, RRBs, SFBs, and cooperative banks. RBI classifies centres as rural (<10K population), semi-urban (10K-1L), urban (1L-10L), or metro (>10L).', fallbacks: ['total', 'no_of_branches', 'total_no_of_br', 'total_branche_s', 'total_branches', 'total_branch_es', 'branches_total'] },
          { field: 'branch_rural', label: 'Rural Branches', unit: '', desc: 'Branches in centres with population under 10,000. Critical for last-mile banking access in villages.', fallbacks: ['atm_rural', 'rural', 'branches_rural'] },
          { field: 'branch_semi_urban', label: 'Semi-Urban Branches', unit: '', desc: 'Branches in centres with population between 10,000 and 1 lakh. Serve smaller towns and block headquarters.', fallbacks: ['semi_urban', 'branches_semi_urban'] },
          { field: 'branch_urban', label: 'Urban Branches', unit: '', desc: 'Branches in centres with population between 1 lakh and 10 lakh.', fallbacks: ['urban', 'branches_urban'] },
          { field: 'total_atm', label: 'Total ATMs', unit: '', desc: 'Total ATMs (on-site + off-site) across all banks. Includes Cash Recycler Machines (CRMs). ATM density is often lower in NE states compared to national average.', fallbacks: ['no_of_atm', 'total_atms', 'atm_total'] },
          { field: 'total_csp', label: 'Total CSPs', unit: '', desc: 'Customer Service Points operated by Business Correspondents (BCs). These are agents — often shopkeepers — with a micro-ATM device who provide basic banking services in unbanked villages.', fallbacks: ['bc_total', 'total_bc'] },
        ],
      },
      kcc: {
        title: 'Kisan Credit Card',
        desc: 'Revolving credit facility for farmers to meet crop production and allied activity expenses. Provides short-term credit at subsidized interest rates (currently 4% effective after subvention). Extended to animal husbandry and fisheries in 2019.',
        metrics: [
          { field: 'total_no_of_kcc', label: 'Total KCC Issued', unit: '', desc: 'Total number of Kisan Credit Cards issued (including renewals). Each card provides a credit limit based on the farmer\'s landholding, crop pattern, and scale of finance.', fallbacks: ['no_of_kcc', 'kcc_no', 'total_kcc_no', 'total_no', 'o_s_position_no_of_cards_issued', 'cum_no_app_sanc', 'no_of_kcc_issued_during_quarter_including_renewal', 'rupay_card_issued_in_kcc', 'target_no', 'outstanding_at_the_end_of_reporting_quarter_no', 'outstanding_at_the_end_of_reporting_quarter_number', 'kcc_card_activated_number', 'no_of_applications_sanctioned', 'kcc_new_target_no', 'kcc_outstanding_as_on', 'no_of_kcc_issued'] },
          { field: 'outstanding_amt', label: 'Outstanding Amount', unit: '₹', desc: 'Total credit outstanding under KCC in Rs. Lakhs. Represents the cumulative utilization of KCC credit limits by farmers in the district.', fallbacks: ['total_outstanding', 'total_o_s_kcc_amt', 'kcc_outstanding', 'o_s_position_limit_sanctioned', 'kcc_limit_sanctioned_in_rs_lakhs', 'amount', 'outstanding_at_the_end_of_reporting_quarter_amt', 'amt', 'amount_disbursed'] },
          { field: 'no_of_rupay_card_issued', label: 'RuPay Cards Issued', unit: '', desc: 'KCC holders who received RuPay cards, enabling them to withdraw credit from ATMs and make purchases at PoS terminals.', fallbacks: ['rupay_card_issued', 'out_of_total_kcc_issued,_no_of_rupay_cards_issued_number', 'out_of_total_kcc_issued,_no_of_rupay_cards_issued_no'] },
          { field: 'kcc_card_activated', label: 'Cards Activated', unit: '', desc: 'KCC cards that have been activated by the holder — meaning at least one transaction has been done. Gap between issued and activated indicates dormant cards.', fallbacks: ['card_activated', 'kcc_card_activated_no', 'kcc_card_activated_number'] },
        ],
      },
      shg: {
        title: 'Self Help Groups',
        desc: 'Groups of 10-20 women who pool savings and take collective bank loans under NRLM/DAY-NRLM. The SHG-Bank Linkage Programme (SHG-BLP) is the world\'s largest microfinance program, covering 14+ crore households.',
        metrics: [
          { field: 'savings_linked_no', label: 'Savings Linked SHGs', unit: '', desc: 'SHGs that have opened a savings account with a bank. This is the first step in the SHG-Bank Linkage Programme — groups save collectively before becoming eligible for credit.', fallbacks: ['savings_linked', 'credit_linked_no', 'credit_linked', 'current_fy_savings_linked_no', 'no_of_shgs', 'deposit_linkage_no_of_groups', 'total_sanction_no', 'total_sanctioned', 'total_shgs_repeat_renewals_enhancement_fy_2025_26', 'disburdsement_target_no_of_shgs', 'no_of_shgs_credit_linked_as_on_31st_march_2023', 'cumulative_achievement_physical_7', 'target_physical_3', 'disbursement_no', 'outstanding_no', 'sanctioned_upto_dec25_no', 'sanctioned_upto_sep25_no', 'sanctioned_upto_jun25_no', 'sanctioned_upto_mar25_no', 'target_fy_2025_26_no'] },
          { field: 'credit_linked_no', label: 'Credit Linked SHGs', unit: '', desc: 'SHGs that have received a bank loan. Typically after 6 months of regular saving, groups become eligible for credit up to 4x their savings. A subset of savings-linked SHGs.', fallbacks: ['credit_linked', 'current_fy_credit_linked_no', 'credit_linkage_loan_given_by_banks_no', 'total_disbursement_no'] },
          { field: 'shg_o_s_amt', label: 'Outstanding Amount', unit: '₹', desc: 'Total bank loans outstanding to SHGs in the district, in Rs. Lakhs. Higher amounts with low NPA indicate healthy credit absorption by groups.', fallbacks: ['outstanding_amt', 'shg_o_s', 'outstanding_accounts', 'total_outsanding_no', 'total_outstanding_amt_rs_in_lakh'] },
          { field: 'shg_npa_pct', label: 'SHG NPA %', unit: '%', desc: 'Non-Performing Asset percentage for SHG loans. Loans overdue for 90+ days. Lower is better. SHG NPAs are typically much lower than overall bank NPAs due to group peer pressure.' },
        ],
      },
      digital_transactions: {
        title: 'Digital Transactions',
        desc: 'Digital payment adoption across districts — UPI transaction data from PhonePe Pulse (covers ~48% of India\'s UPI volume) plus SLBC digital coverage metrics for savings bank accounts.',
        timePoints: ['2024-03','2023-12','2023-09','2023-06','2023-03','2022-12','2022-09','2022-06','2022-03','2021-12','2021-09','2021-06','2021-03','2020-12','2020-09','2020-06'],
        metrics: [
          { field: 'transaction_count', label: 'UPI Transaction Count (PhonePe)', unit: '', desc: 'Total UPI transactions processed through PhonePe in the district during the quarter. PhonePe handles ~48% of all UPI transactions in India, making this a strong proxy for district-level digital payment adoption. Covers P2P transfers, merchant payments, and bill payments.' },
          { field: 'transaction_amount', label: 'UPI Transaction Amount (PhonePe)', unit: '₹', desc: 'Total value of UPI transactions in Rs. Lakhs via PhonePe. A proxy for digital economic activity and cashless adoption in the district.' },
          { field: 'coverage_sb_pct', label: 'SB Digital Coverage %', unit: '%', desc: 'Percentage of operative savings bank accounts covered by at least one digital payment mode (RuPay card, UPI, IMPS, USSD, or internet banking). The headline digital inclusion metric from SLBC data.', fallbacks: ['coverage_pct', 'achievement', 'pct_coverage', 'pct_coverag_e_h', 'pct_coverage_9688', 'of_such_accounts_out_of_total_operative_savings_accounts'] },
          { field: 'digital_coverage_sb_a_c', label: 'SB A/Cs Digitally Covered', unit: '', desc: 'Absolute number of savings bank accounts that have been enabled with at least one digital payment mode.', fallbacks: ['total_operative_sb_a_c', 'no_of_operative_sb_a_c_covered_with_at_least_one_digital_mode', 'debit_rupay_cards_coverage_total_no_of_accounts_covered', 'debit_rupay_cards_coverage_total_no_of_accounts_covered_g', 'coverage_with_at_least_one_of_the_digital_modes_of_payment_debit_rupay_cards,_in'] },
